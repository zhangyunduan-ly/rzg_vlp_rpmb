+    // for (int group = 0; group < KEY_GROUP_COUNT; group++) {
+    //     for (int key = 0; key < KEY_PER_GROUP; key++) {
+    //         DMSG("[RPMB CRC Verify]   key_len[%d][%d]: 0x%08X (%u)\n", 
+    //                group, key, storage->key_len[group][key], storage->key_len[group][key]);
+    //     }
+    // }
+
+    // 3. µēōÕŹ░key_dataõĖēń╗┤ÕŁŚĶŖéµĢ░ń╗ä’╝łÕ»åķÆźµĢ░µŹ«’╝īÕŹüÕģŁĶ┐øÕłČµĀ╝Õ╝Å’╝ē
+    DMSG("[RPMB CRC Verify] key_data array (hex format):\n");
+    // for (int group = 0; group < KEY_GROUP_COUNT; group++) {
+    //     for (int key = 0; key < KEY_PER_GROUP; key++) {
+    //         DMSG("[RPMB CRC Verify]   key_data[%d][%d]: ", group, key);
+    //         // ķĆÉÕŁŚĶŖéµēōÕŹ░Õ»åķÆźµĢ░µŹ«
+    //         for (int byte = 0; byte < sizeof(sce_aes_wrapped_key_t); byte++) {
+    //             DMSG("%02X ", storage->key_data[group][key][byte]);
+    //             // µ»Å16õĖ¬ÕŁŚĶŖéµŹóĶĪī’╝īµÅÉÕŹćÕÅ»Ķ»╗µĆ¦
+    //             if ((byte + 1) % 16 == 0 && byte != sizeof(sce_aes_wrapped_key_t) - 1) {
+    //                 DMSG("\n[RPMB CRC Verify]                    ");
+    //             }
+    //         }
+    //         DMSG("\n");
+    //     }
+    // }
+    DMSG("[RPMB CRC Verify] Finish printing RPMB_Key_Storage content\n");
+
+    // 1. Determine valid data area
+    const uint8_t *valid_data_start = (const uint8_t *)&(storage->rpmb_key_id);
+    uint32_t valid_data_len = sizeof(RPMB_Key_Storage) - sizeof(uint32_t);
+
+    // 2. Recalculate CRC32 for current valid data
+    uint32_t current_crc = calculate_crc32(valid_data_start, valid_data_len);
+
+    // 3. Print CRC values (hex format for standard CRC32 representation)
+    DMSG("[RPMB CRC Verify] Calculated CRC32 value: 0x%08X\n", current_crc);
+    DMSG("[RPMB CRC Verify] Stored CRC32 value:    0x%08X\n", storage->crc32_value);
+
+    // 4. Compare recalculated CRC with stored CRC in structure
+    if (current_crc == storage->crc32_value) {
+        DMSG("[RPMB CRC Verify] Verification passed\n");
+        return 0; // Verification passed
+    } else {
+        EMSG("[RPMB CRC Verify] Verification failed - CRC value mismatch\n");
+        return 1; // Verification failed
+    }
+}
