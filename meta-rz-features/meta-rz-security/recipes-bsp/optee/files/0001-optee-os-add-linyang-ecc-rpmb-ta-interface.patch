+/**
+ * Invert a field element with modulus p applying the Binary Extended Euclidean algorithm.
+ * C.f Hankerson, et. al, "Guide to Elliptic Curve Cryptography", Alg. 2.22
+ */
+void
+EscEccArithS0_Fe_ModularInvertInit(
+    EscEccArithS0_Fe_ModularInvertContext* ctx,
+    EscEcc_FieldElementT* c,
+    const EscEcc_FieldElementT* a,
+    const EscEcc_FieldT* fGP,
+    const Esc_UINT8 lenWords )
+{
+    Esc_UINT32 carry;
+    Esc_BOOL isFinished;
+
+    EscEccFe_Assign( &ctx->u, a, lenWords );
+    EscEccFe_Assign( &ctx->v, &fGP->prime_p, lenWords );
+    EscEccFe_SetZero( &ctx->x2 );
+    EscEccFe_SetOne( &ctx->x1 );
+
+    isFinished = FALSE;
+
+    if ( EscEccFe_IsOne( &ctx->u, lenWords ) )
+    {
+        isFinished = TRUE;
+    }
+    else if ( EscEccFe_IsOne( &ctx->v, lenWords ) )
+    {
+        isFinished = TRUE;
+    }
+    else
+    {
+        /* nothing */
+    }
+
+    while (isFinished == FALSE)
+    {
+        while ( (ctx->u.word[0] & 1U) == 0U )
+        {
+            EscEccFe_ShiftRight( &ctx->u, lenWords );
+            if ( (ctx->x1.word[0] & 1U) == 0U )
+            {
+                EscEccFe_ShiftRight( &ctx->x1, lenWords );
+            }
+            else
+            {
+                EscEccWd_AddCLoop( &carry, ctx->x1.word, ctx->x1.word, fGP->prime_p.word, lenWords );
+                EscEccFe_ShiftRight( &ctx->x1, lenWords );
+            }
+        }
+
+        while ( (ctx->v.word[0] & 1U) == 0U )
+        {
+            EscEccFe_ShiftRight( &ctx->v, lenWords );
+            if ( (ctx->x2.word[0] & 1U) == 0U )
+            {
+                EscEccFe_ShiftRight( &ctx->x2, lenWords );
+            }
+            else
+            {
+                EscEccWd_AddCLoop( &carry, ctx->x2.word, ctx->x2.word, fGP->prime_p.word, lenWords );
+                EscEccFe_ShiftRight( &ctx->x2, lenWords );
+            }
+        }
+
+        if (EscEccFe_AbsoluteCompare( &ctx->u, &ctx->v, lenWords ) > -1)
+        {
+            EscEccWd_SubBLoop( ctx->u.word, &carry, ctx->u.word, ctx->v.word, lenWords );
+            EscEccFe_ModularSub( &ctx->x1, &ctx->x1, &ctx->x2, fGP, lenWords );
+        }
+        else
+        {
+            EscEccWd_SubBLoop( ctx->v.word, &carry, ctx->v.word, ctx->u.word, lenWords );
+            EscEccFe_ModularSub( &ctx->x2, &ctx->x2, &ctx->x1, fGP, lenWords );
+        }
+
+        if ( EscEccFe_IsOne( &ctx->u, lenWords ) )
+        {
+            isFinished = TRUE;
+        }
+        else if ( EscEccFe_IsOne( &ctx->v, lenWords ) )
+        {
+            isFinished = TRUE;
+        }
+        else
+        {
+            /* nothing */
+        }
+    }
+
+    if ( EscEccFe_IsOne( &ctx->u, lenWords ) )
+    {
+        EscEccFe_Assign( c, &ctx->x1, lenWords );
+    }
+    else
+    {
+        EscEccFe_Assign( c, &ctx->x2, lenWords );
+    }
+}
+
+Esc_ERROR
+EscEccArithS0_Fe_ModularInvertRun(
+    EscEccArithS0_Fe_ModularInvertContext* ctx )
+{
+    Esc_UNUSED_PARAM (ctx);
+
+    return Esc_NO_ERROR;
+}
+
+
+void
+EscEccArithS0_Pt_ToAffineInit(
+    EscEccArithS0_Pt_ToAffineContext* ctx,
+    EscEcc_PointT* pA,
+    const EscEcc_PointT* pJ,
+    const EscEcc_CurveT* curve)
+{
+    Esc_ASSERT( pJ->type == C_PT_JACOBIAN );
+
+    if ( EscEccPt_IsInfinity( pJ, curve ) )
+    {
+        /* set pA type */
+        pA->type = C_PT_AFFINE;
+        /* pA = (0) */
+        EscEccPt_SetInfinity( pA );
+    }
+    else
+    {
+        /* pJ(1/z) : 1I */
+        EscEccArithS0_Fe_ModularInvertInit( &ctx->modInvertCtx, &ctx->fe_z_inv1_3, &pJ->z, &curve->ecc_field_params, curve->maxWords );
+        /* pJ(1/z2) : 1S */
+        EscEccFe_MultiplyModP( &ctx->fe_z_inv2, &ctx->fe_z_inv1_3, &ctx->fe_z_inv1_3, curve );
+        /* pJ(1/z3) : 1M */
+        EscEccFe_MultiplyModP( &ctx->fe_z_inv1_3, &ctx->fe_z_inv1_3, &ctx->fe_z_inv2, curve );
+        /* pA(x) = pJ(x/z2) : 1M */
+        EscEccFe_MultiplyModP( &pA->x, &pJ->x, &ctx->fe_z_inv2, curve );
+        /* pA(y) = pJ(y/z3) : 1M */
+        EscEccFe_MultiplyModP( &pA->y, &pJ->y, &ctx->fe_z_inv1_3, curve );
+        /* pA(z) = 0 */
+        EscEccFe_SetZero( &pA->z );
+        /* set pA type */
+        pA->type = C_PT_AFFINE;
+    }
+}
+
+Esc_ERROR
+EscEccArithS0_Pt_ToAffineRun(
+    EscEccArithS0_Pt_ToAffineContext* ctx )
+{
+    Esc_UNUSED_PARAM (ctx);
+
+    return Esc_NO_ERROR;
+}
+
+
+/***********************************************
+ * scalar multiplication of unknown pA1 with k *
+ ***********************************************/
+void
+EscEccArithS0_Pt_JacobianMultiplyBinaryInit(
+    EscEccArithS0_Pt_JacobianMultiplyBinaryContext* ctx,
+    EscEcc_PointT* pJ,
+    const EscEcc_FieldElementT* k,
+    const EscEcc_PointT* pA1,
+    const EscEcc_CurveT* curve )
+{
+    const Esc_UINT8 maxWords = curve->maxWords;
+
+#if EscEcc_USE_SLIDING_WINDOW == 1
+    Esc_ASSERT( pA1->type == C_PT_AFFINE );
+
+    /* check P = (0) */
+    if (EscEccPt_IsZero( pA1, curve ) == FALSE)
+    {
+        Esc_SINT16 bitIndex, j, windowsize;
+        Esc_UINT16 exponent, n;
+
+        /* precomputation - bitIndex < ((2^k_m) / 2) + 1 */
+        ctx->precompArray[0].type = C_PT_JACOBIAN;
+        EscEccFe_Assign( &ctx->precompArray[0].x, &pA1->x, maxWords );
+        EscEccFe_Assign( &ctx->precompArray[0].y, &pA1->y, maxWords );
+        EscEccFe_SetOne( &ctx->precompArray[0].z );
+
+        /* pJ = (0) */
+        pJ->type = C_PT_JACOBIAN;
+        EscEccPt_SetInfinity( pJ );
+
+        /* Compute 2 x pJ, use last element of precomp array as temporary location */
+        EscEccPt_JacobianDouble( &ctx->precompArray[EscEcc_NUM_WINDOW_ELEMENTS - 1], &ctx->precompArray[0], curve );
+
+        for (j = 1; j < (Esc_SINT16)EscEcc_NUM_WINDOW_ELEMENTS; j++)
+        {
+            EscEccPt_JacobianAdd( &ctx->precompArray[j], &ctx->precompArray[j - 1], &ctx->precompArray[EscEcc_NUM_WINDOW_ELEMENTS - 1], curve );
+        }
+
+        bitIndex = (Esc_SINT16)( (Esc_SINT16)maxWords * (Esc_SINT16)EscEcc_WORD_BITS ) - 1;
+
+        while (bitIndex >= 0)
+        {
+            /* if Exponent = 0 double only */
+            if (EscEccFe_isBitSet( k, bitIndex ) == FALSE)
+            {
+                EscEccPt_JacobianDouble( pJ, pJ, curve );
+                bitIndex--;
+            }
+            else
+            {
+                /* build window */
+                exponent = 0U;
+                n = (Esc_UINT16)(EscEcc_WINDOW_SIZE - 1U);
+                windowsize = (Esc_SINT16)EscEcc_WINDOW_SIZE;
+                for (j = bitIndex; ( j > (bitIndex - (Esc_SINT16)EscEcc_WINDOW_SIZE) ) && (j >= 0); j--)
+                {
+                    /* build temporary exponent */
+                    if (EscEccFe_isBitSet( k, j ) == TRUE)
+                    {
+                        exponent += (Esc_UINT16)( ( (Esc_UINT16)1U ) << n );
+                    }
+                    n--;
+                }
+                bitIndex -= (Esc_SINT16)EscEcc_WINDOW_SIZE;
+                /* make window odd and adjust bitIndex, reduce window size */
+                while ( (exponent % 2U) == 0U )
+                {
+                    exponent = (Esc_UINT16)(exponent / 2U);
+                    bitIndex++;
+                    windowsize--;
+                }
+
+                /* double */
+                for (j = 0; j < windowsize; j++)
+                {
+                    EscEccPt_JacobianDouble( pJ, pJ, curve );
+                }
+
+                /* Assert that exponent/2 is within bounds of precompArray */
+                Esc_ASSERT( (exponent / 2U) < EscEcc_NUM_WINDOW_ELEMENTS );
+
+                /* add */
+                EscEccPt_JacobianAdd( pJ, pJ, &ctx->precompArray[exponent / 2U], curve );
+            }
+        }
+    }
+    else
+    {
+        /* return Zero point */
+        pJ->type = C_PT_JACOBIAN;
+        EscEccPt_SetInfinity( pJ );
+    }
+
+#else /* EscEcc_USE_SLIDING_WINDOW */
+    Esc_ASSERT( pA1->type == C_PT_AFFINE );
+
+    ctx->pTemp.type = C_PT_JACOBIAN;
+    /* pJx = pXx */
+    EscEccFe_Assign( &ctx->pTemp.x, &pA1->x, maxWords );
+    /* pJy = pXy */
+    EscEccFe_Assign( &ctx->pTemp.y, &pA1->y, maxWords );
+    /* pJz = 1 */
+    EscEccFe_SetOne( &ctx->pTemp.z );
+
+    /* check P = (0) */
+    if ( EscEccPt_IsZero( pA1, curve ) == FALSE )
+    {
+        Esc_SINT16 i;
+        /* set pJ = 0 */
+        pJ->type = C_PT_JACOBIAN;
+        EscEccPt_SetInfinity( pJ );
+
+        for (i = (Esc_SINT16)maxWords - 1; i >= 0; i--)
+        {
+            Esc_UINT16 j;
+            Esc_UINT32 temp;
+
+            temp = k->word[i];
+
+            for (j = 0U; j < EscEcc_WORD_BITS; j++)
+            {
+                EscEccPt_JacobianDouble( pJ, pJ, curve );
+
+                if ( (temp & 0x80000000U) != 0U )          /* highest bit set */
+                {
+                    EscEccPt_JacobianAdd( pJ, pJ, &ctx->pTemp, curve );
+                }
+                temp <<= 1;
+            }
+        }
+    }
+    else
+    {
+        /* return Zero point */
+        pJ->type = C_PT_JACOBIAN;
+        EscEccPt_SetInfinity( pJ );
+    }
+#endif /* EscEcc_USE_SLIDING_WINDOW */
+}
+
+Esc_ERROR
+EscEccArithS0_Pt_JacobianMultiplyBinaryRun(
+    EscEccArithS0_Pt_JacobianMultiplyBinaryContext* ctx )
+{
+    Esc_UNUSED_PARAM (ctx);
+
+    return Esc_NO_ERROR;
+}
+
+
+/*************************************************
+ * calculate k0 * G + k1 * Q with Shamir's trick *
+ *************************************************/
+#if EscEcc_ENABLE_SHAMIRS_TRICK == 1
+void
+EscEccArithS0_Pt_JacDualMulAddBinInit(
+    EscEccArithS0_Pt_JacDualMulAddBinContext* ctx,
+    EscEcc_PointT* pJ,
+    const EscEcc_FieldElementT* k0,
+    const EscEcc_PointT* pA0,
+    const EscEcc_FieldElementT* k1,
+    const EscEcc_PointT* pA1,
+    const EscEcc_CurveT* curve )
+{
+    const Esc_UINT8 maxWords = curve->maxWords;
+    Esc_SINT16 i;
+
+    Esc_ASSERT( pA0->type == C_PT_AFFINE );
+    Esc_ASSERT( pA1->type == C_PT_AFFINE );
+
+    ctx->pPA0.type = C_PT_JACOBIAN;
+    /* pPAx = pAx */
+    EscEccFe_Assign( &ctx->pPA0.x, &pA0->x, maxWords );
+    /* pPAy = pAy */
+    EscEccFe_Assign( &ctx->pPA0.y, &pA0->y, maxWords );
+    /* pPAz = 1 */
+    EscEccFe_SetOne( &ctx->pPA0.z );
+
+    ctx->pPA1.type = C_PT_JACOBIAN;
+    /* pPAx = pAx */
+    EscEccFe_Assign( &ctx->pPA1.x, &pA1->x, maxWords );
+    /* pPAy = pAy */
+    EscEccFe_Assign( &ctx->pPA1.y, &pA1->y, maxWords );
+    /* pPAz = 1 */
+    EscEccFe_SetOne( &ctx->pPA1.z );
+
+    /* set pJ type */
+    pJ->type = C_PT_JACOBIAN;
+    EscEccPt_SetInfinity( pJ );
+
+    /* precompute Q + G */
+    EscEccPt_JacobianAdd( &ctx->pQPlusG, &ctx->pPA0, &ctx->pPA1, curve );
+
+    i = ( (Esc_SINT16)maxWords * (Esc_SINT16)EscEcc_WORD_BITS ) - 1;
+
+    /* skip common leading zeros of k0 and k1 */
+    while ( !( (EscEccFe_isBitSet( k0, i ) == TRUE) || (EscEccFe_isBitSet( k1, i ) == TRUE) ) )
+    {
+        i--;
+    }
+
+    for (;;)
+    {
+        if ( EscEccFe_isBitSet( k0, i ) )
+        {
+            if ( EscEccFe_isBitSet( k1, i ) )
+            {
+                /* k0=1 k1=1 */
+                EscEccPt_JacobianAdd( pJ, pJ, &ctx->pQPlusG, curve );
+            }
+            else
+            {
+                /* k0=1 k1=0 */
+                EscEccPt_JacobianAdd( pJ, pJ, &ctx->pPA0, curve );
+            }
+        }
+        else
+        {
+            if ( EscEccFe_isBitSet( k1, i ) )
+            {
+                /* k0=0 k1=1 */
+                EscEccPt_JacobianAdd( pJ, pJ, &ctx->pPA1, curve );
+            }
+        }
+        i--;
+
+        if (i < 0)
+        {
+            break;
+        }
+
+        EscEccPt_JacobianDouble( pJ, pJ, curve );
+    }
+}
+
+Esc_ERROR
+EscEccArithS0_Pt_JacDualMulAddBinRun(
+    EscEccArithS0_Pt_JacDualMulAddBinContext* ctx )
+{
+    Esc_UNUSED_PARAM (ctx);
+
+    return Esc_NO_ERROR;
+}
+#endif /* EscEcc_ENABLE_SHAMIRS_TRICK */
