+    const uint8_t *valid_data_start = (const uint8_t *)&(storage->ecc_key_data);
+    uint32_t valid_data_len = sizeof(ECC_RPMB_Key_Storage) - sizeof(uint32_t);
+    uint32_t current_crc = calculate_crc32(valid_data_start, valid_data_len);
+
+    // µēōÕŹ░CRCÕĆ╝
+    DMSG("[ECC CRC Verify] Calculated CRC32: 0x%08X, Stored CRC32: 0x%08X", current_crc, storage->crc32_value);
+
+    return (current_crc == storage->crc32_value) ? 0 : 1;
+}
