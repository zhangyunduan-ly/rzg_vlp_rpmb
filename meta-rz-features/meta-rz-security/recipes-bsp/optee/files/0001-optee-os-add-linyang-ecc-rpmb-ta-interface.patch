+typedef enum {
+    TEE_RPMB_DATA_RAW = 0,                  // µÖ«ķĆÜÕŁŚĶŖéµĄü’╝łAKńö©’╝ē
+    TEE_RPMB_DATA_SCE_WRAPPED = 1           // sce_aes_wrapped_key_tń╗ōµ×äõĮō’╝łEK/BK/MKńö©’╝ē
+} TEE_RPMB_Data_Type;
+
+
+TEE_Result TA_InvokeCommandEntryPoint(void __unused *session,
+				      uint32_t command,
+				      uint32_t param_types,
+				      TEE_Param params[4])
+{
+	switch (command) {
+
+	case TA_SECURE_STORAGE_CMD_WRITE_RAW:
+		DMSG("\r\n Now is writing to RPMB!!");
+		return create_raw_object(param_types, params);
+
+	case TA_SECURE_STORAGE_CMD_READ_ONLY:
+		DMSG("\r\n Now is reading from RPMB directly!!");
+		return read_raw_object(param_types, params);
+
+	case TA_SECURE_STORAGE_CMD_FROM_RAM:
+		DMSG("\r\n Reading from RAM now!!!");
+		return read_raw_object_from_ram(param_types, params);
+
+	case TA_SECURE_STORAGE_CMD_DELETE:
+		DMSG("\r\n Deleteing RPMB now!!!");
+		return delete_object(param_types, params);
+
+	case TA_SECURE_STORAGE_CMD_READ_TO_RAM:
+		DMSG("\r\n Reading RPMB to RAM now!!!");
+		return read_raw_object_to_ram(param_types, params);
+
+	default:
+		EMSG("Command ID 0x%x is not supported", command);
+		return TEE_ERROR_NOT_SUPPORTED;
+	}
+}
