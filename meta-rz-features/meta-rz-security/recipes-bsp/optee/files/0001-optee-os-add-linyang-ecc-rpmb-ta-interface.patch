+
+/***************************************************************************
+ * 2. DEFINES                                                              *
+ ***************************************************************************/
+
+/***************************************************************************
+ * 3. DEFINITIONS                                                          *
+ ***************************************************************************/
+
+/*
+   The functions are classified in four types:
+   Word arithmetic - EscEccWd_*
+   Field arithmetic - EscEccFe_*
+   Point arithmetic - EscEccPt_*
+   Miscellaneous - EscEcc_*
+ */
+
+/* Word arithmetic */
+#if Esc_HAS_INT64 == 0
+static void
+EscEccWd_Inc(
+    Esc_UINT32* hi,
+    Esc_UINT32* lo,
+    Esc_UINT32 increment );
+
+#endif
+static void
+EscEccWd_AddC(
+    Esc_UINT32* carry,
+    Esc_UINT32* c,
+    const Esc_UINT32 a,
+    const Esc_UINT32 b );
+
+static void
+EscEccWd_SubB(
+    Esc_UINT32* borrow,
+    Esc_UINT32* c,
+    Esc_UINT32 a,
