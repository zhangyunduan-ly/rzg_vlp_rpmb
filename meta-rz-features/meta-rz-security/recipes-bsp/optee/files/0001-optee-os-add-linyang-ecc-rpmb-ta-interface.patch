+}
+
+/*
+ * SHA-256 context setup
+ */
+void SERVp_hash_sha256_starts(SERVp_hash_sha256_state *ctx)
+{
+  ctx->total[0] = 0;
+  ctx->total[1] = 0;
+
+  /* SHA-256 */
