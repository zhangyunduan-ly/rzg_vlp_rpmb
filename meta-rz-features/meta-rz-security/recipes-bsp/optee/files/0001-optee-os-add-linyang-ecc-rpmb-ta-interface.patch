new file mode 100644
index 00000000..23afc0b6
--- /dev/null
+++ b/ta/ly_ecc/include/SERVp_hash_MD5.h
@@ -0,0 +1,35 @@
+#ifndef SERVP_SHA_MD5_H  
+#define SERVP_SHA_MD5_H  
+
+#include <stddef.h>
+#include <stdint.h>
+#include "SERVp_macro_type.h"
+//#include "cxType.h"
+
+typedef struct  
+{  
+    unsigned int count[2];  
+    unsigned int state[4];  
+    unsigned char buffer[64];     
+}SERVp_hash_MD5_CTX;  
+  
+  
+#define MD5_F(x,y,z) ((x & y) | (~x & z))  
+#define MD5_G(x,y,z) ((x & z) | (y & ~z))  
+#define MD5_H(x,y,z) (x^y^z)  
+#define MD5_I(x,y,z) (y ^ (x | ~z))  
+#define ROTATE_LEFT(x,n) ((x << n) | (x >> (32-n)))  
+#define FF(a,b,c,d,x,s,ac)      { a += MD5_F(b,c,d) + x + ac; a = ROTATE_LEFT(a,s); a += b; }  
+#define GG(a,b,c,d,x,s,ac)      { a += MD5_G(b,c,d) + x + ac; a = ROTATE_LEFT(a,s); a += b; }  
+#define HH(a,b,c,d,x,s,ac)      { a += MD5_H(b,c,d) + x + ac; a = ROTATE_LEFT(a,s); a += b; }  
+#define II(a,b,c,d,x,s,ac)      { a += MD5_I(b,c,d) + x + ac; a = ROTATE_LEFT(a,s); a += b; }                                              
+
+void SERVp_hash_MD5Init(SERVp_hash_MD5_CTX *context);  
+void SERVp_hash_MD5Update(SERVp_hash_MD5_CTX *context,unsigned char *input,unsigned int inputlen);  
+void SERVp_hash_MD5Final(SERVp_hash_MD5_CTX *context,unsigned char digest[16]);  
+void SERVp_hash_MD5Transform(unsigned int state[4],unsigned char block[64]);  
+void SERVp_hash_MD5Encode(unsigned char *output,unsigned int *input,unsigned int len);  
+void SERVp_hash_MD5Decode(unsigned int *output,unsigned char *input,unsigned int len);  
+void SERVp_hash_MD5( unsigned char *input, size_t ilen, unsigned char output[16]);
+
+#endif 
