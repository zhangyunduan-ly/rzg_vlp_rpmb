+static TEE_Result create_raw_object(uint32_t param_types, TEE_Param params[4]) {
+    const uint32_t exp_param_types =
+        TEE_PARAM_TYPES(TEE_PARAM_TYPE_MEMREF_INPUT,
+                        TEE_PARAM_TYPE_MEMREF_INPUT,
+                        TEE_PARAM_TYPE_NONE,
+                        TEE_PARAM_TYPE_NONE);
+    TEE_ObjectHandle object;
+    TEE_Result res;
+    char *obj_id;
+    size_t obj_id_sz;
+    char *data;
+    size_t data_sz;
+    uint32_t obj_data_flag;
+    uint32_t *p_rpmb_key_id = NULL;
+    int cache_idx = -1;
+    RPMB_Key_Storage *p_cache_data = NULL;
+    ECC_RPMB_Key_Storage *tmp_cache = NULL;
+    const char *tmp_name = NULL;
+
+    // ÕģźÕÅéń▒╗Õ×ŗµĀĪķ¬ī
+    if (param_types != exp_param_types)
+        return TEE_ERROR_BAD_PARAMETERS;
+
+    // Õ«ēÕģ©ĶÄĘÕÅ¢obj_id
+    obj_id_sz = params[0].memref.size;
+    obj_id = TEE_Malloc(obj_id_sz, 0);
+    if (!obj_id)
+        return TEE_ERROR_OUT_OF_MEMORY;
+    TEE_MemMove(obj_id, params[0].memref.buffer, obj_id_sz);
+
+    // Õ«ēÕģ©ĶÄĘÕÅ¢ÕŠģÕåÖÕģźµĢ░µŹ«
+    data_sz = params[1].memref.size;
+    data = TEE_Malloc(data_sz, 0);
+    if (!data) {
+        TEE_Free(obj_id);
+        return TEE_ERROR_OUT_OF_MEMORY;
+    }
+    TEE_MemMove(data, params[1].memref.buffer, data_sz);
+
+    // ÕłøÕ╗║RPMBµīüõ╣ģÕī¢Õ»╣Ķ▒Ī
+    obj_data_flag = TEE_DATA_FLAG_ACCESS_READ |
+                    TEE_DATA_FLAG_ACCESS_WRITE |
+                    TEE_DATA_FLAG_ACCESS_WRITE_META |
+                    TEE_DATA_FLAG_OVERWRITE;
+    res = TEE_CreatePersistentObject(TEE_STORAGE_PRIVATE_RPMB, obj_id, obj_id_sz,
+                                     obj_data_flag, TEE_HANDLE_NULL, NULL, 0, &object);
+    if (res != TEE_SUCCESS) {
+        EMSG("TEE_CreatePersistentObject failed 0x%08x", res);
+        TEE_Free(obj_id);
+        TEE_Free(data);
+        return res;
+    }
+    DMSG("Write data to RPMB success! key_id=0x%08X, data_len=%zu Bytes", *(uint32_t*)obj_id, data_sz);
+    // Ķ¦Żµ×Ékey_id
+    p_rpmb_key_id = (uint32_t *)obj_id;
+
+    // ========== Õłåµö»1’╝ÜKUK0/KUK1ÕżäńÉå ==========
+    if ((*p_rpmb_key_id == KUK0_RPMB_KEY_ID) || (*p_rpmb_key_id == KUK1_RPMB_KEY_ID)) {
+
+        if (data_sz != sizeof(KUK_RPMB_Storage)) {
+            EMSG("KUK data size mismatch! expect %zu, got %zu", sizeof(KUK_RPMB_Storage), data_sz);
+            TEE_CloseObject(object);
+            TEE_Free(obj_id);
+            TEE_Free(data);
+            return TEE_ERROR_BAD_PARAMETERS;
+        }
+        res = TEE_WriteObjectData(object, data, data_sz);
+        if (res != TEE_SUCCESS) {
+            EMSG("KUK TEE_WriteObjectData failed 0x%08x", res);
+            TEE_CloseAndDeletePersistentObject1(object);
+            TEE_Free(obj_id);
+            TEE_Free(data);
+            return res;
+        }
+        TEE_CloseObject(object);
+        
+        // ÕÉīµŁźÕł░KUK0ń╝ōÕŁś
+        memset((void*)&g_kuk0_cache, 0, sizeof(KUK_RPMB_Storage));
+        TEE_MemMove((void*)&g_kuk0_cache, data, sizeof(KUK_RPMB_Storage));
+        DMSG("KUK stored to RPMB success! key_id=0x%08X, valid=%d", 
+             *p_rpmb_key_id, ((KUK_RPMB_Storage*)data)->valid);
+    }
+    // ========== Õłåµö»2’╝ÜECCÕ»åķÆźń╗¤õĖĆÕżäńÉå ==========
+    else if (get_ecc_cache_by_key_id(*p_rpmb_key_id, &tmp_cache, &tmp_name) == TEE_SUCCESS) {
+        ECC_RPMB_Key_Storage *p_ecc_data = (ECC_RPMB_Key_Storage *)data;
+        ECC_RPMB_Key_Storage *ecc_cache = NULL;
+        const char *cache_name = NULL;
+
+        // µĀĪķ¬īµĢ░µŹ«ķĢ┐Õ║”
+        if (data_sz != sizeof(ECC_RPMB_Key_Storage)) {
+            EMSG("ECC key data size mismatch! expect %zu, got %zu", sizeof(ECC_RPMB_Key_Storage), data_sz);
+            TEE_CloseObject(object);
+            TEE_Free(obj_id);
+            TEE_Free(data);
+            return TEE_ERROR_BAD_PARAMETERS;
+        }
+
+        // Ķ«ŠńĮ«µ£ēµĢłµĆ¦µĀćĶ«░
+        for (int group = 0; group < ECC_KEY_GROUP_COUNT; group++) {
+            for (int type = 0; type < ASYKEY_TYPE_COUNT; type++) {
+                p_ecc_data->ecc_key_valid[group][type] = 1;
+            }
+        }
+        DMSG("ECC key valid flags updated: all [group][type] marked as 1 (valid)");
+
+        // Ķ«Īń«ŚCRC
+        update_ecc_key_crc(p_ecc_data); 
+        DMSG("ECC key CRC32 calculated: 0x%08X (key_id=0x%08X)", p_ecc_data->crc32_value, *p_rpmb_key_id);
+
+        // ÕåÖÕģźRPMB
+        res = TEE_WriteObjectData(object, data, data_sz);
+        if (res != TEE_SUCCESS) {
+            EMSG("ECC key TEE_WriteObjectData failed 0x%08x", res);
+            TEE_CloseAndDeletePersistentObject1(object);
+            TEE_Free(obj_id);
+            TEE_Free(data);
+            return res;
+        }
+        TEE_CloseObject(object);
+
+        // ĶÄĘÕÅ¢Õ»╣Õ║öń╝ōÕŁśÕ╣ČÕÉīµŁź
+        get_ecc_cache_by_key_id(*p_rpmb_key_id, &ecc_cache, &cache_name);
+        memset((void*)ecc_cache, 0, sizeof(ECC_RPMB_Key_Storage));
+        TEE_MemMove((void*)ecc_cache, data, sizeof(ECC_RPMB_Key_Storage));
+        TEE_CacheClean((void*)ecc_cache, sizeof(ECC_RPMB_Key_Storage));
+        
+        DMSG("ECC key stored to RPMB success! sync to %s (CRC=0x%08X)", 
+             cache_name, ecc_cache->crc32_value);
+        
+        // µēōÕŹ░µ£ēµĢłµĆ¦µĀćĶ«░
+        IMSG("ECC key valid flags in cache (%s):", cache_name);
+        for (int group = 0; group < ECC_KEY_GROUP_COUNT; group++) {
+            for (int type = 0; type < ASYKEY_TYPE_COUNT; type++) {
+                IMSG("  [group:%d][type:%d] valid = %d", group, type, ecc_cache->ecc_key_valid[group][type]);
+            }
+        }
+    }
+    // ========== Õłåµö»3’╝ÜķĆÜńö©Õ»åķÆźÕżäńÉå ==========
+    else {
+        RPMB_Key_Storage *p_common_data = (RPMB_Key_Storage *)data;
+
+        if (data_sz != sizeof(RPMB_Key_Storage)) {
+            EMSG("Common key data size mismatch! expect %zu, got %zu", sizeof(RPMB_Key_Storage), data_sz);
+            TEE_CloseObject(object);
+            TEE_Free(obj_id);
+            TEE_Free(data);
+            return TEE_ERROR_BAD_PARAMETERS;
+        }
+        // ÕĪ½ÕģģÕ¤║ńĪĆÕŁŚµ«ĄÕ╣ČĶ«Īń«ŚCRC
+        p_common_data->rpmb_key_id = *p_rpmb_key_id;
+        p_common_data->is_valid = 1;
+        update_rpmb_key_crc(p_common_data);
+        DMSG("Common key fields filled and CRC32 updated: key_id=0x%08X, is_valid=%d, crc32=0x%08X",
+             p_common_data->rpmb_key_id, p_common_data->is_valid, p_common_data->crc32_value);
+
+        // ÕåÖÕģźRPMB
+        res = TEE_WriteObjectData(object, data, data_sz);
+        if (res != TEE_SUCCESS) {
+            EMSG("Common key TEE_WriteObjectData failed 0x%08x", res);
+            TEE_CloseAndDeletePersistentObject1(object);
+            TEE_Free(obj_id);
+            TEE_Free(data);
+            return res;
+        }
+        TEE_CloseObject(object);
+        DMSG("Common key stored to RPMB success! key_id=0x%08X", *p_rpmb_key_id);
+
+        // ÕÉīµŁźÕł░ķĆÜńö©ń╝ōÕŁś
+        cache_idx = rpmb_cache_alloc_or_find_idx(*p_rpmb_key_id);
+        if (cache_idx < 0) {
+            EMSG("g_rpmb_key_cache is full! can not sync data\r\n");
+        } else {
+            p_cache_data = (RPMB_Key_Storage *)&g_rpmb_key_cache[cache_idx];
+            memset((void*)p_cache_data, 0, sizeof(RPMB_Key_Storage));
+            TEE_MemMove((void*)p_cache_data, data, sizeof(RPMB_Key_Storage));
+            DMSG("Sync common key to g_rpmb_key_cache success! key_id=0x%08X, cache_idx=%d, is_valid=%d",
+                 *p_rpmb_key_id, cache_idx, p_cache_data->is_valid);
+        }
+    }
+
+    // ķćŖµöŠÕåģÕŁś
+    TEE_Free(obj_id);
+    TEE_Free(data);
+    return res;
+}
