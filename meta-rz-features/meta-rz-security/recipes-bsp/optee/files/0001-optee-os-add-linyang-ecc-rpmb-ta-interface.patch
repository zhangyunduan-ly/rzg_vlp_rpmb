+    /* Update chaining vars */  
+    hd->h0 += a;  
+    hd->h1 += b;  
+    hd->h2 += c;  
+    hd->h3 += d;  
+    hd->h4 += e;  
+}  
+  
+  
+/* Update the message digest with the contents  
+ * of INBUF with length INLEN.  
+ */  
+void SERVp_hash_sha1_write( SERVp_hash_SHA1_CONTEXT *hd, unsigned char *inbuf, size_t inlen)  
+{  
+    if( hd->count == 64 ) { /* flush the buffer */  
+		if((NULL != hd->SHAquitCondition)&&(true == hd->SHAquitCondition()))//µÄēńöĄÕÅŖµŚČķĆĆÕć║
+		{
+			hd->count = 0;
+			hd->nblocks = 0;
+			return ;
+		}
+        SERVp_hash_Sha1transform( hd, hd->buf );  
+        hd->count = 0;  
+        hd->nblocks++;  
+    }  
+    if( !inbuf )  
+	{
+        return;  
+	}
+    if( hd->count ) {  
+        for( ; inlen && hd->count < 64; inlen-- )  
+		{
+            hd->buf[hd->count++] = *inbuf++;  
+		}
+        SERVp_hash_sha1_write( hd, NULL, 0 );  
+        if( !inlen )  
+		{
+            return;  
+		}
+    }  
+  
+    while( inlen >= 64 ) { 
+
+		if((NULL != hd->SHAquitCondition)&&(true == hd->SHAquitCondition()))//µÄēńöĄÕÅŖµŚČķĆĆÕć║
+		{
+			hd->count = 0;
+			hd->nblocks = 0;
+			return ;
+		}
+
+        SERVp_hash_Sha1transform( hd, inbuf );  
+        hd->count = 0;  
+        hd->nblocks++;  
+        inlen -= 64;  
+        inbuf += 64;  
+    }  
+    for( ; inlen && hd->count < 64; inlen-- )  
+	{
+        hd->buf[hd->count++] = *inbuf++;  
+	}
+}  
+  
+  
+/* The routine final terminates the computation and  
+ * returns the digest.  
+ * The handle is prepared for a new cycle, but adding bytes to the  
+ * handle will the destroy the returned buffer.  
+ * Returns: 20 bytes representing the digest.  
+ */  
+  
+void SERVp_hash_sha1_final(SERVp_hash_SHA1_CONTEXT *hd)  
+{  
+    u32 t, msb, lsb;  
+    unsigned char *p;  
+  
+    SERVp_hash_sha1_write(hd, NULL, 0); /* flush */;  
+  
+    t = hd->nblocks;  
+    /* multiply by 64 to make a byte count */  
+    lsb = t << 6;  
+    msb = t >> 26;  
+    /* add the count */  
+    t = lsb;  
+    if( (lsb += hd->count) < t )  
+	{
+        msb++;  
+	}
+    /* multiply by 8 to make a bit count */  
+    t = lsb;  
+    lsb <<= 3;  
+    msb <<= 3;  
+    msb |= t >> 29;  
+  
+    if( hd->count < 56 ) { /* enough room */  
+        hd->buf[hd->count++] = 0x80; /* pad */  
+        while( hd->count < 56 )  
+		{
+            hd->buf[hd->count++] = 0;  /* pad */  
+		}
+    }  
+    else { /* need one extra block */  
+        hd->buf[hd->count++] = 0x80; /* pad character */  
+        while( hd->count < 64 )  
+		{
+            hd->buf[hd->count++] = 0;  
+		}
+        SERVp_hash_sha1_write(hd, NULL, 0);  /* flush */;  
+        memset(hd->buf, 0, 56 ); /* fill next block with zeroes */  
+    }  
+    /* append the 64 bit count */  
+    hd->buf[56] = msb >> 24;  
+    hd->buf[57] = msb >> 16;  
+    hd->buf[58] = msb >>  8;  
+    hd->buf[59] = msb       ;  
+    hd->buf[60] = lsb >> 24;  
+    hd->buf[61] = lsb >> 16;  
+    hd->buf[62] = lsb >>  8;  
+    hd->buf[63] = lsb       ;  
+	if((NULL != hd->SHAquitCondition)&&(true == hd->SHAquitCondition()))//µÄēńöĄÕÅŖµŚČķĆĆÕć║
+	{
+		hd->count = 0;
+		hd->nblocks = 0;
+		return ;
+	}
+    SERVp_hash_Sha1transform( hd, hd->buf );  
+  
+    p = hd->buf;  
+#ifdef BIG_ENDIAN_HOST  
+#define X(a) do { *(u32*)p = hd->h##a ; p += 4; } while(0)  
+#else /* little endian */  
+#define X(a) do { *p++ = hd->h##a >> 24; *p++ = hd->h##a >> 16;\
+        *p++ = hd->h##a >> 8; *p++ = hd->h##a; } while(0)  
+#endif  
+    X(0);  
+    X(1);  
+    X(2);  
+    X(3);  
+    X(4);  
+#undef X  
+} 
+
+
+
+void SERVp_hash_sha1( unsigned char *input, size_t ilen, unsigned char output[20],B_FUN_V SHAquitCondition)
+{
+#ifdef	CFGSHA1_hardWareEnable
+	return;//µÜéõĖŹµö»µīüńĪ¼õ╗Čsha1
+#else
+     SERVp_hash_SHA1_CONTEXT ctx;
+
+     SERVp_hash_sha1_init (&ctx,SHAquitCondition);    
+     SERVp_hash_sha1_write (&ctx, input, ilen);   
+     SERVp_hash_sha1_final (&ctx);
+ 	 memcpy(&output[0],&ctx.buf[0],20);
+#endif	//CFGSHA1_hardWareEnable
+}
+  
+  
+  
+/*  
+Local Variables:  
+compile-command: "cc -Wall -g -o sha1sum sha1sum.c"  
+End:  
+*/ 
