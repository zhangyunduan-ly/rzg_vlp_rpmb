index 00000000..7bc7a275
--- /dev/null
+++ b/ta/ly_ecc/include/ecc_cfg.h
@@ -0,0 +1,184 @@
+/***************************************************************************
+ * This file is part of the cryptographic library CycurLIB                 *
+ *                                                                         *
