+        unsigned char *p2;  
+        for(i=0, p2=(unsigned char*)x; i < 16; i++, p2 += 4 ) {  
+            p2[3] = *data++;  
+            p2[2] = *data++;  
+            p2[1] = *data++;  
+            p2[0] = *data++;  
+        }  
