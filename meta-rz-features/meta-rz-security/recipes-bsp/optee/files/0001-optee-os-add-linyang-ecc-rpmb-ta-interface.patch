+/***************************************************************************/
+/*!
+   \file
+
+   \brief       Common types and basic functions for ECC.
+
+   Byteorder of the long numbers is Little endian
+
+   $Rev: 2750 $
+ */
+/***************************************************************************/
+/***************************************************************************
+ * 1. INCLUDES                                                             *
+ ***************************************************************************/
+
+#include "_ecc.h"
