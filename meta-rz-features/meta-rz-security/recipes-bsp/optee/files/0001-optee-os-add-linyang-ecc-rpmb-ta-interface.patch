+    EscEcc_FieldElementT* r,
+    const EscEcc_FieldElementLongT* z,
+    const EscEcc_FieldT* fGP );
+#endif
+
+static void
+EscEcc_MemsetZero(
+    Esc_UINT32 dest[],
+    Esc_UINT32 length );
+
+/***************************************************************************
+ * 4. IMPLEMENTATION OF FUNCTIONS                                          *
+ ***************************************************************************/
+
+/*****************************************************************
+ Increments a 64 bit value whose low byte is in *lo and high byte
+ is in *hi by the value increment.
+ *****************************************************************/
+#if Esc_HAS_INT64 == 0
+static void
+EscEccWd_Inc(
+    Esc_UINT32* hi,
+    Esc_UINT32* lo,
+    Esc_UINT32 increment )
+{
+    /* (a+b)>0xffffffff => a > 0xffffffff - b */
+    if ( *lo > (0xffffffffU - increment) )
+    {
+        (*hi)++;
+    }
+    *lo += increment;
+}
+
+#endif
+/*****************************************************************
+ Adds two FWORDs to another FWORD + carry
+ c = a + b + carry
+ *****************************************************************/
+static void
+EscEccWd_AddC(
+    Esc_UINT32* carry,
+    Esc_UINT32* c,
+    const Esc_UINT32 a,
+    const Esc_UINT32 b )
+{
+#if Esc_HAS_INT64 == 1
+    Esc_UINT64 u64_temp = (Esc_UINT64)a + (Esc_UINT64)b + (Esc_UINT64) * carry;
+    *carry = EscEcc_HI64( u64_temp );
+    *c = EscEcc_LO64( u64_temp );
+#else
+    *c = *carry;
+    *carry = 0U;
+    EscEccWd_Inc( carry, c, a );
+    EscEccWd_Inc( carry, c, b );
+#endif
+}
+
+/*****************************************************************
+Adds two arrays of FWORDs with a length of len
+ with carry
+*****************************************************************/
+void
+EscEccWd_AddCLoop(
+    Esc_UINT32* carry_out,
+    Esc_UINT32 c[],
+    const Esc_UINT32 a[],
+    const Esc_UINT32 b[],
+    const Esc_UINT8 len)
+{
+    Esc_UINT16 i;
+    *carry_out = 0U;
+    for (i = 0U; i < len; i++)
+    {
+        EscEccWd_AddC( carry_out, &c[i], a[i], b[i] );
+    }
+}
+
+/*****************************************************************
+Calculates c = a - b + borrow
+****************************************************************/
+static void
+EscEccWd_SubB(
+    Esc_UINT32* borrow,
+    Esc_UINT32* c,
+    Esc_UINT32 a,
+    Esc_UINT32 b )
+{
+    Esc_UINT32 inv_b = ~b;
+#if Esc_HAS_INT64 == 1
+    Esc_UINT64 u64_temp = (Esc_UINT64)a + (Esc_UINT64)inv_b + (Esc_UINT64) * borrow;
+    *borrow = EscEcc_HI64( u64_temp );
+    *c = EscEcc_LO64( u64_temp );
+#else
+    EscEccWd_AddC( borrow, c, a, inv_b );
+#endif
+}
+
+/*****************************************************************
+Subtracts two arrays of FWORDs with a length of len,
+ with borrow
+*****************************************************************/
+void
+EscEccWd_SubBLoop(
+    Esc_UINT32 c[],
+    Esc_UINT32* borrow_out,
+    const Esc_UINT32 a[],
+    const Esc_UINT32 b[],
+    const Esc_UINT8 len )
+{
+    Esc_UINT16 i;
+
+    Esc_ASSERT( len != 0U );
+
+    *borrow_out = 1U;
+    for (i = 0U; i < len; i++)
+    {
+        EscEccWd_SubB( borrow_out, &c[i], a[i], b[i] );
+    }
+}
+
+/*****************************************************************
+Calculates c = a * b
+****************************************************************/
+
+#if Esc_HAS_INT64 == 0
+static void
+EscEccWd_Multiply(
+    Esc_UINT32* c_high,
+    Esc_UINT32* c_low,
+    Esc_UINT32 a,
+    Esc_UINT32 b )
+{
+    Esc_UINT16 a1, a0;
+    Esc_UINT16 b1, b0;
+    Esc_UINT32 uv;
+    Esc_UINT16 u;
+    Esc_UINT16 c2, c1, c0;
+
+    /*
+       We use an inlined version of the classical
+       multiplication algorithm:
+     */
+    a0 = EscEcc_LO32( a );
+    a1 = EscEcc_HI32( a );
+    b0 = EscEcc_LO32( b );
+    b1 = EscEcc_HI32( b );
+
+    /* i=0, j=0 */
+    uv = (Esc_UINT32)a0 * (
+            Esc_UINT32)b0;
+    u = EscEcc_HI32( uv );
+    c0 = EscEcc_LO32( uv );
+
+    /* j=1 */
+    uv = ( (Esc_UINT32)a0 * (Esc_UINT32)b1 ) + (Esc_UINT32)u;
+    c1 = EscEcc_LO32( uv );
+    c2 = EscEcc_HI32( uv );
+
+    /* i=1, j=0 */
+    uv = (Esc_UINT32)c1 + ( (Esc_UINT32)a1 * (Esc_UINT32)b0 );
+    u = EscEcc_HI32( uv );
+
+    /* j=1 */
+    *c_low = (Esc_UINT32)c0 + (uv << 16);
+    *c_high = (Esc_UINT32)c2 + ( (Esc_UINT32)a1 * (Esc_UINT32)b1 ) + (Esc_UINT32)u;
+}
+
+#endif
+
+/******************************************************
+Converts an octet string in Big Endian format into a Esc_UINT32 value in little Endian
+ ******************************************************/
+static Esc_UINT32
+EscEccWd_FromOctets(
+    const Esc_UINT8 octets[],
+    Esc_UINT32 idx )
+{
+    Esc_UINT32 v;
+    v = ( ( (Esc_UINT32)octets[idx + 3U] ) |
+          ( (Esc_UINT32)octets[idx + 2U] << 8 ) |
+          ( (Esc_UINT32)octets[idx + 1U] << 16 ) |
+          ( (Esc_UINT32)octets[idx] << 24 )
+          );
+    return v;
+}
+
+/******************************************
+ * substitute for memset(dest, 0, length) *
+ ******************************************/
+static void
+EscEcc_MemsetZero(
+    Esc_UINT32 dest[],
+    Esc_UINT32 length )
+{
+    Esc_UINT32 i;
+
+    for (i = 0U; i < length; i++)
+    {
+        dest[i] = 0U;
+    }
+}
+
+/*****************************************************
+ * Convert EscEcc_FieldElementT to Esc_UINT8         *
+ *****************************************************/
+void
+EscEccFe_ToUint8(
+    const EscEcc_FieldElementT* input,  /* field element to convert */
+    Esc_UINT8 output[],                 /* result */
+    const EscEcc_CurveT* curve )
+{
+    Esc_UINT16 i;
+    Esc_UINT32 input_w32;
+    Esc_UINT16 keyWords = curve->keySizeWords;
+    Esc_UINT16 lastByteIndex = (Esc_UINT16)curve->keySizeBytes - 1U;
+
+#if (EscEcc_SECP_521_ENABLED == 1)
+    if (curve->keySizeBits == 521U)
+    {
+        /* copy the first two bytes from the Field Element */
+        input_w32 = input->word[keyWords - 1U];
+        output[1] = (Esc_UINT8)( (input_w32) );
+        output[0] = (Esc_UINT8)( (input_w32) >> 8 );
+
+        keyWords--;
+    }
+#endif
+
+    for (i = 0U; i < keyWords; i++)
+    {
+        input_w32 = input->word[i];
+
+        output[(lastByteIndex - (4U * i))]      = (Esc_UINT8)( (input_w32) );
+        output[(lastByteIndex - (4U * i)) - 1U] = (Esc_UINT8)( (input_w32) >> 8U );
+        output[(lastByteIndex - (4U * i)) - 2U] = (Esc_UINT8)( (input_w32) >> 16U );
+        output[(lastByteIndex - (4U * i)) - 3U] = (Esc_UINT8)( (input_w32) >> 24U );
+    }
+
+}
+
+/********************************************************
+ * Convert Esc_UINT8 to EscEcc_FieldElementT            *
+ ********************************************************/
+void
+EscEccFe_FromUint8(
+    const Esc_UINT8 input[],        /* Esc_UINT8 array to convert */
+    Esc_UINT32 inputLen,
+    EscEcc_FieldElementT* output,   /* result */
+    const EscEcc_CurveT* curve )
+{
+    Esc_UINT32 usedInputBytes, nonFullWordBytes, feWord;
+    Esc_UINT16 i, paddingWords, feWordIndex;
+
+    if ( inputLen >= curve->keySizeBytes )
+    {
+        usedInputBytes = curve->keySizeBytes;
+        paddingWords = 0U;
+    }
+    else
+    {
+        /* Pad the input value with zero at the leftmost bytes (rightmost FE words).
+           Byte padding inside a word is done later, here we compute only the full padding words. */
+        usedInputBytes = inputLen;
+        /* compute number of padding words by rounding up the division */
+        paddingWords = (curve->keySizeWords - (((Esc_UINT16)usedInputBytes + 3U) / 4U));
+    }
+    nonFullWordBytes = usedInputBytes & 0x03U;
+    feWordIndex = (curve->keySizeWords - (Esc_UINT16)1U);
+
+    /* Padding words */
+    for ( i = 0; i < paddingWords; i++ )
+    {
+        output->word[feWordIndex - i] = 0U;
+    }
+    feWordIndex -= paddingWords;
+
+    /* Convert first bytes to non-full word, if required */
+    feWord = 0U;
+    if (( nonFullWordBytes) != 0U )
+    {
+        for ( i = 0; i < nonFullWordBytes; i++ )
+        {
+            feWord <<= 8;
+            feWord |= input[i];
+        }
+        output->word[feWordIndex] = feWord;
+        feWordIndex--;
+        usedInputBytes -= nonFullWordBytes;
+    }
+
+    /* Converting remaining bytes to full FEs */
+    feWord = 0U;
+    for ( i = 0U; i < usedInputBytes; i++ )
+    {
+        /* Big endian byte array [0,1,2,3,4,5,6,7] => FE:
+            [4,5,6,7][0,1,2,3] */
+        feWord <<= 8;
+        feWord |= input[i + nonFullWordBytes];
+        if ( (i & 0x03U) == 0x03U )
+        {
+            output->word[feWordIndex] = feWord;
+            feWordIndex--;
+            feWord = 0U;
+        }
+    }
+
+    for (i = curve->keySizeWords; i < curve->maxWords; i++)
+    {
+        output->word[i] = 0U;
+    }
+}
+
+#if EscEcc_ECDSA_ENABLED == 1
+/****************************************************
+ * Convert EscEcc_FieldElementT to                  *
+ * EscEcc_FieldElementLongT                         *
+ ****************************************************/
+void
+EscEccFe_ToLongElement(
+    EscEcc_FieldElementLongT* a,
+    const EscEcc_FieldElementT* b,
+    const Esc_UINT8 lenWords )
+{
+    Esc_UINT16 i;
+
+    for (i = 0U; i < lenWords; i++)
+    {
+        a->word[i] = b->word[i];
+    }
+    for (i = lenWords; i < EscEcc_MAX_LONG_WORDS; i++)
+    {
+        a->word[i] = 0U;
+    }
+}
+
+#endif
+
+/*****************************
+ * set field element to zero *
+ *****************************/
+void
+EscEccFe_SetZero(
+    EscEcc_FieldElementT* a )
+{
+    EscEcc_MemsetZero( a->word, EscEcc_MAX_WORDS );
+}
+
+/****************************
+ * set field element to one *
+ ****************************/
+void
+EscEccFe_SetOne(
+    EscEcc_FieldElementT* a )
+{
+    a->word[0] = 1U;
+
+    EscEcc_MemsetZero( &a->word[1], (EscEcc_MAX_WORDS - 1U) );
+}
+
+/**********************************
+ * check if field element is zero *
+ **********************************/
+Esc_BOOL
+EscEccFe_IsZero(
+    const EscEcc_FieldElementT* a,
+    const Esc_UINT8 lenWords )
+{
+    Esc_UINT8 i;
+    Esc_BOOL isZero = TRUE;
+
+    /* for i from 0 to t do a[i] =? 0 */
+    for (i = 0U; i < lenWords; i++)
+    {
+        if (a->word[i] != 0U)
+        {
+            /* not zero */
+            isZero = FALSE;
+            break;
+        }
+    }
+
+    return isZero;
+}
+
+/***********************************
+ * checks if field element is one  *
+ **********************************/
+Esc_BOOL
+EscEccFe_IsOne(
+    const EscEcc_FieldElementT* a,
+    const Esc_UINT8 lenWords )
+{
+    Esc_BOOL isOne = TRUE;
+
+    /* a[0] =? 1 */
+    if (a->word[0] != 1U)
+    {
+        isOne = FALSE;
+    }
+    else
+    {
+        Esc_UINT8 i;
+        /* for i from 1 to t-1 do a[i] =? 0 */
+        for (i = 1U; i < lenWords; i++)
+        {
+            if (a->word[i] != 0U)
+            {
+                /* not one */
+                isOne = FALSE;
+            }
+        }
+    }
+
+    return isOne;
+}
+
+/*******************************************
+ * compares two field elements `a' and `b' *
+  +1: a>b
+  -1: a<b
+   0: a==b
+ *******************************************/
+Esc_SINT8
+EscEccFe_AbsoluteCompare(
+    const EscEcc_FieldElementT* a,
+    const EscEcc_FieldElementT* b,
+    const Esc_UINT8 lenWords )
+{
+    Esc_SINT8 i;
+    Esc_SINT8 compResult = 0;
+
+    Esc_ASSERT( lenWords < 128U );
+
+    /* compare the corresponding words until a different word pair is found */
+    for (i = ((Esc_SINT8)lenWords - 1); (compResult == 0) && (i >= 0); i--)
+    {
+        /* next lower pair */
+        if (a->word[i] > b->word[i])
+        {
+            /* a > b */
+            compResult = 1;
+        }
+        else if (a->word[i] < b->word[i])
+        {
+            /* a < b */
+            compResult = -1;
+        }
+        else
+        {
+            /* do nothing */
+        }
+    }
+
+    return compResult;
+}
+
+/************************************************************
+ * assigns a field element to another field element         *
+ ************************************************************/
+void
+EscEccFe_Assign(
+    EscEcc_FieldElementT* c,
+    const EscEcc_FieldElementT* a,
+    const Esc_UINT8 lenWords )
+{
+    Esc_UINT8 i;
+
+    for (i = 0U; i < lenWords; i++)
+    {
+        c->word[i] = a->word[i];
+    }
+}
+
+/****************************************************
+ * shifts field element right by 1 bit              *
+ ****************************************************/
+void
+EscEccFe_ShiftRight(
+    EscEcc_FieldElementT* a,
+    const Esc_UINT8 lenWords )
+{
+    Esc_UINT8 i;
+
+    /* shift first words */
+    for (i = 0U; i < (lenWords - 1U); i++)
+    {
+        Esc_UINT32 v;
+        v = a->word[i] >> 1;
+        v ^= a->word[i + 1U] << 31;
+
+        a->word[i] = v;
+    }
+
+    /* shift last word */
+    a->word[lenWords - 1U] >>= 1;
+}
+
+/***********************************************************************
+ * multiplies two field elements c = a * b
+ Highest word will only be used if one operand is the prime number -->
+ adjusted loop borders for optimization
+ Note: To calculate with all words use EscEccFe_Multiply !!!
+ ***********************************************************************/
+static void
+EscEccFe_MultiplyShort(
+    EscEcc_FieldElementLongT* c,
+    const EscEcc_FieldElementT* a,
+    const EscEcc_FieldElementT* b,
+    const EscEcc_CurveT* curve )
+{
+    Esc_UINT8 i, j;
+    const Esc_UINT8 maxWordsLong = curve->maxWordsLong;
+    /* specifies the number of used words in multiplication */
+    Esc_UINT8 mulMaxWords = curve->maxWords - 1U;
+
+#if Esc_HAS_INT64 == 1
+    Esc_UINT8 min;
+    Esc_UINT8 b_0, a_0;
+    Esc_UINT32 carry;
+    Esc_UINT32 t;
+    Esc_UINT64 uv_t = 0U;
+    Esc_UINT64 uv;
+#endif
+
+#if (EscEcc_SECP_160_ENABLED == 1)
+    if ( curve->curveID == EscEcc_CURVE_SECP_160 )
+    {
+        /* For secp160r1 the highest 2 words are not used in almost every calculation except
+           if one operand is the variable "base_point_order_n" */
+        if ( (a->word[ curve->maxWords - 2U] == 0U) && (b->word[ curve->maxWords - 2U] == 0U) )
+        {
+            mulMaxWords = (Esc_UINT8)( curve->maxWords - 2U);
+        }
+    }
+#endif
+
+    /* check if highest words are really not used */
+    Esc_ASSERT( (a->word[mulMaxWords] == 0U) && (b->word[mulMaxWords] == 0U) );
+
+
+    /* if Esc_UINT64 type is supported, use row-wise multiplication (a lot faster) */
+#if Esc_HAS_INT64 == 1
+
+    /* Clear upper 2 words because they won't be calculated */
+    c->word[maxWordsLong - 1U] = 0U;
+    c->word[maxWordsLong - 2U] = 0U;
+
+#   if (EscEcc_SECP_160_ENABLED == 1)
+    if ( curve->curveID == EscEcc_CURVE_SECP_160 )
+    {
+        /* For secp160r1 the highest 4 words has to be cleared */
+        c->word[maxWordsLong - 3U] = 0U;
+        c->word[maxWordsLong - 4U] = 0U;
+    }
+#   endif
+
+
+    for (i = 0U; i < ( 2U * (mulMaxWords) ); i++)
+    {
+        t = 0U;
+        b_0 = EscEcc_MIN( (mulMaxWords - 1U), i );
+        a_0 = i - b_0;
+        min = EscEcc_MIN( (Esc_UINT8)(mulMaxWords - a_0), (b_0 + 1U) );
+        for (j = 0U; j < min; j++)
+        {
+            /* a[a_o +j] * b[b_o - j] */
+            uv = (Esc_UINT64)a->word[a_0 + j] * (Esc_UINT64)b->word[b_0 - j];
+            /* sum on uv_t */
+            uv_t += uv;
+            /* if overflow save carry to t */
+            if (uv_t < uv)
+            {
+                t++;
+            }
+        }
+
+        /* c[i] = v, v = u, u = t, t = 0 */
+        c->word[i] = EscEcc_LO64( uv_t );
+        carry = EscEcc_HI64( uv_t );
+        uv_t = carry;
+        uv_t |= (Esc_UINT64)(t) << 32U;
+    }
+
+    /* if Esc_UINT64 type is not supported, use classical multiplication */
+#else  /* Esc_HAS_INT64 */
+       /* HAC Alg. 14.12 */
+       /* 1.) c = 0 */
+    for (i = 0U; i < maxWordsLong; i++)
+    {
+        c->word[i] = 0U;
+    }
+    /* 2.) for i = 0 to curve->maxWords */
+    for (i = 0U; i < (mulMaxWords); i++)
+    {
+        Esc_UINT32 u;
+        /* 2.1) u = 0 */
+        u = 0U;
+
+        /* 2.2) for j = 0 to (mulMaxWords) do */
+        for (j = 0U; j < (mulMaxWords); j++)
+        {
+            Esc_UINT32 v;
+            Esc_UINT32 prevU;       /* previous u */
+
+            prevU = u;
+
+            /* (uv) = a[j] * b[i] */
+            EscEccWd_Multiply( &u, &v, a->word[j], b->word[i] );
+
+            /* (uv) = a[j] * b[i] + u */
+            EscEccWd_Inc( &u, &v, prevU );
+
+            /* (uv) = c[i+j] + a[j] * b[i] + u */
+            EscEccWd_Inc( &u, &v, c->word[i + j] );
+
+            /* c[i+j] = v */
+            c->word[i + j] = v;
+        }
+
+        /* 2.3) c[i+mulMaxWords] = u */
+        c->word[i + (mulMaxWords)] = u;
+    }
+#endif /* Esc_HAS_INT64 */
+}
+
+/******************************************
+ * multiplies two field elements c = a * b
+ ******************************************/
+void
+EscEccFe_Multiply(
+    EscEcc_FieldElementLongT* c,
+    const EscEcc_FieldElementT* a,
+    const EscEcc_FieldElementT* b,
+    const EscEcc_CurveT* curve )
+{
+    Esc_UINT8 i;
+    const Esc_UINT8 maxWords = curve->maxWords;
+
+#if Esc_HAS_INT64 == 1
+    /* row-wise multiplication */
+    Esc_UINT8 j;
+    Esc_UINT8 min;
+    Esc_UINT32 carry, t;
+    Esc_UINT8 b_0, a_0;
+    Esc_UINT64 uv_t;
+    Esc_UINT64 uv;
+    uv_t = 0U;
+    t = 0U;
+
+    for (i = 0U; i < (2U * maxWords); i++)
+    {
+        b_0 = EscEcc_MIN( (maxWords - 1U), i );
+        a_0 = i - b_0;
+        min = EscEcc_MIN( (Esc_UINT8)(maxWords - a_0), (b_0 + 1U) );
+        for (j = 0U; j < min; j++)
+        {
+            /* a[a_o +j] * b[b_o - j] */
+            uv = (Esc_UINT64)a->word[a_0 + j] * (Esc_UINT64)b->word[b_0 - j];
+            /* sum on uv_t */
+            uv_t += uv;
+            /* if overflow save carry to t */
+            if (uv_t < uv)
+            {
+                t++;
+            }
+        }
+
+        /* c[i] = v, v = u, u = t, t = 0 */
+        c->word[i] = EscEcc_LO64( uv_t );
+        carry = EscEcc_HI64( uv_t );
+        uv_t = carry;
+        uv_t |= (Esc_UINT64)(t) << 32U;
+        t = 0U;
+    }
+
+#else
+    /* HAC Alg. 14.12 */
+    /* 1.) c = 0 */
+    for (i = 0U; i < curve->maxWordsLong; i++)
+    {
+        c->word[i] = 0U;
+    }
+    /* 2.) for i = 0 to curve->maxWords */
+    for (i = 0U; i < maxWords; i++)
+    {
+        Esc_UINT8 j;
+        Esc_UINT32 u;
+        /* 2.1) u = 0 */
+        u = 0U;
+
+        /* 2.2) for j = 0 to curve->maxWords do */
+        for (j = 0U; j < maxWords; j++)
+        {
+            Esc_UINT32 v;
+            Esc_UINT32 prevU;       /* previous u */
+
+            prevU = u;
+
+            /* (uv) = a[j] * b[i] */
+            EscEccWd_Multiply( &u, &v, a->word[j], b->word[i] );
+
+            /* (uv) = a[j] * b[i] + u */
+            EscEccWd_Inc( &u, &v, prevU );
+
+            /* (uv) = c[i+j] + a[j] * b[i] + u */
+            EscEccWd_Inc( &u, &v, c->word[i + j] );
+
+            /* c[i+j] = v */
+            c->word[i + j] = v;
+        }
+
+        /* 2.3) c[i+curve->maxWords] = u */
+        c->word[i + maxWords] = u;
+    }
+#endif
+}
+
+/******************************************
+ * add two field elements under modulus p *
+ ******************************************/
+void
+EscEccFe_ModularAdd(
+    EscEcc_FieldElementT* c,
+    const EscEcc_FieldElementT* a,
+    const EscEcc_FieldElementT* b,
+    const EscEcc_FieldT* fGP,
+    const Esc_UINT8 lenWords )
+{
+    Esc_UINT32 carry, borrow;
+
+    /* 1.) & 2.)                                                */
+    /* for i from 0 to t-1 do c[i] = add_with_carry(a[i], b[i]) */
+    EscEccWd_AddCLoop( &carry, c->word, a->word, b->word, lenWords );
+
+    /* 4.) while c >= p, do c = c - p */
+    while ( (carry == 1U) || (EscEccFe_AbsoluteCompare( c, &fGP->prime_p, lenWords ) >= 0 ) )
+    {
+        /* for i from 0 to t-1 do c[i] = subtract_with_borrow(c[i], p[i])  */
+        EscEccWd_SubBLoop( c->word, &borrow, c->word, fGP->prime_p.word, lenWords );
+        carry -= borrow;
+    }
+}
+
+/************************************************
+ * subtracts two field elements under modulus p *
+ ************************************************/
+void
+EscEccFe_ModularSub(
+    EscEcc_FieldElementT* c,
+    const EscEcc_FieldElementT* a,
+    const EscEcc_FieldElementT* b,
+    const EscEcc_FieldT* fGP,
+    const Esc_UINT8 lenWords )
+{
+    Esc_UINT32 borrow, carry;
+
+    /* 1.) & 2.) */
+    /* for i from 0 to t-1 do c[i] = subtract_with_borrow(a[i], b[i])  */
+    EscEccWd_SubBLoop( c->word, &borrow, a->word, b->word, lenWords );
+
+    /* 3.) while carry bit is set (i.e. borrow == 0), add p to c = {c[t-1],..,c[1],c[0]} */
+    while (borrow == 0U)
+    {
+        /* for i from 0 to t-1 do c[i] = add_with_carry(c[i], p[i]) */
+        EscEccWd_AddCLoop( &carry, c->word, c->word, fGP->prime_p.word, lenWords );
+        borrow += carry;
+    }
+}
+
+/********************************************************
+ * reduce a field element z with modulus p using Barrett*
+ * r = z mod p                                          *
+ ********************************************************/
+void
+EscEccFe_ReduceBarrett(
+    EscEcc_FieldElementT* r,
+    const EscEcc_FieldElementLongT* z,
+    const EscEcc_FieldT* fGP,
+    const EscEcc_CurveT* curve )
+{
+    /* C.f Hankerson, et. al, "Guide to Elliptic Curve Cryptography", Algorithm 2.14, Barret Reduction */
+    Esc_UINT8 i;
+    Esc_UINT32 borrow;
+    const Esc_UINT8 maxWords = curve->maxWords;
+
+    EscEcc_FieldElementT tmp;
+    EscEcc_FieldElementLongT tmpLong;
+    EscEcc_FieldElementT q;
+    EscEcc_FieldElementT r1, r2;
+
+    /* reduction */
+    /* 1.) q = floor(floor(z / (b ^(k-1))) * mu / b^(k+1)) */
+
+    /* tmp = floor(z / (b ^(k-1))) */
+    for (i = 0U; i < (fGP->pLen + 1U); i++)
+    {
+        tmp.word[i] = z->word[(fGP->pLen - 1U) + i];
+    }
+    /* Zerorize remaining words of all used FEs in this function.
+       ReduceBarrett is only called with fGP = 'base_point_order_n' or
+       fGP = 'EscEcc_PRIME_P'(defined ecc_curves32.c) as the modulo.
+       Since these fields - except the prime of the secPr1 160 curve for which
+       the NIST reduction is used - have a length of curve->maxWords-1, this
+       loop is never be used!
+       Leave this for maintainability and possible changes in future ECC versions */
+    for (; i < maxWords; i++)
+    {
+        tmp.word[i] = 0U;
+        r1.word[i] = 0U;
+        r2.word[i] = 0U;
+    }
+
+    /* tmpLong = tmp * my_p  = floor(z / (b ^(k-1))) * mu */
+    /* use Big-version here because precalc_my_p has full word size */
+    EscEccFe_Multiply( &tmpLong, &tmp, &fGP->precalc_my_p, curve );
+
+    /* q = floor(tmpLong / b^(k+1)) = floor(floor(z / (b ^(k-1))) * mu / b^(k+1)) */
+    Esc_ASSERT( ( (fGP->pLen + 1U) + maxWords ) <= curve->maxWordsLong );
+    for (i = 0U; i < maxWords; i++)
+    {
+        q.word[i] = tmpLong.word[(fGP->pLen + 1U) + i];
+    }
+
+    /* 2.) r = z % (b^(k+1)) - ((q * p) % (b^(k+1)) */
+
+    /* r1 = (z % (b^(k+1)) */
+    for (i = 0U; i < (fGP->pLen + 1U); i++)
+    {
+        r1.word[i] = z->word[i];
+    }
+
+    /* tmpLong = q * p */
+    EscEccFe_MultiplyShort( &tmpLong, &q, &fGP->prime_p, curve );
+
+    /* r2 = tmpLong % (b^(k+1)) = (q * p) % (b^(k+1)) */
+    for (i = 0U; i < (fGP->pLen + 1U); i++)
+    {
+        r2.word[i] = tmpLong.word[i];
+    }
+
+    /*r = r1 - r2 = (z % (b^(k+1)) - ((q * p) % (b^(k+1))) */
+    if (EscEccFe_AbsoluteCompare( &r1, &r2, maxWords ) < 0)
+    {
+        /* Include Step 3. if r<0, r := r + b^(k+1) */
+
+        /* Setting r1.word[ fGP->pLen + 1U ] = 1U; for computing  r1 := r1 + b^(k+1)
+           is not possible since fGP-pLen + 1U could exceed the length of a field
+           element.
+
+           Naive approach: r = r1 + b^(k+1) - r2
+
+           We compute: r = b^(k+1)-1 - (r2 - r1 - 1) [ <-- this is computed by us]
+                         = b^(k+1)-1 -  r2 + r1 + 1
+                         = b^(k+1)   -  r2 + r1      [which is the same as computed in the naive approach]
+
+           In the our computation there is no element which could exceed curve->maxWords,
+           especially b^(k+1)-1 fits within curve->maxWords words.
+        */
+
+        /* r2 = r2 - r1*/
+        EscEccWd_SubBLoop( r2.word, &borrow, r2.word, r1.word, maxWords );
+
+        /* r2 = r2 - 1 */
+        EscEccFe_SetOne( &tmp );
+        EscEccWd_SubBLoop( r2.word, &borrow, r2.word, tmp.word, maxWords );
+
+        /* r1 = b^(k+1)-1 */
+        for (i = 0U; i < maxWords; i++)
+        {
+            r1.word[i] = 0xFFFFFFFFU;
+        }
+    }
+    EscEccWd_SubBLoop( r->word, &borrow, r1.word, r2.word, maxWords );
+
+    /* 4.) while r>=p do : r:= r - p */
+    while (EscEccFe_AbsoluteCompare( r, &fGP->prime_p, maxWords ) >= 0)
+    {
+        /* r := r - p */
+        EscEccWd_SubBLoop( r->word, &borrow, r->word, fGP->prime_p.word, maxWords );
+    }
+    /* 5.) return r */
+}
+
+/************************************************
+ * multiply two field elements under modulus p  *
+ ************************************************/
+void
+EscEccFe_MultiplyModP(
+    EscEcc_FieldElementT* c,
+    const EscEcc_FieldElementT* a,
+    const EscEcc_FieldElementT* b,
+    const EscEcc_CurveT* curve )
+{
+    EscEcc_FieldElementLongT longC;
+    const EscEcc_FieldT* fGP;
+
+    fGP = &curve->ecc_field_params;
+
+    /* multiply */
+    EscEccFe_MultiplyShort( &longC, a, b, curve );
+
+    /* reduce */
+    /*lint -save -e9081 We violate the too few cases for switch rule depending on the curve configuration.
+      This saves us some ifdefs cascades and improves the readability. */
+    switch (curve->curveID)
+    {
+#if (EscEcc_SECP_160_ENABLED == 1)
+        case EscEcc_CURVE_SECP_160:
+            EscEccFe_ReduceNIST_160( c, &longC, fGP );
+            break;
+#endif
+
+#if (EscEcc_SECP_192_ENABLED == 1)
+        case EscEcc_CURVE_SECP_192:
+            EscEccFe_ReduceNIST_192( c, &longC, fGP );
+            break;
+#endif
+
+#if (EscEcc_SECP_224_ENABLED == 1)
+        case EscEcc_CURVE_SECP_224:
+            EscEccFe_ReduceNIST_224( c, &longC, fGP );
+            break;
+#endif
+
+#if (EscEcc_SECP_256_ENABLED == 1)
+        case EscEcc_CURVE_SECP_256:
+            EscEccFe_ReduceNIST_256( c, &longC, fGP );
+            break;
+#endif
+
+#if (EscEcc_SECP_384_ENABLED == 1)
+        case EscEcc_CURVE_SECP_384:
+            EscEccFe_ReduceNIST_384( c, &longC, fGP );
+            break;
+#endif
+
+#if (EscEcc_SECP_521_ENABLED == 1)
+        case EscEcc_CURVE_SECP_521:
+            EscEccFe_ReduceNIST_521( c, &longC, fGP );
+            break;
+#endif
+
+#if (EscEcc_BRAINPOOL_P160_ENABLED == 1)
+        case EscEcc_CURVE_BRAINPOOL_P160:
+#endif
+
+#if (EscEcc_BRAINPOOL_P192_ENABLED == 1)
+        case EscEcc_CURVE_BRAINPOOL_P192:
+#endif
+
+#if (EscEcc_BRAINPOOL_P224_ENABLED == 1)
+        case EscEcc_CURVE_BRAINPOOL_P224:
+#endif
+
+#if (EscEcc_BRAINPOOL_P256_ENABLED == 1)
+        case EscEcc_CURVE_BRAINPOOL_P256:
+#endif
+
+#if (EscEcc_BRAINPOOL_P320_ENABLED == 1)
+        case EscEcc_CURVE_BRAINPOOL_P320:
+#endif
+
+#if (EscEcc_BRAINPOOL_P384_ENABLED == 1)
+        case EscEcc_CURVE_BRAINPOOL_P384:
+#endif
+
+#if (EscEcc_BRAINPOOL_P512_ENABLED == 1)
+        case EscEcc_CURVE_BRAINPOOL_P512:
+#endif
+
+        default:
+            EscEccFe_ReduceBarrett( c, &longC, fGP, curve );
+            break;
+    }
+    /*lint -restore */
+}
