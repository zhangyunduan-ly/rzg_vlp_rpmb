+/***************************************
+ * optimized reduction for NIST-Primes *
+ ***************************************/
+
+#if (EscEcc_SECP_160_ENABLED == 1)
+static void
+EscEccFe_ReduceNIST_160(
+    EscEcc_FieldElementT* r,
+    const EscEcc_FieldElementLongT* z,
+    const EscEcc_FieldT* fGP )
+{
+    /* see da_uhsadel.pdf for details */
+    Esc_SINT8 compResult;
+    Esc_UINT8 c_array_word[5];
+    Esc_UINT32 tmp;
+    Esc_UINT8 i;
+
+    /* clear result variable */
+    for (i = 5U; i < EscEcc_curveSecp160r1.maxWords; i++)
+    {
+        r->word[i] = 0U;
+    }
+
+    /* copy lower words of z, add higher words of z and save carrys for each word */
+    for (i = 0U; i < 5U; i++)
+    {
+        c_array_word[i] = 0U;
+        r->word[i] = z->word[i];
+        r->word[i] += z->word[i + 5U];
+        if (r->word[i] < z->word[i + 5U])
+        {
+            c_array_word[i]++;
+        }
+    }
+
+    /* add shifted higher words with bit 0 of the next word */
+    /* word[1] - word[4] */
+    for (i = 1U; i < 5U; i++)
+    {
+        tmp = (z->word[i + 4U] >> 1U) | ( (z->word[i + 5U] & 1U) << 31U );
+        r->word[i] += tmp;
+        if (r->word[i] < tmp)
+        {
+            c_array_word[i]++;
+        }
+    }
+
+    /* remaining special cases for word[0] and word[1] */
+    /* word[0] */
+    tmp = (z->word[9] >> 1U) | ( ( (z->word[9] >> 1U) & 1U ) << 31U );
+    r->word[0] += tmp;
+    if (r->word[0] < tmp)
+    {
+        c_array_word[0]++;
+    }
+    /* word[0] */
+    tmp = (z->word[5] & 1U) << 31U;
+    r->word[0] += tmp;
+    if (r->word[0] < tmp)
+    {
+        c_array_word[0]++;
+    }
+    /* word[1] */
+    tmp = (z->word[9] >> 2U);
+    r->word[1] += tmp;
+    if (r->word[1] < tmp)
+    {
+        c_array_word[1]++;
+    }
+
+    /* add collected carrys */
+    for (i = 0U; i < 4U; i++)
+    {
+        r->word[i + 1U] += c_array_word[i];
+        if (r->word[i + 1U] < c_array_word[i])
+        {
+            c_array_word[i + 1U]++;
+        }
+    }
+
+    /* save last carry */
+    r->word[5] = c_array_word[4];
+
+    /* subtract modulus if result is bigger */
+    do
+    {
+        compResult = EscEccFe_AbsoluteCompare( r, &fGP->prime_p, EscEcc_curveSecp160r1.maxWords );
+
+        if (compResult == 1)
+        {
+            EscEccWd_SubBLoop( r->word, &tmp, r->word, fGP->prime_p.word, EscEcc_curveSecp160r1.maxWords );
+        }
+        else if (compResult == 0)
+        {
+            EscEccFe_SetZero( r );
+        }
+        else
+        {
+            /* do nothing */
+        }
+    } while (compResult == 1);
+}
+
+#endif
+
+#if (EscEcc_SECP_192_ENABLED == 1)
+static void
+EscEccFe_ReduceNIST_192(
+    EscEcc_FieldElementT* r,
+    const EscEcc_FieldElementLongT* z,
+    const EscEcc_FieldT* fGP )
+{
+    /* c_x = 2^64
+       s1 = (c_2, c_1, c_0) s2 = (0, c_3, c_3) s3 = (c_4, c_4, 0) s4 = c_5, c_5, c_5)
+       calculate (s1 + s2 + s3 + s4) mod p_192 */
+    Esc_UINT8 i;
+    EscEcc_FieldElementT s2;
+    EscEcc_FieldElementT s3;
+    EscEcc_FieldElementT s4;
+
+    EscEccFe_SetZero( &s2 );
+    EscEccFe_SetZero( &s3 );
+    s4.word[EscEcc_curveSecp192r1.maxWords - 1U] = 0U;
+    r->word[EscEcc_curveSecp192r1.maxWords - 1U] = 0U;
+
+    for (i = 0U; i < 6U; i++)
+    {
+        r->word[i] = z->word[i];
+    }
+    for (i = 6U; i < 8U; i++)
+    {
+        s2.word[i - 6U] = z->word[i];
+        s2.word[i - 4U] = z->word[i];
+    }
+    for (i = 8U; i < 10U; i++)
+    {
+        s3.word[i - 6U] = z->word[i];
+        s3.word[i - 4U] = z->word[i];
+    }
+    for (i = 10U; i < 12U; i++)
+    {
+        s4.word[i - 10U] = z->word[i];
+        s4.word[i - 8U] = z->word[i];
+        s4.word[i - 6U] = z->word[i];
+    }
+
+    EscEccFe_ModularAdd( r, r, &s2, fGP, EscEcc_curveSecp192r1.maxWords );
+    EscEccFe_ModularAdd( r, r, &s3, fGP, EscEcc_curveSecp192r1.maxWords );
+    EscEccFe_ModularAdd( r, r, &s4, fGP, EscEcc_curveSecp192r1.maxWords );
+}
+
+#endif
+
+#if (EscEcc_SECP_224_ENABLED == 1)
+static void
+EscEccFe_ReduceNIST_224(
+    EscEcc_FieldElementT* r,
+    const EscEcc_FieldElementLongT* z,
+    const EscEcc_FieldT* fGP )
+{
+    /* Algorithm 2.28, Guide to Elliptic Curve Cryptography */
+    Esc_UINT8 i;
+    EscEcc_FieldElementT s2;
+    EscEcc_FieldElementT s3;
+    EscEcc_FieldElementT s4;
+    EscEcc_FieldElementT s5;
+
+    EscEccFe_SetZero( &s2 );
+    EscEccFe_SetZero( &s3 );
+    EscEccFe_SetZero( &s5 );
+    r->word[EscEcc_curveSecp224r1.maxWords - 1U] = 0U;
+    s4.word[EscEcc_curveSecp224r1.maxWords - 1U] = 0U;
+
+    for (i = 0U; i < 7U; i++)
+    {
+        r->word[i] = z->word[i];
+    }
+    for (i = 0U; i < 7U; i++)
+    {
+        s4.word[i] = z->word[i + 7U];
+    }
+    for (i = 3U; i < 7U; i++)
+    {
+        s2.word[i] = z->word[i + 4U];
+    }
+    for (i = 0U; i < 3U; i++)
+    {
+        s5.word[i] = z->word[i + 11U];
+        s3.word[i + 3U] = z->word[i + 11U];
+    }
+
+    EscEccFe_ModularAdd( r, r, &s2, fGP, EscEcc_curveSecp224r1.maxWords );
+    EscEccFe_ModularAdd( r, r, &s3, fGP, EscEcc_curveSecp224r1.maxWords );
+    EscEccFe_ModularSub( r, r, &s4, fGP, EscEcc_curveSecp224r1.maxWords );
+    EscEccFe_ModularSub( r, r, &s5, fGP, EscEcc_curveSecp224r1.maxWords );
+}
+
+#endif
+
+#if (EscEcc_SECP_256_ENABLED == 1)
+static void
+EscEccFe_ReduceNIST_256(
+    EscEcc_FieldElementT* r,
+    const EscEcc_FieldElementLongT* z,
+    const EscEcc_FieldT* fGP )
+{
+    /* c = 2^32
+       Algorithm 2.29, Guide to Elliptic Curve Cryptography */
+    EscEcc_FieldElementT s2;
+    EscEcc_FieldElementT s3;
+    EscEcc_FieldElementT s4;
+    EscEcc_FieldElementT s5;
+    EscEcc_FieldElementT s6;
+    EscEcc_FieldElementT s7;
+    EscEcc_FieldElementT s8;
+    EscEcc_FieldElementT s9;
+
+    Esc_UINT8 i;
+
+    r->word[EscEcc_curveSecp256r1.maxWords - 1U] = 0U;
+    for (i = 0U; i < 8U; i++)
+    {
+        r->word[i] = z->word[i];
+    }
+    EscEccFe_SetZero( &s2 );
+    for (i = 3U; i < 8U; i++)
+    {
+        s2.word[i] = z->word[i + 8U];
+    }
+    EscEccFe_SetZero( &s3 );
+    for (i = 3U; i < 7U; i++)
+    {
+        s3.word[i] = z->word[i + 9U];
+    }
+    EscEccFe_SetZero( &s4 );
+    for (i = 0U; i < 2U; i++)
+    {
+        s4.word[i] = z->word[i + 8U];
+        s4.word[i + 6U] = z->word[i + 14U];
+    }
+    s4.word[2U] = z->word[10U];
+    s5.word[EscEcc_curveSecp256r1.maxWords - 1U] = 0U;
+    for (i = 0U; i < 3U; i++)
+    {
+        s5.word[i] = z->word[i + 9U];
+        s5.word[i + 3U] = z->word[i + 13U];
+    }
+    s5.word[6U] = z->word[13U];
+    s5.word[7U] = z->word[8U];
+    EscEccFe_SetZero( &s6 );
+    s8.word[EscEcc_curveSecp256r1.maxWords - 1U] = 0U;
+    s8.word[EscEcc_curveSecp256r1.maxWords - 3U] = 0U;
+    EscEccFe_SetZero( &s9 );
+    for (i = 0U; i < 3U; i++)
+    {
+        s6.word[i] = z->word[i + 11U];
+        s8.word[i] = z->word[i + 13U];
+        s8.word[i + 3U] = z->word[i + 8U];
+        s9.word[i + 3U] = z->word[i + 9U];
+    }
+    s6.word[6U] = z->word[8U];
+    s6.word[7U] = z->word[10U];
+    s8.word[7U] = z->word[12U];
+    s9.word[0U] = z->word[14U];
+    s9.word[1U] = z->word[15U];
+    s9.word[7U] = z->word[13U];
+    EscEccFe_SetZero( &s7 );
+    for (i = 0U; i < 4U; i++)
+    {
+        s7.word[i] = z->word[i + 12U];
+    }
+    s7.word[6U] = z->word[9U];
+    s7.word[7U] = z->word[11U];
+
+    EscEccFe_ModularAdd( r, r, &s4, fGP, EscEcc_curveSecp256r1.maxWords );
+    EscEccFe_ModularAdd( &s2, &s2, &s3, fGP, EscEcc_curveSecp256r1.maxWords );
+    EscEccFe_ModularAdd( &s2, &s2, &s2, fGP, EscEcc_curveSecp256r1.maxWords );
+    EscEccFe_ModularAdd( r, r, &s2, fGP, EscEcc_curveSecp256r1.maxWords );
+    EscEccFe_ModularAdd( r, r, &s5, fGP, EscEcc_curveSecp256r1.maxWords );
+    EscEccFe_ModularSub( r, r, &s6, fGP, EscEcc_curveSecp256r1.maxWords );
+    EscEccFe_ModularSub( r, r, &s7, fGP, EscEcc_curveSecp256r1.maxWords );
+    EscEccFe_ModularSub( r, r, &s8, fGP, EscEcc_curveSecp256r1.maxWords );
+    EscEccFe_ModularSub( r, r, &s9, fGP, EscEcc_curveSecp256r1.maxWords );
+}
+
+#endif
+
+#if (EscEcc_SECP_384_ENABLED == 1)
+static void
+EscEccFe_ReduceNIST_384(
+    EscEcc_FieldElementT* r,
+    const EscEcc_FieldElementLongT* z,
+    const EscEcc_FieldT* fGP )
+{
+    /* c = 2^32
+       Algorithm 2.30, Guide to Elliptic Curve Cryptography */
+    EscEcc_FieldElementT s2;
+    EscEcc_FieldElementT s3;
+    EscEcc_FieldElementT s4;
+    EscEcc_FieldElementT s5;
+    EscEcc_FieldElementT s6;
+    EscEcc_FieldElementT s7;
+    EscEcc_FieldElementT s8;
+    EscEcc_FieldElementT s9;
+    EscEcc_FieldElementT s10;
+
+    Esc_UINT8 i;
+
+    r->word[EscEcc_curveSecp384r1.maxWords - 1U] = 0U;
+    for (i = 0U; i < 12U; i++)
+    {
+        r->word[i] = z->word[i];
+    }
+    EscEccFe_SetZero( &s2 );
+    for (i = 4U; i < 7U; i++)
+    {
+        s2.word[i] = z->word[i + 17U];
+    }
+    s3.word[EscEcc_curveSecp384r1.maxWords - 1U] = 0U;
+    for (i = 0U; i < 12U; i++)
+    {
+        s3.word[i] = z->word[i + 12U];
+    }
+    s4.word[EscEcc_curveSecp384r1.maxWords - 1U] = 0U;
+    for (i = 3U; i < 12U; i++)
+    {
+        s4.word[i] = z->word[i + 9U];
+    }
+    s4.word[0U] = z->word[21U];
+    s4.word[1U] = z->word[22U];
+    s4.word[2U] = z->word[23U];
+    for (i = 4U; i < 12U; i++)
+    {
+        s5.word[i] = z->word[i + 8U];
+    }
+    s5.word[0U] = 0U;
+    s5.word[1U] = z->word[23U];
+    s5.word[2U] = 0U;
+    s5.word[3U] = z->word[20U];
+    s5.word[EscEcc_curveSecp384r1.maxWords - 1U] = 0U;
+    EscEccFe_SetZero( &s6 );
+    for (i = 4U; i < 8U; i++)
+    {
+        s6.word[i] = z->word[i + 16U];
+    }
+    EscEccFe_SetZero( &s7 );
+    s7.word[0U] = z->word[20U];
+    s7.word[3U] = z->word[21U];
+    s7.word[4U] = z->word[22U];
+    s7.word[5U] = z->word[23U];
+    for (i = 1U; i < 12U; i++)
+    {
+        s8.word[i] = z->word[i + 11U];
+    }
+    s8.word[0U] = z->word[23U];
+    s8.word[EscEcc_curveSecp384r1.maxWords - 1U] = 0U;
+    EscEccFe_SetZero( &s9 );
+    for (i = 1U; i < 5U; i++)
+    {
+        s9.word[i] = z->word[i + 19U];
+    }
+    EscEccFe_SetZero( &s10 );
+    s10.word[3U] = z->word[23U];
+    s10.word[4U] = z->word[23U];
+
+    EscEccFe_ModularAdd( r, r, &s2, fGP, EscEcc_curveSecp384r1.maxWords );
+    EscEccFe_ModularAdd( r, r, &s2, fGP, EscEcc_curveSecp384r1.maxWords );
+    EscEccFe_ModularAdd( r, r, &s3, fGP, EscEcc_curveSecp384r1.maxWords );
+    EscEccFe_ModularAdd( r, r, &s4, fGP, EscEcc_curveSecp384r1.maxWords );
+    EscEccFe_ModularAdd( r, r, &s5, fGP, EscEcc_curveSecp384r1.maxWords );
+    EscEccFe_ModularAdd( r, r, &s6, fGP, EscEcc_curveSecp384r1.maxWords );
+    EscEccFe_ModularAdd( r, r, &s7, fGP, EscEcc_curveSecp384r1.maxWords );
+    EscEccFe_ModularSub( r, r, &s8, fGP, EscEcc_curveSecp384r1.maxWords );
+    EscEccFe_ModularSub( r, r, &s9, fGP, EscEcc_curveSecp384r1.maxWords );
+    EscEccFe_ModularSub( r, r, &s10, fGP, EscEcc_curveSecp384r1.maxWords );
+}
+
+#endif
+
+#if (EscEcc_SECP_521_ENABLED == 1)
+static void
+EscEccFe_ReduceNIST_521(
+    EscEcc_FieldElementT* r,
+    const EscEcc_FieldElementLongT* z,
+    const EscEcc_FieldT* fGP )
+{
+    /* c = 2^1
+       Algorithm 2.31, Guide to Elliptic Curve Cryptography */
+    EscEcc_FieldElementT s2;
+
+    Esc_UINT8 i;
+
+    r->word[EscEcc_curveSecp521r1.maxWords - 1U] = 0U;
+
+    for (i = 0U; i < 17U; i++)
+    {
+        r->word[i] = (z->word[i + 16U] >> 9U);
+        r->word[i] = ( r->word[i] | (z->word[i + 17U] << 23U) );
+    }
+
+    s2.word[EscEcc_curveSecp521r1.maxWords - 1U] = 0U;
+
+    for (i = 0U; i < 17U; i++)
+    {
+        s2.word[i] = z->word[i];
+    }
+    /* we want the bits 512 to 520 only */
+    s2.word[16U] = (s2.word[16U] & (Esc_UINT32)0x1FF);
+
+    EscEccFe_ModularAdd( r, r, &s2, fGP, EscEcc_curveSecp521r1.maxWords );
+}
+
+#endif
+
+#if (EscEcc_USE_SLIDING_WINDOW == 1) || (EscEcc_ENABLE_SHAMIRS_TRICK == 1)
+/*************************************************
+ * return true if bit on position "index" is set *
+ *************************************************/
+Esc_BOOL
+EscEccFe_isBitSet(
+    const EscEcc_FieldElementT* c,
+    Esc_SINT16 index )
+{
+    Esc_BOOL isSet;
+    if ( ( ( c->word[(Esc_UINT16)index >> 5U] >> ( (Esc_UINT16)index & 0x1fU ) ) & 1U ) == 1U )
+    {
+        isSet = TRUE;
+    }
+    else
+    {
+        isSet = FALSE;
+    }
+
+    return isSet;
+}
+
+#endif
+
+/**************************
+ * sets point to infinity *
+ **************************/
+void
+EscEccPt_SetInfinity(
+    EscEcc_PointT* pX )
+{
+    if (pX->type == C_PT_AFFINE)
+    {
+        /* pX = (0,0,0) */
+        EscEccFe_SetZero( &pX->x );
+        EscEccFe_SetZero( &pX->y );
+        EscEccFe_SetZero( &pX->z );
+    }
+    else
+    {
+        /* pX->type == C_PT_JACOBIAN */
+        /* pX = (1,1,0) */
+        EscEccFe_SetOne( &pX->x );
+        EscEccFe_SetOne( &pX->y );
+        EscEccFe_SetZero( &pX->z );
+    }
+}
+
+/*****************************
+ * checks if a point is zero *
+ *****************************/
+Esc_BOOL
+EscEccPt_IsZero(
+    const EscEcc_PointT* pX,
+    const EscEcc_CurveT* curve )
+{
+    Esc_BOOL isZero = TRUE;
+
+    if (EscEccFe_IsZero( &pX->x, curve->maxWords ) == FALSE)
+    {
+        isZero = FALSE;
+    }
+    else if (EscEccFe_IsZero( &pX->y, curve->maxWords ) == FALSE)
+    {
+        isZero = FALSE;
+    }
+    else
+    {
+        if ( (pX->type == C_PT_JACOBIAN) )
+        {
+            if (EscEccFe_IsZero( &pX->z, curve->maxWords ) == FALSE)
+            {
+                isZero = FALSE;
+            }
+        }
+    }
+
+    return isZero;
+}
+
+/******************************************************
+ * check if a point of the given curve is at infinity *
+ ******************************************************/
+Esc_BOOL
+EscEccPt_IsInfinity(
+    const EscEcc_PointT* pX,
+    const EscEcc_CurveT* curve )
+{
+    Esc_BOOL isInfinity;
+
+    /* check if infinity */
+    if (pX->type == C_PT_AFFINE)
+    {
+        /* pX =? (0,0) */
+        isInfinity = EscEccPt_IsZero( pX, curve );
+    }
+    else
+    {
+        /* pX->type == C_PT_JACOBIAN */
+        /* pX =? (lamba┬▓,lamba┬│,0) */
+        isInfinity = EscEccFe_IsZero( &pX->z, curve->maxWords );
+    }
+
+    return isInfinity;
+}
+
+/******************
+ * assign a point *
+ ******************/
+void
+EscEccPt_Assign(
+    EscEcc_PointT* pY,
+    const EscEcc_PointT* pX,
+    const EscEcc_CurveT* curve )
+{
+    /* assign type */
+    pY->type = pX->type;
+
+    /* assign coordinates */
+    EscEccFe_Assign( &pY->x, &pX->x, curve->maxWords );
+    EscEccFe_Assign( &pY->y, &pX->y, curve->maxWords );
+    EscEccFe_Assign( &pY->z, &pX->z, curve->maxWords );
+}
+
+/**********************************************************
+ * doubles a jacobian projection point                    *
+ * Algorithm A.10.4 from IEEE P1363-2000                  *
+ **********************************************************/
+void
+EscEccPt_JacobianDouble(
+    EscEcc_PointT* pJ,
+    const EscEcc_PointT* pJ0,
+    const EscEcc_CurveT* curve )
+{
+    const Esc_UINT8 maxWords = curve->maxWords;
+    const EscEcc_FieldT* ecc_field_params = &curve->ecc_field_params;
+    Esc_ASSERT( pJ0->type == C_PT_JACOBIAN );
+
+    /* set pJ type */
+    pJ->type = C_PT_JACOBIAN;
+
+    /* check for point at infinity */
+    if ( EscEccPt_IsInfinity( pJ0, curve ) )
+    {
+        EscEccPt_SetInfinity( pJ );
+    }
+    else if ( EscEccFe_IsZero( &pJ0->y, maxWords ) )
+    {
+        EscEccPt_SetInfinity( pJ );
+    }
+    else if ( EscEccFe_IsZero( &pJ0->z, maxWords ) )
+    {
+        EscEccPt_SetInfinity( pJ );
+    }
+    else
+    {
+        EscEcc_FieldElementT T1;
+        EscEcc_FieldElementT T2;
+        EscEcc_FieldElementT T3;
+        EscEcc_FieldElementT T4;
+        EscEcc_FieldElementT T5;
+        EscEcc_FieldElementT TF;
+
+        /* 01.) T1 <- X1 */
+        EscEccFe_Assign( &T1, &pJ0->x, maxWords );
+        /* 02.) T2 <- Y1 */
+        EscEccFe_Assign( &T2, &pJ0->y, maxWords );
+        /* 03.) T3 <- Z1 */
+        EscEccFe_Assign( &T3, &pJ0->z, maxWords );
+
+        /* 04.) If T2 = 0 or T3 = 0 then output (1, 1, 0) and stop */
+        /* checked above */
+
+        /*        T4 <- a */
+        EscEccFe_Assign( &T4, &curve->coefficient_a, maxWords );
+        /*        T5 <- T3┬▓ */
+        EscEccFe_MultiplyModP( &T5, &T3, &T3, curve );
+        /*        T5 <- T5┬▓ */
+        EscEccFe_MultiplyModP( &T5, &T5, &T5, curve );
+        /*        T5 <- T4 * T5 */
+        EscEccFe_MultiplyModP( &T5, &T4, &T5, curve );
+        /*        T4 <- T1┬▓ */
+        EscEccFe_MultiplyModP( &T4, &T1, &T1, curve );
+        /*        T4 <- 3 * T4 */
+        EscEccFe_Assign( &TF, &T4, maxWords );
+        EscEccFe_ModularAdd( &T4, &T4, &T4, ecc_field_params, maxWords );
+        EscEccFe_ModularAdd( &T4, &T4, &TF, ecc_field_params, maxWords );
+
+        /*        T4 <- T4 + T5 = M */
+        EscEccFe_ModularAdd( &T4, &T4, &T5, ecc_field_params, maxWords );
+        /* 06.) T3 <- T2 * T3 */
+        EscEccFe_MultiplyModP( &T3, &T2, &T3, curve );
+        /* 07.) T3 <- 2 * T3 = Z2 */
+        EscEccFe_ModularAdd( &T3, &T3, &T3, ecc_field_params, maxWords );
+        /* 08.) T2 <- T2┬▓ */
+        EscEccFe_MultiplyModP( &T2, &T2, &T2, curve );
+        /* 09.) T5 <- T1 * T2 */
+        EscEccFe_MultiplyModP( &T5, &T1, &T2, curve );
+        /* 10.) T5 <- 4 * T5 = S */
+        EscEccFe_ModularAdd( &T5, &T5, &T5, ecc_field_params, maxWords );
+        EscEccFe_ModularAdd( &T5, &T5, &T5, ecc_field_params, maxWords );
+        /* 11.) T1 <- T4┬▓ */
+        EscEccFe_MultiplyModP( &T1, &T4, &T4, curve );
+        /* 12.) T1 <- T1 - 2 * T5 = X2 */
+        EscEccFe_ModularSub( &T1, &T1, &T5, ecc_field_params, maxWords );
+        EscEccFe_ModularSub( &T1, &T1, &T5, ecc_field_params, maxWords );
+        /* 13.) T2 <- T2┬▓ */
+        EscEccFe_MultiplyModP( &T2, &T2, &T2, curve );
+        /* 14.) T2 <- 8 * T2 = T */
+        EscEccFe_ModularAdd( &T2, &T2, &T2, ecc_field_params, maxWords );
+        EscEccFe_ModularAdd( &T2, &T2, &T2, ecc_field_params, maxWords );
+        EscEccFe_ModularAdd( &T2, &T2, &T2, ecc_field_params, maxWords );
+        /* 15.) T5 <- T5 - T1 */
+        EscEccFe_ModularSub( &T5, &T5, &T1, ecc_field_params, maxWords );
+        /* 16.) T5 <- T4 * T5 */
+        EscEccFe_MultiplyModP( &T5, &T4, &T5, curve );
+        /* 17.) T2 <- T5 - T2 = Y2 */
+        EscEccFe_ModularSub( &T2, &T5, &T2, ecc_field_params, maxWords );
+
+        /* 18.) X2 <- T1 */
+        EscEccFe_Assign( &pJ->x, &T1, maxWords );
+        /* 19.) Y2 <- T2 */
+        EscEccFe_Assign( &pJ->y, &T2, maxWords );
+        /* 20.) Z2 <- T3 */
+        EscEccFe_Assign( &pJ->z, &T3, maxWords );
+    }                           /* ! EscEccPt_IsInfinity( pJ0 ) */
+}
