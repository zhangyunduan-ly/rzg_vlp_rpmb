+const EscEcc_CurveT*
+EscEcc_GetCurve(const EscEcc_CurveId id)
+{
+    /** Lookup table to select a curve by ID */
+    static const EscEcc_CurveT *EscEcc_curveLookup[] =
+    {
+#if (EscEcc_SECP_160_ENABLED == 1)
+        &EscEcc_curveSecp160r1,
+#else
+        Esc_NULL_PTR,
+#endif
+
+#if (EscEcc_SECP_192_ENABLED == 1)
+        &EscEcc_curveSecp192r1,
+#else
+        Esc_NULL_PTR,
+#endif
+
+#if (EscEcc_SECP_224_ENABLED == 1)
+        &EscEcc_curveSecp224r1,
+#else
+        Esc_NULL_PTR,
+#endif
+
+#if (EscEcc_SECP_256_ENABLED == 1)
+        &EscEcc_curveSecp256r1,
+#else
+        Esc_NULL_PTR,
+#endif
+
+#if (EscEcc_SECP_384_ENABLED == 1)
+        &EscEcc_curveSecp384r1,
+#else
+        Esc_NULL_PTR,
+#endif
+
+#if (EscEcc_SECP_521_ENABLED == 1)
+        &EscEcc_curveSecp521r1,
+#else
+        Esc_NULL_PTR,
+#endif
+
+#if (EscEcc_BRAINPOOL_P160_ENABLED == 1)
+        &EscEcc_curveBrainpool160,
+#else
+        Esc_NULL_PTR,
+#endif
+
+#if (EscEcc_BRAINPOOL_P192_ENABLED == 1)
+        &EscEcc_curveBrainpool192,
+#else
+        Esc_NULL_PTR,
+#endif
+
+#if (EscEcc_BRAINPOOL_P224_ENABLED == 1)
+        &EscEcc_curveBrainpool224,
+#else
+        Esc_NULL_PTR,
+#endif
+
+#if (EscEcc_BRAINPOOL_P256_ENABLED == 1)
+        &EscEcc_curveBrainpool256,
+#else
+        Esc_NULL_PTR,
+#endif
+
+#if (EscEcc_BRAINPOOL_P320_ENABLED == 1)
+        &EscEcc_curveBrainpool320,
+#else
+        Esc_NULL_PTR,
+#endif
+
+#if (EscEcc_BRAINPOOL_P384_ENABLED == 1)
+        &EscEcc_curveBrainpool384,
+#else
+        Esc_NULL_PTR,
+#endif
+
+#if (EscEcc_BRAINPOOL_P512_ENABLED == 1)
+        &EscEcc_curveBrainpool512,
+#else
+        Esc_NULL_PTR,
+#endif
+    };
+
+    const EscEcc_CurveT *result = Esc_NULL_PTR;
+
+    if (id <= EscEcc_MAX_CURVE_ID)
+    {
+        result = EscEcc_curveLookup[id];
+    }
+
+    return result;
+}
