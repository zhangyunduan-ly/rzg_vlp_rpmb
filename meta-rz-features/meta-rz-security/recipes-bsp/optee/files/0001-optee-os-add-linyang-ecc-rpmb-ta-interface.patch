+static TEE_Result ecdsa_sec_verify(uint32_t types, TEE_Param params[TEE_NUM_PARAMS])
+{
+    // ķćŹµ¢░Õ«Üõ╣ē4ÕÅéµĢ░ÕłåķģŹ’╝łķĆéķģŹõĖŖÕ▒éµśÄµ¢ćÕģ¼ķÆźõ╝ĀķĆÆ’╝ē’╝Ü
+    // params[0]’╝ÜĶŠōÕģź’╝īµśÄµ¢ćÕģ¼ķÆź’╝łx+yÕłåķćÅ’╝īķĢ┐Õ║”=2*ń¦üķÆźķĢ┐Õ║”’╝ē
+    // params[1]’╝ÜĶŠōÕģź’╝īÕŠģķ¬īĶ»üµĢ░µŹ«+ńŁŠÕÉŹńÜäń╗äÕÉłń╗ōµ×ä’╝łµĀ╝Õ╝Å’╝Ü[4ÕŁŚĶŖéµĢ░µŹ«ķĢ┐Õ║”][ÕŠģķ¬īµĢ░µŹ«][ńŁŠÕÉŹ]’╝ē
+    // params[2]’╝ÜķóäńĢÖ
+    // params[3]’╝ÜĶŠōÕć║’╝īķ¬īĶ»üń╗ōµ×£’╝ł1=µłÉÕŖ¤’╝ī0=Õż▒Ķ┤ź’╝ī1ÕŁŚĶŖé’╝ē
+
+    // µÅÉÕÅ¢ĶŠōÕģźÕÅéµĢ░
+    uint8_t *plain_pub_key = (uint8_t *)params[0].memref.buffer;   // µśÄµ¢ćÕģ¼ķÆź
+    uint32_t plain_pub_len = params[0].memref.size;                // µśÄµ¢ćÕģ¼ķÆźķĢ┐Õ║”
+    uint8_t *combined_data = (uint8_t *)params[1].memref.buffer;   // ń╗äÕÉłµĢ░µŹ«’╝łÕŠģķ¬īµĢ░µŹ«+ńŁŠÕÉŹ’╝ē
+    uint32_t combined_size = params[1].memref.size;                // ń╗äÕÉłµĢ░µŹ«µĆ╗ķĢ┐Õ║”
+    uint8_t *verify_result = (uint8_t *)params[3].memref.buffer;   // ķ¬īĶ»üń╗ōµ×£ĶŠōÕć║
+    uint32_t result_buf_size = params[3].memref.size;              // ń╗ōµ×£ń╝ōÕå▓Õī║Õż¦Õ░Å
+
+    // Õåģķā©ÕÅśķćÅ
+    BOOL verify_success = FALSE;
+    uint8_t t_key_len;                  // ń¦üķÆźķĢ┐Õ║”’╝ł=Õģ¼ķÆźķĢ┐Õ║”/2’╝ē
+    TEE_Result tee_res = TEE_SUCCESS;
+    // ń╗äÕÉłµĢ░µŹ«Ķ¦Żµ×ÉÕÉÄÕÅśķćÅ
+    uint32_t data_len;                  // ÕŠģķ¬īĶ»üµĢ░µŹ«ķĢ┐Õ║”
+    uint8_t *pBuf;                      // ÕŠģķ¬īĶ»üµĢ░µŹ«µīćķÆł
+    uint8_t *pSig;                      // ńŁŠÕÉŹµĢ░µŹ«µīćķÆł
+    uint32_t sig_len;                   // ńŁŠÕÉŹķĢ┐Õ║”
+
+
+    // 1. µĀĪķ¬īÕÅéµĢ░ń▒╗Õ×ŗ
+    if (types != TEE_PARAM_TYPES(
+                    TEE_PARAM_TYPE_MEMREF_INPUT,   // params[0]’╝ÜµśÄµ¢ćÕģ¼ķÆź
+                    TEE_PARAM_TYPE_MEMREF_INPUT,   // params[1]’╝Üń╗äÕÉłµĢ░µŹ«
+                    TEE_PARAM_TYPE_NONE,            // params[2]’╝ÜķóäńĢÖ
+                    TEE_PARAM_TYPE_MEMREF_OUTPUT)) { // params[3]’╝Üķ¬īĶ»üń╗ōµ×£
+        DMSG("\r\n[ECDSA-Verify-TEE] Invalid param types (expected 2 input + 1 output)");
+        return TEE_ERROR_BAD_PARAMETERS;
+    }
+
+
+    // 2. Õ¤║ńĪĆÕÅéµĢ░µ£ēµĢłµĆ¦µĀĪķ¬ī
+    if (!plain_pub_key || !combined_data || !verify_result) {
+        DMSG("\r\n[ECDSA-Verify-TEE] NULL pointer in params (pubkey/combined-data/result)");
+        return TEE_ERROR_BAD_PARAMETERS;
+    }
+
+
+    // 3. Ķ¦Żµ×Éń╗äÕÉłµĢ░µŹ«
+    if (combined_size < 4) { // Ķć│Õ░æķ£ĆĶ”ü4ÕŁŚĶŖéÕŁśÕé©ÕŠģķ¬īµĢ░µŹ«ķĢ┐Õ║”
+        DMSG("\r\n[ECDSA-Verify-TEE] Combined data too short (need >=4 bytes, got %u)", combined_size);
+        *verify_result = 0;
+        return TEE_ERROR_BAD_PARAMETERS;
+    }
+    // µÅÉÕÅ¢ÕŠģķ¬īµĢ░µŹ«ķĢ┐Õ║”
+    data_len = *(uint32_t *)combined_data;
+    pBuf = combined_data + 4;                  // ÕŠģķ¬īµĢ░µŹ«ĶĄĘÕ¦ŗÕ£░ÕØĆ
+    pSig = pBuf + data_len;                    // ńŁŠÕÉŹĶĄĘÕ¦ŗÕ£░ÕØĆ’╝łµĢ░µŹ«õ╣ŗÕÉÄ’╝ē
+    sig_len = combined_size - 4 - data_len;    // ńŁŠÕÉŹķĢ┐Õ║”
+
+    // µĀĪķ¬īń╗äÕÉłµĢ░µŹ«Õ«īµĢ┤µĆ¦
+    if (4 + data_len + sig_len != combined_size) {
+        DMSG("\r\n[ECDSA-Verify-TEE] Combined data format invalid (size mismatch)");
+        *verify_result = 0;
+        return TEE_ERROR_BAD_PARAMETERS;
+    }
+    // µĀĪķ¬īÕŠģķ¬īµĢ░µŹ«ķĢ┐Õ║”µ£ēµĢłµĆ¦
+    if (data_len <= 0 || pBuf >= pSig) {
+        DMSG("\r\n[ECDSA-Verify-TEE] Invalid data length in combined data (%u)", data_len);
+        *verify_result = 0;
+        return TEE_ERROR_BAD_PARAMETERS;
+    }
+
+
+    // 4. µĀĪķ¬īµśÄµ¢ćÕģ¼ķÆźÕÆīńŁŠÕÉŹķĢ┐Õ║”
+    // Õģ¼ķÆźķĢ┐Õ║”Õ┐ģķĪ╗µś»256õĮŹ’╝ł64ÕŁŚĶŖé’╝ēµł¢384õĮŹ’╝ł96ÕŁŚĶŖé’╝ē
+    if (plain_pub_len != 2 * ECC256_PRIKEY_LEN && plain_pub_len != 2 * ECC384_PRIKEY_LEN) {
+        DMSG("\r\n[ECDSA-Verify-TEE] Invalid plain pubkey length (%u, need 64/96 bytes)", plain_pub_len);
+        *verify_result = 0;
+        return TEE_ERROR_BAD_PARAMETERS;
+    }
+    // ń¦üķÆźķĢ┐Õ║” = Õģ¼ķÆźķĢ┐Õ║” / 2
+    t_key_len = plain_pub_len / 2;
+    // ńŁŠÕÉŹķĢ┐Õ║”Õ┐ģķĪ╗ńŁēõ║ÄÕģ¼ķÆźķĢ┐Õ║”
+    if (sig_len != plain_pub_len) {
+        DMSG("\r\n[ECDSA-Verify-TEE] Sig len (%u) != pubkey len (%u)", sig_len, plain_pub_len);
+        *verify_result = 0;
+        return TEE_ERROR_BAD_PARAMETERS;
+    }
+
+
+    // 5. µĀĪķ¬īń╗ōµ×£ń╝ōÕå▓Õī║Õż¦Õ░Å
+    if (result_buf_size < 1) {
+        DMSG("\r\n[ECDSA-Verify-TEE] Result buf too small (need 1 byte, got %u)", result_buf_size);
+        return TEE_ERROR_SHORT_BUFFER;
+    }
+
+
+    // 6. ńø┤µÄźõĮ┐ńö©µśÄµ¢ćÕģ¼ķÆźµē¦ĶĪīńŁŠÕÉŹķ¬īĶ»ü
+    DMSG("\r\n[ECDSA-Verify-TEE] Start verification with plain pubkey:");
+    DMSG("\r\n  Pubkey len: %u bytes, Data len: %u bytes, Sig len: %u bytes",
+         plain_pub_len, data_len, sig_len);
+    // Ķ░āńö©µĀĖÕ┐āķ¬īńŁŠµÄźÕÅŻ
+    verify_success = Servp_ECDSA_Verification(plain_pub_key, t_key_len, pBuf, data_len, pSig);
+
+
+    // 7. Ķ«ŠńĮ«ķ¬īĶ»üń╗ōµ×£’╝ł1=µłÉÕŖ¤’╝ī0=Õż▒Ķ┤ź’╝ē
+    *verify_result = verify_success ? 1 : 0;
+    params[3].memref.size = 1; // Õø║Õ«Üń╗ōµ×£ķĢ┐Õ║”õĖ║1ÕŁŚĶŖé
+
+    if (!verify_success) {
+        DMSG("\r\n[ECDSA-Verify-TEE] Verification failed");
+        return TEE_ERROR_SIGNATURE_INVALID;
+    }
+
+    DMSG("\r\n[ECDSA-Verify-TEE] Verification succeeded");
+    return TEE_SUCCESS;
+}
