+/************************************************
+ * multiply two field elements under modulus n  *
+ ************************************************/
+#if EscEcc_ECDSA_ENABLED == 1
+void
+EscEccFe_MultiplyModN(
+    EscEcc_FieldElementT* c,
+    const EscEcc_FieldElementT* a,
+    const EscEcc_FieldElementT* b,
+    const EscEcc_CurveT* curve )
+{
+    EscEcc_FieldElementLongT longC;
+
+    /* Multiply */
+    EscEccFe_MultiplyShort( &longC, a, b, curve );
+
+    /* Reduce with Barrett reduction */
+    EscEccFe_ReduceBarrett( c, &longC, &curve->base_point_order_n, curve );
+}
