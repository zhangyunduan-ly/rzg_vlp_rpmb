+/**********************************************************
+ * add two jacobian points to a jacobian projection point *
+ * Algorithm A.10.5 from IEEE P1363-2000                  *
+ **********************************************************/
+void
+EscEccPt_JacobianAdd(
+    EscEcc_PointT* pJ,
+    const EscEcc_PointT* pJ0,
+    const EscEcc_PointT* pJ1,
+    const EscEcc_CurveT* curve )
+{
+    const Esc_UINT8 maxWords = curve->maxWords;
+    const EscEcc_FieldT* ecc_field_params = &curve->ecc_field_params;
+    Esc_ASSERT( pJ0->type == C_PT_JACOBIAN );
+    Esc_ASSERT( pJ1->type == C_PT_JACOBIAN );
+
+    /* pJ0 =? (0) */
+    if ( EscEccPt_IsInfinity( pJ0, curve ) )
+    {
+        /* pJ <- pJ1 */
+        EscEccPt_Assign( pJ, pJ1, curve );
+    }
+    else if ( EscEccPt_IsInfinity( pJ1, curve ) )           /* pJ1 =? (0) */
+    {   
+        /* pJ <- pJ0 */
+        EscEccPt_Assign( pJ, pJ0, curve );
+    }
+    else
+    {
+        Esc_BOOL Z1_is_1;
+        EscEcc_FieldElementT T1;
+        EscEcc_FieldElementT T2;
+        EscEcc_FieldElementT T3;
+        EscEcc_FieldElementT T4;
+        EscEcc_FieldElementT T5;
+        EscEcc_FieldElementT T6;
+        EscEcc_FieldElementT T7;
+
+        /* set pJ type. */
+        pJ->type = C_PT_JACOBIAN;
+
+        /* 1.) T1 <- X0 = U0 (if Z1 = 1) */
+        EscEccFe_Assign( &T1, &pJ0->x, maxWords );
+        /* 2.) T2 <- Y0 = S0 (if Z1 = 1) */
+        EscEccFe_Assign( &T2, &pJ0->y, maxWords );
+        /* 3.) T3 <- Z0 */
+        EscEccFe_Assign( &T3, &pJ0->z, maxWords );
+        /* 4.) T4 <- X1 */
+        EscEccFe_Assign( &T4, &pJ1->x, maxWords );
+        /* 5.) T5 <- Y1 */
+        EscEccFe_Assign( &T5, &pJ1->y, maxWords );
+
+        /* 6.) if Z1 != 1 then */
+        Z1_is_1 = EscEccFe_IsOne( &pJ1->z, maxWords );
+        if (Z1_is_1 == FALSE)
+        {
+            /* 6.a) T6 <- Z1 */
+            EscEccFe_Assign( &T6, &pJ1->z, maxWords );
+            /* 6.b) T7 <- T6┬▓ */
+            EscEccFe_MultiplyModP( &T7, &T6, &T6, curve );
+            /* 6.c) T1 <- T1 * T7 = U0 (if Z1 != 1) */
+            EscEccFe_MultiplyModP( &T1, &T1, &T7, curve );
+            /* 6.d) T7 <- T6 * T7 */
+            EscEccFe_MultiplyModP( &T7, &T6, &T7, curve );
+            /* 6.e) T2 <- T2 * T7 = S0 (if Z1 != 1) */
+            EscEccFe_MultiplyModP( &T2, &T2, &T7, curve );
+        }
+
+        /* 7.) T7 <- T3┬▓ */
+        EscEccFe_MultiplyModP( &T7, &T3, &T3, curve );
+        /* 8.) T4 <- T4 * T7 = U1 */
+        EscEccFe_MultiplyModP( &T4, &T4, &T7, curve );
+        /* 9.) T7 <- T3 * T7 */
+        EscEccFe_MultiplyModP( &T7, &T3, &T7, curve );
+        /* 10.) T5 <- T5 * T7 = S1 */
+        EscEccFe_MultiplyModP( &T5, &T5, &T7, curve );
+        /* 11.) T4 <- T1 - T4 = W */
+        EscEccFe_ModularSub( &T4, &T1, &T4, ecc_field_params, maxWords );
+        /* 12.) T5 <- T2 - T5 = R */
+        EscEccFe_ModularSub( &T5, &T2, &T5, ecc_field_params, maxWords );
+
+        /* 13.) if T4 = 0 then */
+        if ( EscEccFe_IsZero( &T4, maxWords ) )
+        {
+            if ( EscEccFe_IsZero( &T5, maxWords ) )
+            {
+                /* 13.a) if T5 = 0 then output (0,0,0) and stop */
+                /* double pJ1 */
+                EscEccPt_JacobianDouble( pJ, pJ1, curve );
+            }
+            else
+            {
+                /* 13.b) else output (1, 1, 0) and stop */
+                /* pJ = (0) */
+                EscEccPt_SetInfinity( pJ );
+            }
+        }
+        else
+        {
+            Esc_UINT32 carry;
+
+            /* 14.) T1 <- 2 * T1 - T4 = T */
+            EscEccFe_ModularAdd( &T1, &T1, &T1, ecc_field_params, maxWords );
+            EscEccFe_ModularSub( &T1, &T1, &T4, ecc_field_params, maxWords );
+
+            /* 15.) T2 <- 2 * T2 - T5 = M */
+            EscEccFe_ModularAdd( &T2, &T2, &T2, ecc_field_params, maxWords );
+            EscEccFe_ModularSub( &T2, &T2, &T5, ecc_field_params, maxWords );
+
+            /* 16.) If Z1 != 1 then T3 <- T3 * T6 */
+            if (Z1_is_1 == FALSE)
+            {
+                EscEccFe_MultiplyModP( &T3, &T3, &T6, curve );
+            }
+
+            /* 17.) T3 <- T3 * T4 = Z2 */
+            EscEccFe_MultiplyModP( &T3, &T3, &T4, curve );
+            /* 18.) T7 <- T4┬▓ */
+            EscEccFe_MultiplyModP( &T7, &T4, &T4, curve );
+            /* 19.) T4 <- T4 * T7 */
+            EscEccFe_MultiplyModP( &T4, &T4, &T7, curve );
+            /* 20.) T7 <- T1 * T7 */
+            EscEccFe_MultiplyModP( &T7, &T1, &T7, curve );
+            /* 21.) T1 <- T5┬▓ */
+            EscEccFe_MultiplyModP( &T1, &T5, &T5, curve );
+            /* 22.) T1 <- T1 - T7 = X2 */
+            EscEccFe_ModularSub( &T1, &T1, &T7, ecc_field_params, maxWords );
+            /* 23.) T7 <- T7 - 2 * T1 = V */
+            EscEccFe_ModularSub( &T7, &T7, &T1, ecc_field_params, maxWords );
+            EscEccFe_ModularSub( &T7, &T7, &T1, ecc_field_params, maxWords );
+
+            /* 24.) T5 <- T5 * T7 */
+            EscEccFe_MultiplyModP( &T5, &T5, &T7, curve );
+            /* 25.) T4 <- T2 * T4 */
+            EscEccFe_MultiplyModP( &T4, &T2, &T4, curve );
+            /* 26.) T2 <- T5 - T4 */
+            EscEccFe_ModularSub( &T2, &T5, &T4, ecc_field_params, maxWords );
+            /* 27.) T2 <- T2 / 2 = Y2 */
+            /* compute (p+1)/2 = inv(2) */
+            EscEccFe_Assign( &T7, &curve->ecc_field_params.prime_p, maxWords );
+            EscEccFe_SetOne( &T6 );
+            EscEccWd_AddCLoop( &carry, T7.word, T7.word, T6.word, maxWords );
+            EscEccFe_ShiftRight( &T7, maxWords );
+            EscEccFe_MultiplyModP( &T2, &T2, &T7, curve );
+
+            /* 28.) X2 <- T1 */
+            EscEccFe_Assign( &pJ->x, &T1, maxWords );
+            /* 29.) Y2 <- T2 */
+            EscEccFe_Assign( &pJ->y, &T2, maxWords );
+            /* 30.) Z2 <- T3 */
+            EscEccFe_Assign( &pJ->z, &T3, maxWords );
+        }                       /* !EscEccFe_IsZero( &T4 ) */
+    }                           /* pJ0 != (0) && pJ1 != (0) */
+}
