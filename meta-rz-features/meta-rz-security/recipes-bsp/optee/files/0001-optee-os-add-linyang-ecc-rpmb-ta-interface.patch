+    Rl( e, a, b, c, d, F3, K3, M(46) );  
+    Rl( d, e, a, b, c, F3, K3, M(47) );  
+    Rl( c, d, e, a, b, F3, K3, M(48) );  
+    Rl( b, c, d, e, a, F3, K3, M(49) );  
+    Rl( a, b, c, d, e, F3, K3, M(50) );  
+    Rl( e, a, b, c, d, F3, K3, M(51) );  
+    Rl( d, e, a, b, c, F3, K3, M(52) );  
+    Rl( c, d, e, a, b, F3, K3, M(53) );  
+    Rl( b, c, d, e, a, F3, K3, M(54) );  
+    Rl( a, b, c, d, e, F3, K3, M(55) );  
+    Rl( e, a, b, c, d, F3, K3, M(56) );  
+    Rl( d, e, a, b, c, F3, K3, M(57) );  
+    Rl( c, d, e, a, b, F3, K3, M(58) );  
+    Rl( b, c, d, e, a, F3, K3, M(59) );  
+    Rl( a, b, c, d, e, F4, K4, M(60) );  
+    Rl( e, a, b, c, d, F4, K4, M(61) );  
+    Rl( d, e, a, b, c, F4, K4, M(62) );  
+    Rl( c, d, e, a, b, F4, K4, M(63) );  
+    Rl( b, c, d, e, a, F4, K4, M(64) );  
+    Rl( a, b, c, d, e, F4, K4, M(65) );  
+    Rl( e, a, b, c, d, F4, K4, M(66) );  
+    Rl( d, e, a, b, c, F4, K4, M(67) );  
+    Rl( c, d, e, a, b, F4, K4, M(68) );  
+    Rl( b, c, d, e, a, F4, K4, M(69) );  
+    Rl( a, b, c, d, e, F4, K4, M(70) );  
+    Rl( e, a, b, c, d, F4, K4, M(71) );  
+    Rl( d, e, a, b, c, F4, K4, M(72) );  
+    Rl( c, d, e, a, b, F4, K4, M(73) );  
+    Rl( b, c, d, e, a, F4, K4, M(74) );  
+    Rl( a, b, c, d, e, F4, K4, M(75) );  
+    Rl( e, a, b, c, d, F4, K4, M(76) );  
+    Rl( d, e, a, b, c, F4, K4, M(77) );  
+    Rl( c, d, e, a, b, F4, K4, M(78) );  
