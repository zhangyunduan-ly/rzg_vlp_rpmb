+// ÕćĮµĢ░’╝ÜCRC µĀĪķ¬īÕż▒Ķ┤źÕÉÄńÜäµŁóµŹ¤ÕżäńÉå
+void rpmb_key_crc_fail_stop_loss(RPMB_Key_Storage *storage)
+{
+    if (storage == NULL) {
+        return;
+    }
+
+    // 1. µĀćĶ«░ń╗ōµ×äõĮōµŚĀµĢł
+    storage->is_valid = 0;
+
+    // 2. µĖģń®║µĀĖÕ┐āÕ»åķÆźµĢ░µŹ«
+    memset(storage->key_data, 0, sizeof(storage->key_data));
+    memset(storage->key_len, 0, sizeof(storage->key_len));
+    storage->rpmb_key_id = 0;
+
+    // 3. µĖģń®║ CRC ÕŁŚµ«Ą
+    storage->crc32_value = 0;
+}
