+static TEE_Result read_raw_object(uint32_t param_types, TEE_Param params[4])
+{
+	const uint32_t exp_param_types =
+		TEE_PARAM_TYPES(TEE_PARAM_TYPE_MEMREF_INPUT,
+				TEE_PARAM_TYPE_MEMREF_OUTPUT,
+				TEE_PARAM_TYPE_NONE,
+				TEE_PARAM_TYPE_NONE);
+	TEE_ObjectHandle object;
+	TEE_ObjectInfo object_info;
+	TEE_Result res;
+	uint32_t read_bytes;
+	char *obj_id;
+	size_t obj_id_sz;
+	char *data;
+	size_t data_sz;
+
+	/*
+	 * Safely get the invocation parameters
+	 */
+	if (param_types != exp_param_types)
+		return TEE_ERROR_BAD_PARAMETERS;
+
+	obj_id_sz = params[0].memref.size;
+	obj_id = TEE_Malloc(obj_id_sz, 0);
+	if (!obj_id)
+		return TEE_ERROR_OUT_OF_MEMORY;
+
+	TEE_MemMove(obj_id, params[0].memref.buffer, obj_id_sz);
+
+	data_sz = params[1].memref.size;
+	data = TEE_Malloc(data_sz, 0);
+	if (!data)
+		return TEE_ERROR_OUT_OF_MEMORY;
+
+	/*
+	 * Check the object exist and can be dumped into output buffer
+	 * then dump it.
+	 */
+	res = TEE_OpenPersistentObject(TEE_STORAGE_PRIVATE_RPMB,
+					obj_id, obj_id_sz,
+					TEE_DATA_FLAG_ACCESS_READ |
+					TEE_DATA_FLAG_SHARE_READ,
+					&object);
+	if (res != TEE_SUCCESS) {
+		EMSG("Failed to open persistent object, res=0x%08x", res);
+		TEE_Free(obj_id);
+		TEE_Free(data);
+		return res;
+	}
+
+	res = TEE_GetObjectInfo1(object, &object_info);
+	if (res != TEE_SUCCESS) {
+		EMSG("Failed to create persistent object, res=0x%08x", res);
+		goto exit;
+	}
+
+	if (object_info.dataSize > data_sz) {
+		/*
+		 * Provided buffer is too short.
+		 * Return the expected size together with status "short buffer"
+		 */
+		params[1].memref.size = object_info.dataSize;
+		res = TEE_ERROR_SHORT_BUFFER;
+		goto exit;
+	}
+
+	res = TEE_ReadObjectData(object, data, object_info.dataSize,
+				 &read_bytes);
+	if (res == TEE_SUCCESS)
+		TEE_MemMove(params[1].memref.buffer, data, read_bytes);
+	if (res != TEE_SUCCESS || read_bytes != object_info.dataSize) {
+		EMSG("TEE_ReadObjectData failed 0x%08x, read %" PRIu32 " over %u",
+				res, read_bytes, object_info.dataSize);
+		goto exit;
+	}
+
+	/* Return the number of byte effectively filled */
+	params[1].memref.size = read_bytes;
+exit:
+	TEE_CloseObject(object);
+	TEE_Free(obj_id);
+	TEE_Free(data);
+	return res;
+}
+
+static TEE_Result read_raw_object_from_ram(uint32_t param_types, TEE_Param params[4])
+{
+    const uint32_t exp_param_types =
+        TEE_PARAM_TYPES(TEE_PARAM_TYPE_MEMREF_INPUT,
+                        TEE_PARAM_TYPE_MEMREF_OUTPUT, 
+                        TEE_PARAM_TYPE_NONE,
+                        TEE_PARAM_TYPE_NONE);
+    TEE_Result res = TEE_SUCCESS;
+    char *obj_id = NULL;
+    size_t obj_id_sz = 0;
+    size_t data_sz = 0;
+    uint32_t target_key_id = 0;
+
+    // 1. ÕģźÕÅéń▒╗Õ×ŗµĀĪķ¬ī
+    if (param_types != exp_param_types) {
+        EMSG("\r\n param_types mismatch, exp=0x%08x, act=0x%08x", exp_param_types, param_types);
+        return TEE_ERROR_BAD_PARAMETERS;
+    }
+
+    // 2. µÅÉÕÅ¢ÕģźÕÅéÕ¤║µ£¼õ┐Īµü»
+    obj_id_sz = params[0].memref.size;
+    data_sz = params[1].memref.size;
+
+    // 3. µĀĪķ¬īobj_idķĢ┐Õ║”
+    if (obj_id_sz < sizeof(uint32_t)) {
+        EMSG("\r\n obj_id size too small! need at least %zu Bytes, actual %zu Bytes", 
+             sizeof(uint32_t), obj_id_sz);
+        return TEE_ERROR_BAD_PARAMETERS;
+    }
+
+    // 4. Ķ¦Żµ×Éńø«µĀćkey_id
+    target_key_id = *(const uint32_t *)params[0].memref.buffer;
+    DMSG("Read target_key_id=0x%08X from RAM", target_key_id);
+
+    // ========== ń╗¤õĖĆÕżäńÉåECCÕ»åķÆź ==========
+    ECC_RPMB_Key_Storage *ecc_cache_node = NULL;
+    const char *cache_name = NULL;
+    if (get_ecc_cache_by_key_id(target_key_id, &ecc_cache_node, &cache_name) == TEE_SUCCESS) {
+        size_t ecc_cache_len = sizeof(ECC_RPMB_Key_Storage);
+
+        // 5.1 µĀĪķ¬īECCń╝ōÕŁśµ£ēµĢłµĆ¦
+        int is_ecc_valid = 0;
+        for (int g = 0; g < ECC_KEY_GROUP_COUNT; g++) {
+            for (int t = 0; t < ASYKEY_TYPE_COUNT; t++) {
+                if (ecc_cache_node->ecc_key_valid[g][t] == 1) {
+                    is_ecc_valid = 1;
+                    break;
+                }
+            }
+            if (is_ecc_valid) break;
+        }
+
+        // 5.2 ń╝ōÕŁśµŚĀµĢłÕłżµ¢Ł
+        if (!is_ecc_valid) {
+            EMSG("\r\n [ECC CACHE(%s)] CACHE INVALID! key_id=0x%08X, no valid [group][type]", 
+                 cache_name, target_key_id);
+            return TEE_ERROR_BAD_STATE;
+        }
+
+        // 5.3 ECCõĖōÕ▒×CRCµĀĪķ¬ī
+        int crc_verify_result = verify_ecc_key_crc(ecc_cache_node);
+        if (crc_verify_result != 0) {
+            EMSG("\r\n [ECC CACHE(%s)] CRC VERIFY FAILED! key_id=0x%08X", cache_name, target_key_id);
+            // ECCń╝ōÕŁśµŁóµŹ¤’╝ÜµĖģń®║µŚĀµĢłµĢ░µŹ«
+            ecc_key_crc_fail_stop_loss(ecc_cache_node);
+            return TEE_ERROR_BAD_PARAMETERS;
+        }
+        DMSG("\r\n [ECC CACHE(%s)] CRC VERIFY SUCCESS! key_id=0x%08X", cache_name, target_key_id);
+
+        // 5.4 µĀĪķ¬īĶŠōÕć║ń╝ōÕå▓Õī║ķĢ┐Õ║”
+        if (ecc_cache_len > data_sz) {
+            params[1].memref.size = ecc_cache_len;
+            EMSG("\r\n [ECC CACHE(%s)] Output buffer too short! need %zu Bytes, actual %zu Bytes",  
+                 cache_name, ecc_cache_len, data_sz);
+            return TEE_ERROR_SHORT_BUFFER;
+        }
+
+        // 5.5 µŗĘĶ┤ØECCń╝ōÕŁśµĢ░µŹ«Õł░ĶŠōÕć║ń╝ōÕå▓Õī║
+        TEE_MemMove(params[1].memref.buffer, ecc_cache_node, ecc_cache_len);
+        params[1].memref.size = ecc_cache_len;
+        IMSG("\r\n [ECC CACHE(%s)] READ SUCCESS! key_id=0x%08X, copy_len=%zu Bytes",
+             cache_name, target_key_id, ecc_cache_len);
+    } 
+    // ========== ķĆÜńö©Õ»åķÆźń╝ōÕŁśĶ»╗ÕÅ¢Õłåµö» ==========
+    else {
+        int cache_idx = rpmb_cache_alloc_or_find_idx(target_key_id);
+        DMSG("Read cache_idx=%d from RAM (Common key)", cache_idx);
+
+        // 6.1 µŻĆµ¤źń╝ōÕŁśń┤óÕ╝Ģµ£ēµĢłµĆ¦
+        if (cache_idx < 0) {
+            EMSG("\r\n [RPMB CACHE] NO CACHE FOUND! target_key_id=0x%08X", target_key_id);
+            return TEE_ERROR_ITEM_NOT_FOUND;
+        }
+
+        // 6.2 ĶÄĘÕÅ¢ķĆÜńö©Õ»åķÆźń╝ōÕŁśĶŖéńé╣
+        RPMB_Key_Storage *cache_node = &g_rpmb_key_cache[cache_idx];
+
+        // 6.3 µĀĪķ¬īķĆÜńö©ń╝ōÕŁśµ£ēµĢłµĆ¦
+        if (cache_node->is_valid != 1 || cache_node->rpmb_key_id != target_key_id) {
+            EMSG("\r\n [RPMB CACHE] CACHE INVALID! key_id=0x%08X, is_valid=%d", 
+                 target_key_id, cache_node->is_valid);
+            return TEE_ERROR_BAD_STATE;
+        }
+
+        // 6.4 ķĆÜńö©Õ»åķÆźCRCµĀĪķ¬ī
+        int crc_verify_result = verify_rpmb_key_crc(cache_node);
+        if (crc_verify_result != 0) {
+            EMSG("\r\n [RPMB CACHE] CRC VERIFY FAILED! key_id=0x%08X, cache_idx=%d", 
+                 target_key_id, cache_idx);
+            // ķĆÜńö©ń╝ōÕŁśµŁóµŹ¤
+            rpmb_key_crc_fail_stop_loss(cache_node);
+            return TEE_ERROR_BAD_PARAMETERS;
+        }
+        DMSG("\r\n [RPMB CACHE] CRC VERIFY SUCCESS! key_id=0x%08X, cache_idx=%d", 
+             target_key_id, cache_idx);
+
+        // 6.5 µĀĪķ¬īĶŠōÕć║ń╝ōÕå▓Õī║ķĢ┐Õ║”
+        size_t cache_data_len = sizeof(RPMB_Key_Storage);
+        if (cache_data_len > data_sz) {
+            params[1].memref.size = cache_data_len;
+            EMSG("\r\n [RPMB CACHE] Output buffer too short! need %zu Bytes, actual %zu Bytes", 
+                 cache_data_len, data_sz);
+            return TEE_ERROR_SHORT_BUFFER;
+        }
+
+        // 6.6 µŗĘĶ┤ØķĆÜńö©ń╝ōÕŁśµĢ░µŹ«Õł░ĶŠōÕć║ń╝ōÕå▓Õī║
+        TEE_MemMove(params[1].memref.buffer, cache_node, cache_data_len);
+        params[1].memref.size = cache_data_len;
+
+        IMSG("\r\n [RPMB CACHE] READ SUCCESS! key_id=0x%08X, cache_idx=%d, copy_len=%zu Bytes",
+             target_key_id, cache_idx, cache_data_len);
+    }
+
+    return res;
+}
+
+static TEE_Result read_raw_object_to_ram(uint32_t param_types, TEE_Param params[4])
+{
+    const uint32_t exp_param_types =
+        TEE_PARAM_TYPES(TEE_PARAM_TYPE_MEMREF_INPUT,
+                        TEE_PARAM_TYPE_MEMREF_OUTPUT,
+                        TEE_PARAM_TYPE_NONE,
+                        TEE_PARAM_TYPE_NONE);
+    TEE_ObjectHandle object = NULL;
+    TEE_ObjectInfo object_info; 
+    TEE_Result res = TEE_SUCCESS; // ÕłØÕ¦ŗÕī¢ķ╗śĶ«żµłÉÕŖ¤
+    uint32_t read_bytes = 0;
+    char *obj_id = NULL;
+    size_t obj_id_sz = 0;
+    char *data = NULL;
+    size_t data_sz = 0;
+    uint32_t target_key_id = 0;
+
+    /* 1. ÕģźÕÅéń▒╗Õ×ŗµĀĪķ¬ī */
+    if (param_types != exp_param_types) {
+        EMSG("Invalid param types, expect 0x%08X, got 0x%08X", exp_param_types, param_types);
+        return TEE_ERROR_BAD_PARAMETERS;
+    }
+
+    /* 2. Õ«ēÕģ©ĶÄĘÕÅ¢obj_id’╝łrpmb_key_id’╝ē */
+    obj_id_sz = params[0].memref.size;
+    obj_id = TEE_Malloc(obj_id_sz, 0);
+    if (!obj_id) {
+        EMSG("Malloc obj_id failed, size=%zu", obj_id_sz);
+        return TEE_ERROR_OUT_OF_MEMORY;
+    }
+    TEE_MemMove(obj_id, params[0].memref.buffer, obj_id_sz);
+    
+    // µÅÉÕēŹĶ¦Żµ×Ékey_id’╝īńö©õ║ÄÕÉÄń╗ŁÕłåµö»Õłżµ¢Ł
+    if (obj_id_sz >= sizeof(uint32_t)) {
+        target_key_id = *(const uint32_t *)obj_id;
+    } else {
+        EMSG("obj_id size too small, can't parse key_id (sz=%zu)", obj_id_sz);
+        res = TEE_ERROR_BAD_PARAMETERS;
+        goto exit;
+    }
+
+    /* 3. Õ«ēÕģ©ĶÄĘÕÅ¢ĶŠōÕć║ń╝ōÕå▓Õī║ */
+    data_sz = params[1].memref.size;
+    data = TEE_Malloc(data_sz, 0);
+    if (!data) {
+        EMSG("Malloc data buffer failed, size=%zu", data_sz);
+        res = TEE_ERROR_OUT_OF_MEMORY;
+        goto exit;
+    }
+
+    /* 4. µēōÕ╝ĆRPMBµīüõ╣ģÕī¢Õ»╣Ķ▒Ī */
+    res = TEE_OpenPersistentObject(TEE_STORAGE_PRIVATE_RPMB,
+                    obj_id, obj_id_sz,
+                    TEE_DATA_FLAG_ACCESS_READ | TEE_DATA_FLAG_SHARE_READ, 
+                    &object);
+    if (res != TEE_SUCCESS) {
+        EMSG("Open RPMB object failed, res=0x%08X, key_id=0x%08X", res, target_key_id);
+        goto exit;
+    }
+
+    /* 5. ĶÄĘÕÅ¢Õ»╣Ķ▒Īõ┐Īµü»’╝īµĀĪķ¬īń╝ōÕå▓Õī║Õż¦Õ░Å */
+    res = TEE_GetObjectInfo1(object, &object_info);
+    if (res != TEE_SUCCESS) {
+        EMSG("Get object info failed, res=0x%08X", res);
+        goto exit;
+    }
+    if (object_info.dataSize > data_sz) {
+        params[1].memref.size = object_info.dataSize;
+        EMSG("Output buffer too small! need %u Bytes, got %zu Bytes", object_info.dataSize, data_sz);
+        res = TEE_ERROR_SHORT_BUFFER;
+        goto exit;
+    }
+
+    /* 6. Ķ»╗ÕÅ¢RPMBµĢ░µŹ«Õł░õĖ┤µŚČń╝ōÕå▓Õī║ */
+    res = TEE_ReadObjectData(object, data, object_info.dataSize, &read_bytes);
+    if (res != TEE_SUCCESS || read_bytes != object_info.dataSize) {
+        EMSG("Read RPMB data failed! res=0x%08X, read %" PRIu32 " / %u Bytes",res, read_bytes, object_info.dataSize);
+        goto exit;
+    }
+    EMSG("\r\n read_bytes=%" PRIu32, read_bytes);
+
+    /* 7. ń╗¤õĖĆÕżäńÉåECCÕ»åķÆź */
+    ECC_RPMB_Key_Storage *ecc_cache_node = NULL;
+    const char *cache_name = NULL;
+    if (get_ecc_cache_by_key_id(target_key_id, &ecc_cache_node, &cache_name) == TEE_SUCCESS) {
+        // 7.1 µĀĪķ¬īECCµĢ░µŹ«ķĢ┐Õ║”
+        if (read_bytes != sizeof(ECC_RPMB_Key_Storage)) {
+            EMSG("ECC %s data size mismatch! expect %zu, got %" PRIu32, 
+                 cache_name, sizeof(ECC_RPMB_Key_Storage), read_bytes);
+            res = TEE_ERROR_CORRUPT_OBJECT;
+            goto exit;
+        }
+
+        // 7.2 ECCõĖōÕ▒×CRCµĀĪķ¬ī
+        ECC_RPMB_Key_Storage *p_ecc_data = (ECC_RPMB_Key_Storage *)data;
+        int crc_result = verify_ecc_key_crc(p_ecc_data);
+        if (crc_result != 0) {
+            EMSG("ECC %s CRC check failed! key_id=0x%08X, stored_crc=0x%08X",
+                 cache_name, target_key_id, p_ecc_data->crc32_value);
+            res = TEE_ERROR_CORRUPT_OBJECT;
+            goto exit;
+        }
+        DMSG("ECC %s CRC check success! key_id=0x%08X, crc=0x%08X",
+             cache_name, target_key_id, p_ecc_data->crc32_value);
+
+        // 7.3 µŗĘĶ┤ØECCµĢ░µŹ«Õł░ĶŠōÕć║ń╝ōÕå▓Õī║’╝łÕÉ½CRC’╝ē
+        TEE_MemMove(params[1].memref.buffer, data, read_bytes);
+        params[1].memref.size = read_bytes;
+        
+        // 7.4 ÕÉīµŁźECCÕ»åķÆźÕł░õĖōÕ▒×Õģ©Õ▒Ćń╝ōÕŁś
+        memset((void*)ecc_cache_node, 0, sizeof(ECC_RPMB_Key_Storage));
+        TEE_MemMove((void*)ecc_cache_node, data, sizeof(ECC_RPMB_Key_Storage));
+        
+        // 7.5 Õ╝║ÕłČń╝ōÕŁśÕłĘÕåÖ’╝īńĪ«õ┐ØµĢ░µŹ«ÕÉīµŁź
+        TEE_CacheClean((void*)ecc_cache_node, sizeof(ECC_RPMB_Key_Storage));
+
+        
+        // 7.6 µēōÕŹ░ECCń╝ōÕŁśõ┐Īµü»
+        IMSG("=====================================================");
+        IMSG("[ECC CACHE(%s)] Sync success, key_id=0x%08X", cache_name, target_key_id);
+        IMSG("[ECC CACHE] crc32_value       = 0x%08X", ecc_cache_node->crc32_value);
+        IMSG("[ECC CACHE] Read data len     = %" PRIu32 " Bytes", read_bytes);
+        IMSG("[ECC CACHE] Cache size        = %zu Bytes", sizeof(ECC_RPMB_Key_Storage));
+        IMSG("=====================================================\n");
+    } 
+    // ---------- ķĆÜńö©Õ»åķÆźÕłåµö»  ----------
+    else {
+        // µĀĪķ¬īķĆÜńö©Õ»åķÆźµĢ░µŹ«ķĢ┐Õ║”
+        if (read_bytes != sizeof(RPMB_Key_Storage)) {
+            EMSG("Common key data size mismatch! expect %zu, got %" PRIu32, 
+                 sizeof(RPMB_Key_Storage), read_bytes);
+            res = TEE_ERROR_CORRUPT_OBJECT;
+            goto exit;
+        }
+
+        // µĀĖÕ┐ā’╝ÜķĆÜńö©Õ»åķÆźCRCµĀĪķ¬ī
+        RPMB_Key_Storage *p_common_data = (RPMB_Key_Storage *)data;
+        int crc_result = verify_rpmb_key_crc(p_common_data);
+        
+        if (crc_result != 0) {
+            EMSG("Common key CRC check failed! key_id=0x%08X, stored_crc=0x%08X",
+                 target_key_id, p_common_data->crc32_value);
+            res = TEE_ERROR_CORRUPT_OBJECT;
+            goto exit;
+        }
+        DMSG("Common key CRC check success! key_id=0x%08X, crc=0x%08X",
+             target_key_id, p_common_data->crc32_value);
+        
+        // µŗĘĶ┤ØķĆÜńö©Õ»åķÆźµĢ░µŹ«Õł░ĶŠōÕć║ń╝ōÕå▓Õī║
+        TEE_MemMove(params[1].memref.buffer, data, read_bytes);
+        params[1].memref.size = read_bytes;
+        
+        /* ÕÉīµŁźķĆÜńö©Õ»åķÆźÕł░Õģ©Õ▒Ćń╝ōÕŁś */
+        int cache_idx = rpmb_cache_alloc_or_find_idx(target_key_id);
+        if (cache_idx >= 0) {
+            
+            RPMB_Key_Storage *cache_node = &g_rpmb_key_cache[cache_idx]; 
+            size_t copy_len = (read_bytes > sizeof(RPMB_Key_Storage)) ? sizeof(RPMB_Key_Storage) : read_bytes;
+            
+            // µŗĘĶ┤ØÕ«īµĢ┤µĢ░µŹ«’╝łÕīģÕÉ½CRC32ÕŁŚµ«Ą’╝ē
+            TEE_MemMove(cache_node, data, copy_len);
+            // µĖģķøČµ£¬Ķ”åńø¢Õī║Õ¤¤
+            if (copy_len < sizeof(RPMB_Key_Storage)) {
+                memset((uint8_t*)cache_node + copy_len, 0x00, sizeof(RPMB_Key_Storage) - copy_len);
+            }
+            // ĶĪźÕģ©Õģ│ķö«ÕŁŚµ«Ą
+            cache_node->rpmb_key_id = target_key_id;
+            cache_node->is_valid = 1;
+
+            // Õ╝║ÕłČń╝ōÕŁśÕłĘÕåÖ
+            TEE_CacheClean((void*)cache_node, sizeof(RPMB_Key_Storage));
+            TEE_CacheClean((void*)g_rpmb_key_cache, sizeof(g_rpmb_key_cache));
+            
+            // µēōÕŹ░ń╝ōÕŁśõ┐Īµü»’╝łÕÉ½CRC’╝ē
+            IMSG("=====================================================");
+            IMSG("[RPMB CACHE] Sync success, cache_idx = %d", cache_idx);
+            IMSG("[RPMB CACHE] rpmb_key_id       = 0x%08X", cache_node->rpmb_key_id);
+            IMSG("[RPMB CACHE] crc32_value       = 0x%08X", cache_node->crc32_value);
+            IMSG("[RPMB CACHE] is_valid          = %d", cache_node->is_valid);
+            IMSG("[RPMB CACHE] Read data len     = %" PRIu32 " Bytes", read_bytes);
+            IMSG("[RPMB CACHE] Cache node size   = %zu Bytes", sizeof(RPMB_Key_Storage));
+            IMSG("-----------------------------------------------------");
+
+            // µēōÕŹ░key_len
+            IMSG("[RPMB CACHE] Key Length Table (GROUP[IDX] -> LEN):");
+            for (int g = 0; g < KEY_GROUP_COUNT; g++) {
+                for (int k = 0; k < KEY_PER_GROUP; k++) {
+                    IMSG("  GROUP[%d] KEY[%d] len = %u Bytes", g, k, cache_node->key_len[g][k]);
+                }
+            }
+            IMSG("-----------------------------------------------------");
+
+            // µēōÕŹ░key_data
+            IMSG("[RPMB CACHE] Key Data Table (GROUP[IDX] -> HEX DATA):");
+            IMSG("=====================================================\n");
+        } else {
+            EMSG("RPMB cache full! can't sync key_id=0x%08X", target_key_id);
+        }
+    }
+
+exit:
+    /* ń╗¤õĖĆĶĄäµ║ÉķćŖµöŠ */
+    if (object) {
+        TEE_CloseObject(object);
+    }
+    if (obj_id) {
+        TEE_Free(obj_id);
+    }
+    if (data) {
+        TEE_Free(data);
+    }
+
+    return res;
+}
