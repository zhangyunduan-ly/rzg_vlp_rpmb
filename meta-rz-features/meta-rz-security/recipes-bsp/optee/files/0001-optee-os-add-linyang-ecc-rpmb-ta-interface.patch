+/***************************************************************************/
+/*!
+   \file
+
+   \brief       Elliptic Curve Arithmetic, sliced variants.
+
+   $Rev: 2750 $
+ */
+/***************************************************************************/
+/***************************************************************************
+ * 1. INCLUDES                                                             *
+ ***************************************************************************/
+
+#include "eccarith_s1.h"
+#include "_ecc.h"
+#include "ecc_cfg.h"
+#include "ecc_curves32.h"
+
+/***************************************************************************
+ * 2. DEFINES                                                              *
+ ***************************************************************************/
+
+ /*lint -esym(750,EscEccArithS1_STATE_JAC*) Depending on the configuration, some state symbols may not be used */
+
+/** States for the Modular inversion */
+#define EscEccArithS1_STATE_MODULARINVERT_NEXT_LOOP       10
+#define EscEccArithS1_STATE_MODULARINVERT_FINISH          11
+
+/** States for the point conversion */
+#define EscEccArithS1_STATE_TOAFFINE_MODINVERT            20
+#define EscEccArithS1_STATE_TOAFFINE_MULTIPY              21
+#define EscEccArithS1_STATE_TOAFFINE_FINISH               22
+
+/** States for the point multiplication (Double-Add and SLiding window) */
+#define EscEccArithS1_STATE_JACMULTIPLY_PROCESS_NEXT_WORD 30
+#define EscEccArithS1_STATE_JACMULTIPLY_DOUBLE            31
+#define EscEccArithS1_STATE_JACMULTIPLY_ADD               32
+#define EscEccArithS1_STATE_JACMULTIPLY_FINISH            33
+/** States for the point multiplication (only used for sliding window) */
+#define EscEccArithS1_STATE_JACMULTIPLY_PRECOMPLOOP       40
+#define EscEccArithS1_STATE_JACMULTIPLY_NEXTWINDOW        41
+#define EscEccArithS1_STATE_JACMULTIPLY_DOUBLE_ADD        42
+
+/** States for the dual multiply (Shamir's trick) */
+#define EscEccArithS1_STATE_JACDUALMUL_COMPUTE_QP         50
+#define EscEccArithS1_STATE_JACDUALMUL_PREPARE_LOOP       51
+#define EscEccArithS1_STATE_JACDUALMUL_NEXT_LOOP          52
+#define EscEccArithS1_STATE_JACDUALMUL_DOUBLE             53
+
+/***************************************************************************
+ * 3. DEFINITIONS                                                          *
+ ***************************************************************************/
+
+/***************************************************************************
+ * 4. IMPLEMENTATION OF FUNCTIONS                                          *
+ ***************************************************************************/
+
+/**
+ * Invert a field element with modulus p applying the Binary Extended Euclidean algorithm.
+ * C.f Hankerson, et. al, "Guide to Elliptic Curve Cryptography", Alg. 2.22
+ */
+void
+EscEccArithS1_Fe_ModularInvertInit(
+    EscEccArithS1_Fe_ModularInvertContext* ctx,
+    EscEcc_FieldElementT* c,
+    const EscEcc_FieldElementT* a,
+    const EscEcc_FieldT* fGP,
+    const Esc_UINT8 lenWords )
+{
+    /* Set context elements */
+    ctx->c = c;
+    ctx->fGP = fGP;
+    ctx->lenWords = lenWords;
+
+    EscEccFe_Assign( &ctx->u, a, ctx->lenWords );
+    EscEccFe_Assign( &ctx->v, &fGP->prime_p, ctx->lenWords );
+    EscEccFe_SetZero( &ctx->x2 );
+    EscEccFe_SetOne( &ctx->x1 );
+
+    if ( (EscEccFe_IsOne( &ctx->u, ctx->lenWords ) == TRUE ) || (EscEccFe_IsOne( &ctx->v, ctx->lenWords ) == TRUE ) )
+    {
+        ctx->state = EscEccArithS1_STATE_MODULARINVERT_FINISH;
+    }
+    else
+    {
+        ctx->state = EscEccArithS1_STATE_MODULARINVERT_NEXT_LOOP;
+    }
+}
+
+Esc_ERROR
+EscEccArithS1_Fe_ModularInvertRun(
+    EscEccArithS1_Fe_ModularInvertContext* ctx )
+{
+    Esc_ERROR returnCode = Esc_AGAIN;
+    Esc_UINT32 carry;
+
+    switch( ctx->state )
+    {
+        case EscEccArithS1_STATE_MODULARINVERT_NEXT_LOOP:
+            while ( (ctx->u.word[0] & 1U) == 0U )
+            {
+                EscEccFe_ShiftRight( &ctx->u, ctx->lenWords );
+                if ( (ctx->x1.word[0] & 1U) == 0U )
+                {
+                    EscEccFe_ShiftRight( &ctx->x1, ctx->lenWords );
+                }
+                else
+                {
+                    EscEccWd_AddCLoop( &carry, ctx->x1.word, ctx->x1.word, ctx->fGP->prime_p.word, ctx->lenWords );
+                    EscEccFe_ShiftRight( &ctx->x1, ctx->lenWords );
+                }
+            }
+
+            while ( (ctx->v.word[0] & 1U) == 0U )
+            {
+                EscEccFe_ShiftRight( &ctx->v, ctx->lenWords );
+                if ( (ctx->x2.word[0] & 1U) == 0U )
+                {
+                    EscEccFe_ShiftRight( &ctx->x2, ctx->lenWords );
+                }
+                else
+                {
+                    EscEccWd_AddCLoop( &carry, ctx->x2.word, ctx->x2.word, ctx->fGP->prime_p.word, ctx->lenWords );
+                    EscEccFe_ShiftRight( &ctx->x2, ctx->lenWords );
+                }
+            }
+
+            if (EscEccFe_AbsoluteCompare( &ctx->u, &ctx->v, ctx->lenWords ) > -1)
+            {
+                EscEccWd_SubBLoop( ctx->u.word, &carry, ctx->u.word, ctx->v.word, ctx->lenWords );
+                EscEccFe_ModularSub( &ctx->x1, &ctx->x1, &ctx->x2, ctx->fGP, ctx->lenWords );
+            }
+            else
+            {
+                EscEccWd_SubBLoop( ctx->v.word, &carry, ctx->v.word, ctx->u.word, ctx->lenWords );
+                EscEccFe_ModularSub( &ctx->x2, &ctx->x2, &ctx->x1, ctx->fGP, ctx->lenWords );
+            }
+
+            if ( (EscEccFe_IsOne( &ctx->u, ctx->lenWords ) == TRUE) || (EscEccFe_IsOne( &ctx->v, ctx->lenWords ) == TRUE) )
+            {
+                ctx->state = EscEccArithS1_STATE_MODULARINVERT_FINISH;
+            }
+
+            break;
+        case EscEccArithS1_STATE_MODULARINVERT_FINISH:
+            if ( EscEccFe_IsOne( &ctx->u, ctx->lenWords ) )
+            {
+                EscEccFe_Assign( ctx->c, &ctx->x1, ctx->lenWords );
+            }
+            else
+            {
+                EscEccFe_Assign( ctx->c, &ctx->x2, ctx->lenWords );
+            }
+
+            returnCode = Esc_NO_ERROR;
+
+            break;
+        default:
+            returnCode = Esc_UNEXPECTED_FUNCTION_CALL;
+            break;
+    }
+
+    return returnCode;
+}
+
+/****************************************
+ * convert a point into an affine point *
+ ****************************************/
+void
+EscEccArithS1_Pt_ToAffineInit(
+    EscEccArithS1_Pt_ToAffineContext* ctx,
+    EscEcc_PointT* pA,
+    const EscEcc_PointT* pJ,
+    const EscEcc_CurveT* curve )
+{
+    Esc_ASSERT( pJ->type == C_PT_JACOBIAN );
+
+    if ( EscEccPt_IsInfinity( pJ, curve ) )
+    {
+        /* set pA type */
+        pA->type = C_PT_AFFINE;
+        /* pA = (0) */
+        EscEccPt_SetInfinity( pA );
+
+        ctx->state = EscEccArithS1_STATE_TOAFFINE_FINISH;
+    }
+    else
+    {
+        ctx->pA = pA;
+        ctx->pJ = pJ;
+        ctx->curve = curve;
+
+        EscEccArithS1_Fe_ModularInvertInit( &ctx->modInvertCtx, &ctx->fe_z_inv1_3, &ctx->pJ->z, &ctx->curve->ecc_field_params, ctx->curve->maxWords );
+
+        ctx->state = EscEccArithS1_STATE_TOAFFINE_MODINVERT;
+    }
+}
+
+Esc_ERROR
+EscEccArithS1_Pt_ToAffineRun(
+    EscEccArithS1_Pt_ToAffineContext* ctx )
+{
+    Esc_ERROR returnCode = Esc_AGAIN;
+
+    switch( ctx->state )
+    {
+        case EscEccArithS1_STATE_TOAFFINE_MODINVERT:
+
+            /* pJ(1/z) : 1I */
+            returnCode = EscEccArithS1_Fe_ModularInvertRun( &ctx->modInvertCtx );
+
+            if ( returnCode == Esc_NO_ERROR )
+            {
+                /* Finish computation, next state */
+                ctx->state = EscEccArithS1_STATE_TOAFFINE_MULTIPY;
+                returnCode = Esc_AGAIN;
+            }
+
+            break;
+        case EscEccArithS1_STATE_TOAFFINE_MULTIPY:
+            /* pJ(1/z▓) : 1S */
+            EscEccFe_MultiplyModP( &ctx->fe_z_inv2, &ctx->fe_z_inv1_3, &ctx->fe_z_inv1_3, ctx->curve );
+            /* pJ(1/z│) : 1M */
+            EscEccFe_MultiplyModP( &ctx->fe_z_inv1_3, &ctx->fe_z_inv1_3, &ctx->fe_z_inv2, ctx->curve );
+            /* pA(x) = pJ(x/z▓) : 1M */
+            EscEccFe_MultiplyModP( &ctx->pA->x, &ctx->pJ->x, &ctx->fe_z_inv2, ctx->curve );
+            /* pA(y) = pJ(y/z│) : 1M */
+            EscEccFe_MultiplyModP( &ctx->pA->y, &ctx->pJ->y, &ctx->fe_z_inv1_3, ctx->curve );
+            /* pA(z) = 0 */
+            EscEccFe_SetZero( &ctx->pA->z );
+            /* set pA type */
+            ctx->pA->type = C_PT_AFFINE;
+
+            /* Finish */
+            returnCode = Esc_NO_ERROR;
+
+            break;
+        case EscEccArithS1_STATE_TOAFFINE_FINISH:
+            returnCode = Esc_NO_ERROR;
+
+            break;
+        default:
+            returnCode = Esc_UNEXPECTED_FUNCTION_CALL;
+            break;
+    }
+
+    return returnCode;
+
+}
+
+
+/***********************************************
+ * scalar multiplication of unknown pA1 with k *
+ ***********************************************/
+#if EscEcc_USE_SLIDING_WINDOW == 1
+void EscEccArithS1_Pt_JacobianMultiplyBinaryInit(
+    EscEccArithS1_Pt_JacobianMultiplyBinaryContext *ctx,
+    EscEcc_PointT* pJ,
+    const EscEcc_FieldElementT* k,
+    const EscEcc_PointT* pA1,
+    const EscEcc_CurveT* curve )
+{
+    Esc_ASSERT( pA1->type == C_PT_AFFINE );
+
+    /* check P = (0) */
+    if ( EscEccPt_IsZero( pA1, curve ) )
+    {
+        /* Finish, pJ = (0) */
+        pJ->type = C_PT_JACOBIAN;
+        EscEccPt_SetInfinity( pJ );
+
+        ctx->state = EscEccArithS1_STATE_JACMULTIPLY_FINISH;
+    }
+    else
+    {
+        ctx->precompArray[0].type = C_PT_JACOBIAN;
+        EscEccFe_Assign( &ctx->precompArray[0].x, &pA1->x, curve->maxWords );
+        EscEccFe_Assign( &ctx->precompArray[0].y, &pA1->y, curve->maxWords );
+        EscEccFe_SetOne( &ctx->precompArray[0].z );
+
+        /* pJ = (0) */
+        pJ->type = C_PT_JACOBIAN;
+        EscEccPt_SetInfinity( pJ );
+
+        /* Compute 2 x pJ, use last element of precomp array as temporary location */
+        EscEccPt_JacobianDouble( &ctx->precompArray[EscEcc_NUM_WINDOW_ELEMENTS - 1], &ctx->precompArray[0], curve );
+
+        /* Use the bitIndex variable as a temp loop counter for the pre-computation */
+        ctx->bitIndex = 1;
+        ctx->pJ = pJ;
+        ctx->k = k;
+        ctx->curve = curve;
+        ctx->state = EscEccArithS1_STATE_JACMULTIPLY_PRECOMPLOOP;
+    }
+}
+
+Esc_ERROR EscEccArithS1_Pt_JacobianMultiplyBinaryRun(
+    EscEccArithS1_Pt_JacobianMultiplyBinaryContext *ctx )
+{
+    Esc_ERROR returnCode = Esc_AGAIN;
+
+    switch( ctx->state )
+    {
+        case EscEccArithS1_STATE_JACMULTIPLY_PRECOMPLOOP:
+            /* precomputation - i < ((2^k_m) / 2) + 1 */
+            if ( ctx->bitIndex < (Esc_SINT16)EscEcc_NUM_WINDOW_ELEMENTS )
+            {
+                EscEccPt_JacobianAdd( &ctx->precompArray[ctx->bitIndex], &ctx->precompArray[ctx->bitIndex - 1], &ctx->precompArray[EscEcc_NUM_WINDOW_ELEMENTS - 1], ctx->curve );
+                ctx->bitIndex++;
+            }
+            else
+            {
+                ctx->bitIndex = (Esc_SINT16)( (Esc_SINT16)ctx->curve->maxWords * (Esc_SINT16)EscEcc_WORD_BITS ) - 1;
+                /* Next state, actual computation */
+                ctx->state = EscEccArithS1_STATE_JACMULTIPLY_NEXTWINDOW;
+            }
+            break;
+        case EscEccArithS1_STATE_JACMULTIPLY_NEXTWINDOW:
+            if ( ctx->bitIndex >= 0 )
+            {
+                /* if Exponent = 0 double only */
+                if (EscEccFe_isBitSet( ctx->k, ctx->bitIndex ) == FALSE)
+                {
+                    EscEccPt_JacobianDouble( ctx->pJ, ctx->pJ, ctx->curve );
+                    ctx->bitIndex--;
+                }
+                else
+                {
+                    /* Build a new window */
+                    Esc_UINT16 n;
+                    Esc_SINT16 j;
+
+                    ctx->exponent = 0U;
+                    n = (Esc_UINT16)(EscEcc_WINDOW_SIZE - 1U);
+                    ctx->windowsize = (Esc_SINT16)EscEcc_WINDOW_SIZE;
+                    for (j = ctx->bitIndex; ( j > (ctx->bitIndex - (Esc_SINT16)EscEcc_WINDOW_SIZE) ) && (j >= 0); j--)
+                    {
+                        /* build temporary exponent */
+                        if (EscEccFe_isBitSet( ctx->k, j ) == TRUE)
+                        {
+                            ctx->exponent += (Esc_UINT16)( ( (Esc_UINT16)1U ) << n );
+                        }
+                        n--;
+                    }
+                    ctx->bitIndex -= (Esc_SINT16)EscEcc_WINDOW_SIZE;
+                    /* make window odd and adjust bitIndex, reduce window size */
+                    while ( (ctx->exponent % 2U) == 0U )
+                    {
+                        ctx->exponent = (Esc_UINT16)(ctx->exponent / 2U);
+                        ctx->bitIndex++;
+                        ctx->windowsize--;
+                    }
+                    /* Assert that exponent/2 is within bounds of precompArray */
+                    Esc_ASSERT( (ctx->exponent / 2U) < EscEcc_NUM_WINDOW_ELEMENTS );
+                    ctx->bitIndexWindow = 0;
+                    ctx->state = EscEccArithS1_STATE_JACMULTIPLY_DOUBLE_ADD;
+                }
+            }
+            else
+            {
+                /* Computation is finished */
+                returnCode = Esc_NO_ERROR;
+            }
+
+            break;
+        case EscEccArithS1_STATE_JACMULTIPLY_DOUBLE_ADD:
+            if ( ctx->bitIndexWindow < ctx->windowsize )
+            {
+                /* Double */
+                EscEccPt_JacobianDouble( ctx->pJ, ctx->pJ, ctx->curve );
+                ctx->bitIndexWindow++;
+            }
+            else
+            {
+                /* Add */
+                EscEccPt_JacobianAdd( ctx->pJ, ctx->pJ, &ctx->precompArray[ctx->exponent / 2U], ctx->curve );
+                ctx->state = EscEccArithS1_STATE_JACMULTIPLY_NEXTWINDOW;
+            }
+
+            break;
+        case EscEccArithS1_STATE_JACMULTIPLY_FINISH:
+            /* Finish, result point is already set */ 
+            returnCode = Esc_NO_ERROR;
+
+            break;
+        default:
+            returnCode = Esc_UNEXPECTED_FUNCTION_CALL;
+            break;
+    }
+
+    return returnCode;
+}
+#else
+void EscEccArithS1_Pt_JacobianMultiplyBinaryInit(
+    EscEccArithS1_Pt_JacobianMultiplyBinaryContext *ctx,
+    EscEcc_PointT* pJ,
+    const EscEcc_FieldElementT* k,
+    const EscEcc_PointT* pA1,
+    const EscEcc_CurveT* curve )
+{
+    Esc_ASSERT( pA1->type == C_PT_AFFINE );
+
+    /* check P = (0) */
+    if ( EscEccPt_IsZero( pA1, curve ) )
+    {
+        /* Finish, pJ = (0) */
+        pJ->type = C_PT_JACOBIAN;
+        EscEccPt_SetInfinity( pJ );
+
+        ctx->state = EscEccArithS1_STATE_JACMULTIPLY_FINISH;
+    }
+    else
+    {
+        /* Set temporary point */
+        ctx->pTemp.type = C_PT_JACOBIAN;
+        EscEccFe_Assign( &ctx->pTemp.x, &pA1->x, curve->maxWords );
+        EscEccFe_Assign( &ctx->pTemp.y, &pA1->y, curve->maxWords );
+        EscEccFe_SetOne( &ctx->pTemp.z );
+
+        /* pJ = (0) */
+        pJ->type = C_PT_JACOBIAN;
+        EscEccPt_SetInfinity( pJ );
+
+        /* Copy pointers to the context */
+        ctx->pJ = pJ;
+        ctx->k = k;
+        ctx->curve = curve;
+
+        ctx->wordIndex = (Esc_SINT16)ctx->curve->maxWords - 1;
+
+        /* Next state */
+        ctx->state = EscEccArithS1_STATE_JACMULTIPLY_PROCESS_NEXT_WORD;
+    }
+}
+
+Esc_ERROR EscEccArithS1_Pt_JacobianMultiplyBinaryRun(
+    EscEccArithS1_Pt_JacobianMultiplyBinaryContext *ctx )
+{
+    Esc_ERROR returnCode = Esc_AGAIN;
+
+    switch( ctx->state )
+    {
+        case EscEccArithS1_STATE_JACMULTIPLY_PROCESS_NEXT_WORD:
+            ctx->bitIndex = 0U;
+            ctx->tempWord = ctx->k->word[ctx->wordIndex];
+
+            if ( ctx->wordIndex >= 0 )
+            {
+                /* process next bit */
+                ctx->state = EscEccArithS1_STATE_JACMULTIPLY_DOUBLE;
+            }
+            else
+            {
+                /* Finish all words. Result is stored in pJ */
+                returnCode = Esc_NO_ERROR;
+            }
+
+            break;
+        case EscEccArithS1_STATE_JACMULTIPLY_DOUBLE:
+            /* Double */
+            EscEccPt_JacobianDouble( ctx->pJ, ctx->pJ, ctx->curve );
+
+            /* next state */
+            ctx->state = EscEccArithS1_STATE_JACMULTIPLY_ADD;
+
+            break;
+        case EscEccArithS1_STATE_JACMULTIPLY_ADD:
+
+            if ( (ctx->tempWord & 0x80000000U) != 0U )          /* highest bit set */
+            {
+                /* Add */
+                EscEccPt_JacobianAdd( ctx->pJ, ctx->pJ, &ctx->pTemp, ctx->curve );
+            }
+            ctx->tempWord <<= 1;
+
+            if ( ctx->bitIndex < (EscEcc_WORD_BITS-1U) )
+            {
+                /* process next bit */
+                ctx->bitIndex++;
+                ctx->state = EscEccArithS1_STATE_JACMULTIPLY_DOUBLE;
+            }
+            else
+            {
+                /* process next word */
+                ctx->wordIndex--;
+                ctx->state = EscEccArithS1_STATE_JACMULTIPLY_PROCESS_NEXT_WORD;
+            }
+
+            break;
+        case EscEccArithS1_STATE_JACMULTIPLY_FINISH:
+            /* Finish, result point is already set */ 
+            returnCode = Esc_NO_ERROR;
+
+            break;
+        default:
+            returnCode = Esc_UNEXPECTED_FUNCTION_CALL;
+            break;
+    }
+
+    return returnCode;
+}
+
+#endif /* EscEcc_USE_SLIDING_WINDOW */
+
+
+/*************************************************
+ * calculate k0 * G + k1 * Q with Shamir's trick *
+ *************************************************/
+#if EscEcc_ENABLE_SHAMIRS_TRICK == 1
+void
+EscEccArithS1_Pt_JacDualMulAddBinInit(
+    EscEccArithS1_Pt_JacDualMulAddBinContext *ctx,
+    EscEcc_PointT* pJ,
+    const EscEcc_FieldElementT* k0,
+    const EscEcc_PointT* pA0,
+    const EscEcc_FieldElementT* k1,
+    const EscEcc_PointT* pA1,
+    const EscEcc_CurveT* curve )
+{
+    const Esc_UINT8 maxWords = curve->maxWords;
+
+    Esc_ASSERT( pA0->type == C_PT_AFFINE );
+    Esc_ASSERT( pA1->type == C_PT_AFFINE );
+
+    ctx->pPA0.type = C_PT_JACOBIAN;
+    /* pPAx = pAx */
+    EscEccFe_Assign( &ctx->pPA0.x, &pA0->x, maxWords );
+    /* pPAy = pAy */
+    EscEccFe_Assign( &ctx->pPA0.y, &pA0->y, maxWords );
+    /* pPAz = 1 */
+    EscEccFe_SetOne( &ctx->pPA0.z );
+
+    ctx->pPA1.type = C_PT_JACOBIAN;
+    /* pPAx = pAx */
+    EscEccFe_Assign( &ctx->pPA1.x, &pA1->x, maxWords );
+    /* pPAy = pAy */
+    EscEccFe_Assign( &ctx->pPA1.y, &pA1->y, maxWords );
+    /* pPAz = 1 */
+    EscEccFe_SetOne( &ctx->pPA1.z );
+
+    /* set pJ type */
+    pJ->type = C_PT_JACOBIAN;
+    EscEccPt_SetInfinity( pJ );
+
+    ctx->pJ = pJ;
+    ctx->k0 = k0;
+    ctx->k1 = k1;
+    ctx->curve = curve;
+
+    ctx->state = EscEccArithS1_STATE_JACDUALMUL_COMPUTE_QP;
+}
+
+Esc_ERROR
+EscEccArithS1_Pt_JacDualMulAddBinRun(
+    EscEccArithS1_Pt_JacDualMulAddBinContext *ctx )
+{
+    Esc_ERROR returnCode = Esc_AGAIN;
+
+    switch( ctx->state )
+    {
+        case EscEccArithS1_STATE_JACDUALMUL_COMPUTE_QP:
+            /* precompute Q + G */
+            EscEccPt_JacobianAdd( &ctx->pQPlusG, &ctx->pPA0, &ctx->pPA1, ctx->curve );
+            ctx->state = EscEccArithS1_STATE_JACDUALMUL_PREPARE_LOOP;
+
+            break;
+        case EscEccArithS1_STATE_JACDUALMUL_PREPARE_LOOP:
+            ctx->bitIndex = ( (Esc_SINT16)ctx->curve->maxWords * (Esc_SINT16)EscEcc_WORD_BITS ) - 1;
+            /* skip common leading zeros of k0 and k1 */
+            while ( !( (EscEccFe_isBitSet( ctx->k0, ctx->bitIndex ) == TRUE)
+                    || (EscEccFe_isBitSet( ctx->k1, ctx->bitIndex ) == TRUE) ) )
+            {
+                ctx->bitIndex--;
+            }
+            ctx->state = EscEccArithS1_STATE_JACDUALMUL_NEXT_LOOP;
+
+            break;
+        case EscEccArithS1_STATE_JACDUALMUL_NEXT_LOOP:
+            if ( EscEccFe_isBitSet( ctx->k0, ctx->bitIndex ) )
+            {
+                if ( EscEccFe_isBitSet( ctx->k1, ctx->bitIndex ) )
+                {
+                    EscEccPt_JacobianAdd( ctx->pJ, ctx->pJ, &ctx->pQPlusG, ctx->curve );
+                }
+                else
+                {
+                    EscEccPt_JacobianAdd( ctx->pJ,ctx-> pJ, &ctx->pPA0, ctx->curve );
+                }
+            }
+            else
+            {
+                if ( EscEccFe_isBitSet( ctx->k1, ctx->bitIndex ) )
+                {
+                    EscEccPt_JacobianAdd( ctx->pJ, ctx->pJ, &ctx->pPA1, ctx->curve );
+                }
+            }
+
+            ctx->bitIndex--;
+            if (ctx->bitIndex < 0)
+            {
+                /* Finish */
+                returnCode = Esc_NO_ERROR;
+            }
+            else
+            {
+                ctx->state = EscEccArithS1_STATE_JACDUALMUL_DOUBLE;
+            }
+
+            break;
+        case EscEccArithS1_STATE_JACDUALMUL_DOUBLE:
+            EscEccPt_JacobianDouble( ctx->pJ, ctx->pJ, ctx->curve );
+            ctx->state = EscEccArithS1_STATE_JACDUALMUL_NEXT_LOOP;
+
+            break;
+        default:
+            returnCode = Esc_UNEXPECTED_FUNCTION_CALL;
+            break;
+    }
+
+    return returnCode;
+}
+#endif /* EscEcc_ENABLE_SHAMIRS_TRICK */
+
