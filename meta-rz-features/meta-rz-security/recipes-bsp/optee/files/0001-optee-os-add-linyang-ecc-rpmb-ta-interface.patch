+void SERVp_hash_sha512(const unsigned char *input, size_t ilen, unsigned char output[64], int is384, B_FUN_V SHAquitCondition)
+{
+#ifdef CFGSHA512_hardWareEnable
+  return; //µÜéõĖŹµö»µīüńĪ¼õ╗ČSHA512
