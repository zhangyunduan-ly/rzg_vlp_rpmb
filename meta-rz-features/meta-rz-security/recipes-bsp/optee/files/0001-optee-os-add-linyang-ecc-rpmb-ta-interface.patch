+
+TEE_Result ecdsa_sec_keypair_generate(uint32_t types, TEE_Param params[TEE_NUM_PARAMS]) {
+    // 4ÕÅéµĢ░ÕłåķģŹ’╝Ü
+    // params[0]’╝ÜĶŠōÕģź’╝īÕŖĀÕ»åÕźŚõ╗ČnSuite
+    // params[1]’╝ÜĶŠōÕģź’╝īAESÕŖĀÕ»åÕÅéµĢ░’╝łwrapped_key + IV’╝īń╗ōµ×äõĮō’╝ē
+    // params[2]’╝ÜĶŠōÕć║’╝īÕŖĀÕ»åÕÉÄńÜäń¦üķÆź+Õģ¼ķÆź’╝łń¦üķÆźÕ£©ÕēŹ’╝īÕģ¼ķÆźÕ£©ÕÉÄ’╝ē
+    // params[3]’╝ÜķóäńĢÖ
+    uint8_t *nSuite_buf = (uint8_t *)params[0].memref.buffer;
+    uint8_t nSuite;
+    aes_decrypt_params_t *aes_params = (aes_decrypt_params_t *)params[1].memref.buffer;
+    uint8_t *encrypted_output = (uint8_t *)params[2].memref.buffer;
+    uint32_t output_size = params[2].memref.size;
+
+    sce_aes_handle_t pri_aes_handle = {0};  // ń¦üķÆźÕŖĀÕ»åõĖōńö© AES ÕÅźµ¤ä
+    TEE_Result tee_res;
+    uint8_t t_key_len;
+    bool is_aes128 = false;
+    uint8_t plain_pri_key[ECC384_PRIKEY_LEN] = {0};
+    uint8_t plain_pub_key[2 * ECC384_PRIKEY_LEN] = {0};
+    int i = 0;
+
+    // AES TAńøĖÕģ│ÕÅśķćÅ
+    static const TEE_UUID aes_uuid = PTA_SCE_AES_UUID;
+    TEE_TASessionHandle aes_sess = TEE_HANDLE_NULL;
+    uint32_t ta_ret_orig = 0;
+
+    // 1. µĀĪķ¬īÕÅéµĢ░ń▒╗Õ×ŗ’╝ł3 ĶŠōÕģź + 1 ĶŠōÕć║’╝īÕģ▒ 4 ÕÅéµĢ░’╝ē
+    if (types != TEE_PARAM_TYPES(TEE_PARAM_TYPE_MEMREF_INPUT,  // nSuite
+                                 TEE_PARAM_TYPE_MEMREF_INPUT,  // AES ÕŖĀÕ»åÕÅéµĢ░’╝łń╗ōµ×äõĮō’╝ē
+                                 TEE_PARAM_TYPE_MEMREF_OUTPUT, // ÕŖĀÕ»åÕ»åķÆźÕ»╣ĶŠōÕć║
+                                 TEE_PARAM_TYPE_NONE)) {       // ķóäńĢÖÕÅéµĢ░
+        DMSG("Invalid parameter types (expected 4 params)");
+        return TEE_ERROR_BAD_PARAMETERS;
+    }
+    DMSG("\r\nReady to generate key pair step555");
+
+    // 2. µÅÉÕÅ¢Õ╣ČµĀĪķ¬ī nSuite
+    if (!nSuite_buf || params[0].memref.size != sizeof(uint8_t)) {
+        DMSG("Invalid nSuite parameter (size: %u, expected: %zu)",
+             params[0].memref.size, sizeof(uint8_t));
+        return TEE_ERROR_BAD_PARAMETERS;
+    }
+    nSuite = *nSuite_buf;
+
+    // 3. µĀĪķ¬ī AES ÕÅéµĢ░ń╗ōµ×äõĮō
+    if (!aes_params || params[1].memref.size != sizeof(aes_decrypt_params_t)) {
+        DMSG("Invalid AES params (size: %u, expected: %zu)",
+             params[1].memref.size, sizeof(aes_decrypt_params_t));
+        return TEE_ERROR_BAD_PARAMETERS;
+    }
+
+    DMSG("\r\nReady to generate key pair step666");
+
+    // 4. ńĪ«Õ«ÜÕ»åķÆźķĢ┐Õ║”ÕÆī AES ń▒╗Õ×ŗ
+    if (nSuite == 0 || nSuite == 1) {
+        t_key_len = ECC256_PRIKEY_LEN;
+        is_aes128 = true;
+    } else if (nSuite == 2) {
+        t_key_len = ECC384_PRIKEY_LEN;
+        is_aes128 = false;
+    } else {
+        DMSG("Unsupported suite: %d", nSuite);
+        return TEE_ERROR_BAD_PARAMETERS;
+    }
+    DMSG("\r\nReady to generate key pair step777");
+
+    // 5. µĀĪķ¬īĶŠōÕć║ń╝ōÕå▓Õī║Õż¦Õ░Å’╝łń¦üķÆź t_key_len + Õģ¼ķÆź 2*t_key_len’╝ē
+    uint32_t required_out_size = t_key_len + 2 * t_key_len;
+    if (!encrypted_output || output_size < required_out_size) {
+        DMSG("Output buffer too small (need: %u, got: %u)",
+             required_out_size, output_size);
+        return TEE_ERROR_SHORT_BUFFER;
+    }
+    DMSG("\r\nReady to generate key pair step888");
+
+    // 6. ńö¤µłÉµśÄµ¢ć ECC Õ»åķÆźÕ»╣
+    if (!Servp_ECC_GenKeyPair(plain_pri_key, plain_pub_key, t_key_len)) {
+        DMSG("Failed to generate ECC key pair");
+        return TEE_ERROR_GENERIC;
+    }
+    DMSG("\r\nGenerated plain_pri_key:");
+    for (i = 0; i < t_key_len; i++) {
+        DMSG("%2x", plain_pri_key[i]);
+    }
+    DMSG("\r\nGenerated plain_pub_key:");
+    // for (i = 0; i < 2 * t_key_len; i++) {
+    //     DMSG("%2x", plain_pub_key[i]);
+    // }
+    DMSG("\r\nReady to generate key pair step999");
+
+    // ÕģłÕ░åÕģ¼ķÆźÕåÖÕģźĶŠōÕć║ń╝ōÕå▓Õī║
+    memcpy(encrypted_output + t_key_len, plain_pub_key, 2 * t_key_len);
+
+    //-------------------------- ń¼¼õĖĆµŁź’╝Üńŗ¼ń½ŗÕŖĀÕ»åń¦üķÆź’╝łķĆÜĶ┐ćTAĶ░āńö©Õ«×ńÄ░’╝ē--------------------------
+    // µēōÕ╝ĆAES TAõ╝ÜĶ»Ø
+    tee_res = TEE_OpenTASession(&aes_uuid, TEE_TIMEOUT_INFINITE, 0, NULL, &aes_sess, &ta_ret_orig);
+    if (tee_res != TEE_SUCCESS) {
+        DMSG("Can't open session to AES PTA (0x%x)", tee_res);
+        return tee_res;
+    }
+
+    // 7. ÕłØÕ¦ŗÕī¢ń¦üķÆźÕŖĀÕ»åńÜä AES õĖŖõĖŗµ¢ć’╝łĶ░āńö©TAÕæĮõ╗ż’╝ē
+    TEE_Param pri_init_params[TEE_NUM_PARAMS] = {0};
+    uint32_t pri_init_types = TEE_PARAM_TYPES(TEE_PARAM_TYPE_MEMREF_INOUT,
+                                             TEE_PARAM_TYPE_MEMREF_INPUT,
+                                             TEE_PARAM_TYPE_NONE,
+                                             TEE_PARAM_TYPE_NONE);
+    pri_init_params[0].memref.buffer = &pri_aes_handle;
+    pri_init_params[0].memref.size = sizeof(sce_aes_handle_t);
+    pri_init_params[1].memref.buffer = &aes_params->wrapped_key;  // ÕżŹńö© AES ÕīģĶŻģÕ»åķÆź
+    pri_init_params[1].memref.size = sizeof(sce_aes_wrapped_key_t);
+    // pri_init_params[2].memref.buffer = aes_params->initial_vector; // ÕżŹńö©ÕłØÕ¦ŗ IV
+    // pri_init_params[2].memref.size = HW_SCE_AES_CBC_IV_BYTE_SIZE;
+
+    DMSG("\r\nReady to generate key pair stepAAA (pri init)");
+
+
+
+    DMSG("TEE side Param 0 size: %zu, sce_aes_handle_t size: %zu", 
+     pri_init_params[0].memref.size, sizeof(sce_aes_handle_t));
+DMSG("TEE side Param 1 size: %zu, sce_aes_wrapped_key_t size: %zu", 
+     pri_init_params[1].memref.size, sizeof(sce_aes_wrapped_key_t));
+DMSG("TEE side Param 2 size: %zu, HW_SCE_AES_CBC_IV_BYTE_SIZE: %zu", 
+     pri_init_params[2].memref.size, (size_t)HW_SCE_AES_CBC_IV_BYTE_SIZE);
+DMSG("aes_params->wrapped_key address: %p, aes_params->initial_vector address: %p",
+     &aes_params->wrapped_key, aes_params->initial_vector);
+
+    if (is_aes128) {
+        tee_res = TEE_InvokeTACommand(aes_sess, TEE_TIMEOUT_INFINITE,
+                                     PTA_CMD_AES128ECB_EncryptInit,
+                                     pri_init_types, pri_init_params, &ta_ret_orig);
+    } else {
+        tee_res = TEE_InvokeTACommand(aes_sess, TEE_TIMEOUT_INFINITE,
+                                     PTA_CMD_AES256ECB_EncryptInit,
+                                     pri_init_types, pri_init_params, &ta_ret_orig);
+    }
+    if (tee_res != TEE_SUCCESS) {
+        DMSG("Private key AES init failed (0x%x, TA ret: 0x%x)", tee_res, ta_ret_orig);
+        TEE_CloseTASession(aes_sess);
+        return tee_res;
+    }
+
+    // 8. ÕŖĀÕ»åń¦üķÆź’╝łĶŠōÕć║Õł░ encrypted_output ’╝ē
+    TEE_Param pri_update_params[TEE_NUM_PARAMS] = {0};
+    uint32_t pri_update_types = TEE_PARAM_TYPES(TEE_PARAM_TYPE_MEMREF_INOUT,
+                                               TEE_PARAM_TYPE_MEMREF_INPUT,
+                                               TEE_PARAM_TYPE_MEMREF_INOUT,
+                                               TEE_PARAM_TYPE_NONE);
+    pri_update_params[0].memref.buffer = &pri_aes_handle;
+    pri_update_params[0].memref.size = sizeof(sce_aes_handle_t);
+    pri_update_params[1].memref.buffer = plain_pri_key;
+    pri_update_params[1].memref.size = t_key_len;
+    pri_update_params[2].memref.buffer = encrypted_output;  
+    pri_update_params[2].memref.size = t_key_len;
+
+    DMSG("\r\nReady to generate key pair stepBBB (pri encrypt)");
+    if (is_aes128) {
+        tee_res = TEE_InvokeTACommand(aes_sess, TEE_TIMEOUT_INFINITE,
+                                     PTA_CMD_AES128ECB_EncryptUpdate,
+                                     pri_update_types, pri_update_params, &ta_ret_orig);
+    } else {
+        tee_res = TEE_InvokeTACommand(aes_sess, TEE_TIMEOUT_INFINITE,
+                                     PTA_CMD_AES256ECB_EncryptUpdate,
+                                     pri_update_types, pri_update_params, &ta_ret_orig);
+    }
+    if (tee_res != TEE_SUCCESS) {
+        DMSG("Private key encryption failed (0x%x, TA ret: 0x%x)", tee_res, ta_ret_orig);
+        TEE_CloseTASession(aes_sess);
+        return tee_res;
+    }
+
+    // 9. Õ«īµłÉń¦üķÆźÕŖĀÕ»å
+    TEE_Param pri_final_params[TEE_NUM_PARAMS] = {0};
+    uint32_t pri_final_types = TEE_PARAM_TYPES(TEE_PARAM_TYPE_MEMREF_INOUT,
+                                              TEE_PARAM_TYPE_NONE,
+                                              TEE_PARAM_TYPE_NONE,
+                                              TEE_PARAM_TYPE_NONE);
+    pri_final_params[0].memref.buffer = &pri_aes_handle;
+    pri_final_params[0].memref.size = sizeof(sce_aes_handle_t);
+
+    DMSG("\r\nReady to generate key pair stepCCC (pri final)");
+    if (is_aes128) {
+        tee_res = TEE_InvokeTACommand(aes_sess, TEE_TIMEOUT_INFINITE,
+                                     PTA_CMD_AES128ECB_EncryptFinal,
+                                     pri_final_types, pri_final_params, &ta_ret_orig);
+    } else {
+        tee_res = TEE_InvokeTACommand(aes_sess, TEE_TIMEOUT_INFINITE,
+                                     PTA_CMD_AES256ECB_EncryptFinal,
+                                     pri_final_types, pri_final_params, &ta_ret_orig);
+    }
+    if (tee_res != TEE_SUCCESS) {
+        DMSG("Private key encryption final failed (0x%x, TA ret: 0x%x)", tee_res, ta_ret_orig);
+        TEE_CloseTASession(aes_sess);
+        return tee_res;
+    }
+
+    // Õģ│ķŚŁAES TAõ╝ÜĶ»Ø
+    TEE_CloseTASession(aes_sess);
+
+    // µēōÕŹ░ÕŖĀÕ»åń╗ōµ×£
+    DMSG("\r\nEncrypted private key: ");
+    for (i = 0; i < t_key_len; i++) {
+        DMSG("%2x ", encrypted_output[i]);
+    }
+    DMSG("\r\nEncrypted key pair (pri+pub):");
+    // for (i = 0; i < required_out_size; i++) {
+    //     DMSG("%2x", encrypted_output[i]);
+    // }
+
+    // 10. Ķ«ŠńĮ«ĶŠōÕć║ķĢ┐Õ║”’╝łń¦üķÆź + Õģ¼ķÆźµĆ╗ķĢ┐Õ║”’╝ē
+    params[2].memref.size = required_out_size;
+    DMSG("\r\nECC key pair generated and encrypted successfully");
+
+    return TEE_SUCCESS;
+}
+
+static TEE_Result ecdsa_sec_sign(uint32_t types, TEE_Param params[TEE_NUM_PARAMS])
+{
+    // 4ÕÅéµĢ░ÕłåķģŹ’╝Ü
+    // params[0]’╝ÜĶŠōÕģź’╝īÕŖĀÕ»åń¦üķÆź
+    // params[1]’╝ÜĶŠōÕģź’╝īAESĶ¦ŻÕ»åÕÅéµĢ░’╝łwrapped_key + IV’╝īµēōÕīģń╗ōµ×äõĮō’╝ē
+    // params[2]’╝ÜĶŠōÕģź’╝īÕŠģńŁŠÕÉŹµĢ░µŹ«
+    // params[3]’╝ÜĶŠōÕć║’╝īńŁŠÕÉŹń╗ōµ×£
+
+    // ĶŠōÕģźÕÅéµĢ░µÅÉÕÅ¢
+    uint8_t *encrypted_priv_key = (uint8_t *)params[0].memref.buffer;
+    uint32_t encrypted_priv_len = params[0].memref.size;
+    aes_decrypt_params_t *aes_params = (aes_decrypt_params_t *)params[1].memref.buffer;
+    uint8_t *pBuf = (uint8_t *)params[2].memref.buffer;
+    uint32_t inLen = params[2].memref.size;
+    uint8_t *pSigOut = (uint8_t *)params[3].memref.buffer;
+    uint32_t sigOutSize = params[3].memref.size;
+
+    // Ķ¦ŻÕ»åńøĖÕģ│ÕÅśķćÅ
+    sce_aes_handle_t aes_handle = {0};
+    uint8_t plain_priv_key[ECC384_PRIKEY_LEN] = {0};
+    BOOL signResult = FALSE;
+    TEE_Result tee_res = TEE_SUCCESS;
+    bool is_aes128 = false;
+    int i = 0;
+    
+    // TA õ╝ÜĶ»ØńøĖÕģ│ÕÅśķćÅ
+    TEE_TASessionHandle aes_sess = TEE_HANDLE_NULL;
+    uint32_t ta_ret_orig = 0;
+    static const TEE_UUID aes_uuid = PTA_SCE_AES_UUID;
+
+    // 1. µĀĪķ¬īÕÅéµĢ░ń▒╗Õ×ŗ’╝ł4ÕÅéµĢ░’╝Ü3ĶŠōÕģź+1ĶŠōÕć║’╝ē
+    if (types != TEE_PARAM_TYPES(TEE_PARAM_TYPE_MEMREF_INPUT,   // ÕŖĀÕ»åń¦üķÆź
+                                TEE_PARAM_TYPE_MEMREF_INPUT,   // AESĶ¦ŻÕ»åÕÅéµĢ░’╝łń╗ōµ×äõĮō’╝ē
+                                TEE_PARAM_TYPE_MEMREF_INPUT,   // ÕŠģńŁŠÕÉŹµĢ░µŹ«
+                                TEE_PARAM_TYPE_MEMREF_OUTPUT)) { // ńŁŠÕÉŹń╗ōµ×£
+        DMSG("Invalid parameter types (expected 4 params)");
+        return TEE_ERROR_BAD_PARAMETERS;
+    }
+
+    // 2. ÕÅéµĢ░µ£ēµĢłµĆ¦µĀĪķ¬ī
+    if (!encrypted_priv_key || !aes_params || !pBuf || !pSigOut) {
+        DMSG("NULL pointer in parameters");
+        return TEE_ERROR_BAD_PARAMETERS;
+    }
+
+    // µĀĪķ¬īAESĶ¦ŻÕ»åÕÅéµĢ░ń╗ōµ×äõĮōÕż¦Õ░Å
+    if (params[1].memref.size != sizeof(aes_decrypt_params_t)) {
+        DMSG("Invalid AES params size (need %zu, got %u)",
+                     sizeof(aes_decrypt_params_t), params[1].memref.size);
+        return TEE_ERROR_BAD_PARAMETERS;
+    }
+
+    // µĀĪķ¬īń¦üķÆźķĢ┐Õ║”’╝ł256/384õĮŹ’╝ē
+    if (encrypted_priv_len != ECC256_PRIKEY_LEN && encrypted_priv_len != ECC384_PRIKEY_LEN) {
+        DMSG("Invalid encrypted private key length: %u", encrypted_priv_len);
+        return TEE_ERROR_BAD_PARAMETERS;
+    }
+
+    // µĀĪķ¬īńŁŠÕÉŹĶŠōÕć║ń╝ōÕå▓Õī║Õż¦Õ░Å’╝łń¦üķÆźķĢ┐Õ║”├Ś2’╝ē
+    if (sigOutSize < 2 * encrypted_priv_len) {
+        DMSG("Signature buffer too small (need %u, got %u)",
+             2 * encrypted_priv_len, sigOutSize);
+        return TEE_ERROR_SHORT_BUFFER;
+    }
+
+    // 3. ńĪ«Õ«ÜAESń▒╗Õ×ŗ’╝ł256õĮŹń¦üķÆźŌåÆAES-128’╝ī384õĮŹŌåÆAES-256’╝ē
+    if (encrypted_priv_len == ECC256_PRIKEY_LEN) {
+        is_aes128 = true;
+    }
+
+    // -------------------------- µēōÕ╝ĆAES TAõ╝ÜĶ»Ø --------------------------
+    tee_res = TEE_OpenTASession(&aes_uuid, TEE_TIMEOUT_INFINITE, 0, NULL, &aes_sess, &ta_ret_orig);
+    if (tee_res != TEE_SUCCESS) {
+        DMSG("Can't open session to AES PTA (0x%x)", tee_res);
+        return tee_res;
+    }
+
+    // -------------------------- ń¼¼õĖĆµŁź’╝ÜÕłØÕ¦ŗÕī¢AESĶ¦ŻÕ»åõĖŖõĖŗµ¢ć --------------------------
+    TEE_Param init_params[TEE_NUM_PARAMS] = {0};
+    uint32_t init_types = TEE_PARAM_TYPES(TEE_PARAM_TYPE_MEMREF_INOUT,
+                                         TEE_PARAM_TYPE_MEMREF_INPUT,
+                                         TEE_PARAM_TYPE_NONE,
+                                         TEE_PARAM_TYPE_NONE);
+    init_params[0].memref.buffer = &aes_handle;
+    init_params[0].memref.size = sizeof(sce_aes_handle_t);
+    init_params[1].memref.buffer = &aes_params->wrapped_key;  // õ╗Äń╗ōµ×äõĮōÕÅ¢wrapped_key
+    init_params[1].memref.size = sizeof(aes_params->wrapped_key);
+    // init_params[2].memref.buffer = aes_params->initial_vector; // õ╗Äń╗ōµ×äõĮōÕÅ¢IV
+    // init_params[2].memref.size = HW_SCE_AES_CBC_IV_BYTE_SIZE;
+    
+    DMSG("\r\naes_params->wrapped_key (size: %zu bytes): ", sizeof(aes_params->wrapped_key));
+    // for (size_t i = 0; i < sizeof(aes_params->wrapped_key); i++) {
+    //     DMSG("%02x ", (unsigned int)((uint8_t *)&aes_params->wrapped_key)[i]);
+    // } 
+    // DMSG("\r\naes_params->initial_vector (size: %d bytes): ", HW_SCE_AES_CBC_IV_BYTE_SIZE);
+    // for (size_t i = 0; i < HW_SCE_AES_CBC_IV_BYTE_SIZE; i++) {
+    //     DMSG("%02x ", (unsigned int)aes_params->initial_vector[i]);
+    // } 
+
+    // Ķ░āńö©TAńÜäĶ¦ŻÕ»åÕłØÕ¦ŗÕī¢ÕæĮõ╗ż
+    if (is_aes128) {
+        tee_res = TEE_InvokeTACommand(aes_sess, TEE_TIMEOUT_INFINITE,
+                                     PTA_CMD_AES128ECB_DecryptInit,
+                                     init_types, init_params, &ta_ret_orig);
+    } else {
+        tee_res = TEE_InvokeTACommand(aes_sess, TEE_TIMEOUT_INFINITE,
+                                     PTA_CMD_AES256ECB_DecryptInit,
+                                     init_types, init_params, &ta_ret_orig);
+    }
+    if (tee_res != TEE_SUCCESS) {
+        DMSG("AES decrypt init failed (0x%x, TA ret: 0x%x)", tee_res, ta_ret_orig);
+        TEE_CloseTASession(aes_sess);
+        return tee_res;
+    }
+
+    // -------------------------- ń¼¼õ║īµŁź’╝Üµē¦ĶĪīń¦üķÆźĶ¦ŻÕ»å --------------------------
+    TEE_Param update_params[TEE_NUM_PARAMS] = {0};
+    uint32_t update_types = TEE_PARAM_TYPES(TEE_PARAM_TYPE_MEMREF_INOUT,
+                                          TEE_PARAM_TYPE_MEMREF_INPUT,
+                                          TEE_PARAM_TYPE_MEMREF_INOUT,
+                                          TEE_PARAM_TYPE_NONE);
+    update_params[0].memref.buffer = &aes_handle;
+    update_params[0].memref.size = sizeof(sce_aes_handle_t);
+    update_params[1].memref.buffer = encrypted_priv_key;
+    update_params[1].memref.size = encrypted_priv_len;
+    update_params[2].memref.buffer = plain_priv_key;
+    update_params[2].memref.size = encrypted_priv_len;
+
+    // Ķ░āńö©TAńÜäĶ¦ŻÕ»åµø┤µ¢░ÕæĮõ╗ż
+    if (is_aes128) {
+        tee_res = TEE_InvokeTACommand(aes_sess, TEE_TIMEOUT_INFINITE,
+                                     PTA_CMD_AES128ECB_DecryptUpdate,
+                                     update_types, update_params, &ta_ret_orig);
+    } else {
+        tee_res = TEE_InvokeTACommand(aes_sess, TEE_TIMEOUT_INFINITE,
+                                     PTA_CMD_AES256ECB_DecryptUpdate,
+                                     update_types, update_params, &ta_ret_orig);
+    }
+    if (tee_res != TEE_SUCCESS) {
+        DMSG("Private key decryption failed (0x%x, TA ret: 0x%x)", tee_res, ta_ret_orig);
+        TEE_CloseTASession(aes_sess);
+        return tee_res;
+    }
+
+    // -------------------------- ń¼¼õĖēµŁź’╝ÜÕ«īµłÉĶ¦ŻÕ»åµōŹõĮ£ --------------------------
+    TEE_Param final_params[TEE_NUM_PARAMS] = {0};
+    uint32_t final_types = TEE_PARAM_TYPES(TEE_PARAM_TYPE_MEMREF_INOUT,
+                                          TEE_PARAM_TYPE_NONE,
+                                          TEE_PARAM_TYPE_NONE,
+                                          TEE_PARAM_TYPE_NONE);
+    final_params[0].memref.buffer = &aes_handle;
+    final_params[0].memref.size = sizeof(sce_aes_handle_t);
+
+    // Ķ░āńö©TAńÜäĶ¦ŻÕ»åµ£Ćń╗łÕæĮõ╗ż
+    if (is_aes128) {
+        tee_res = TEE_InvokeTACommand(aes_sess, TEE_TIMEOUT_INFINITE,
+                                     PTA_CMD_AES128ECB_DecryptFinal,
+                                     final_types, final_params, &ta_ret_orig);
+    } else {
+        tee_res = TEE_InvokeTACommand(aes_sess, TEE_TIMEOUT_INFINITE,
+                                     PTA_CMD_AES256ECB_DecryptFinal,
+                                     final_types, final_params, &ta_ret_orig);
+    }
+    if (tee_res != TEE_SUCCESS) {
+        DMSG("Decryption finalization failed (0x%x, TA ret: 0x%x)", tee_res, ta_ret_orig);
+        TEE_CloseTASession(aes_sess);
+        return tee_res;
+    }
+
+    // -------------------------- Õģ│ķŚŁTAõ╝ÜĶ»Ø --------------------------
+    TEE_CloseTASession(aes_sess);
+
+    // -------------------------- õĮ┐ńö©Ķ¦ŻÕ»åÕÉÄńÜäń¦üķÆźńŁŠÕÉŹ --------------------------
+    DMSG("Generating ECDSA signature with decrypted key");
+    DMSG("\r\nplain_priv_key is: ");
+    // for(int i=0; i<encrypted_priv_len; i++) {
+    //     DMSG("%02x", plain_priv_key[i]);
+    // }
+
+    DMSG("\r\nWait to sign data is: ");
+    // for(int i=0; i<inLen; i++) {
+    //     DMSG("%02x", pBuf[i]);
+    // }
+
+    signResult = Servp_ECDSA_DigitSign(plain_priv_key, encrypted_priv_len, pBuf, inLen, pSigOut);
+
+    // DMSG("\r\nSig out data is: ");
+    // for(int i=0; i<2*encrypted_priv_len; i++) {
+    //     DMSG("%02x", pSigOut[i]);
+    // }
+
+    if (!signResult) {
+        DMSG("Signature generation failed");
+        return TEE_ERROR_SIGNATURE_INVALID;
+    }
+
+    // -------------------------- Ķ«ŠńĮ«ĶŠōÕć║ķĢ┐Õ║” --------------------------
+    params[3].memref.size = 2 * encrypted_priv_len;
+    DMSG("ECDSA signature generated successfully");
+
+    return TEE_SUCCESS;
+}
