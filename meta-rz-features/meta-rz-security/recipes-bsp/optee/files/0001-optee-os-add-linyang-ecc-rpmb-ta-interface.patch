+    // 1. ńĪ«Õ«Üµ£ēµĢłµĢ░µŹ«Õī║Õ¤¤
+    const uint8_t *valid_data_start = (const uint8_t *)&(storage->rpmb_key_id);
+    uint32_t valid_data_len = sizeof(RPMB_Key_Storage) - sizeof(uint32_t);
+
+    // 2. Ķ«Īń«Ś CRC32 µĀĪķ¬īÕĆ╝
+    uint32_t crc = calculate_crc32(valid_data_start, valid_data_len);
+
+    // 3. Õ░å CRC ń╗ōµ×£ÕåÖÕģźń╗ōµ×äõĮōńÜä crc32_value ÕŁŚµ«Ą
+    storage->crc32_value = crc;
