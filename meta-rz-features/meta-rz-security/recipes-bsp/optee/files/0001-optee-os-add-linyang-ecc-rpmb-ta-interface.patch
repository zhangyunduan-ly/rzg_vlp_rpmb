+}  
+  
+  
+/*  
+ * Transform the message X which consists of 16 32-bit-words  
+ */  
+static void  SERVp_hash_Sha1transform( SERVp_hash_SHA1_CONTEXT *hd, unsigned char *data )  
+{  
+    u32 a,b,c,d,e,tm;  
+    u32 x[16];  
+  
+    /* get values from the chaining vars */  
+    a = hd->h0;  
+    b = hd->h1;  
+    c = hd->h2;  
+    d = hd->h3;  
+    e = hd->h4;  
+  
+#ifdef BIG_ENDIAN_HOST  
+    memcpy( x, data, 64 );  
+#else  
