+/**
+ * @brief µĀ╣µŹ«key_idĶÄĘÕÅ¢Õ»╣Õ║öńÜäECCń╝ōÕŁśµīćķÆł
+ * @param key_id ńø«µĀćÕ»åķÆźID
+ * @param cache_ptr [ĶŠōÕć║] Õī╣ķģŹÕł░ńÜäń╝ōÕŁśµīćķÆł
+ * @param cache_name [ĶŠōÕć║] ń╝ōÕŁśÕÉŹń¦░’╝łńö©õ║ÄµŚźÕ┐Ś’╝ē
+ * @return TEE_SUCCESS:µēŠÕł░Õī╣ķģŹ / TEE_ERROR_NOT_FOUND:µŚĀÕī╣ķģŹ
+ */
+static TEE_Result get_ecc_cache_by_key_id(uint32_t key_id, ECC_RPMB_Key_Storage **cache_ptr, const char **cache_name) {
+    *cache_ptr = NULL;
+    *cache_name = NULL;
+    switch (key_id) {
+        case KEY_PAIR_USED:
+            *cache_ptr = (ECC_RPMB_Key_Storage *)&g_DCU_ecc_key_used_cache;
+            *cache_name = "g_DCU_ecc_key_used_cache";
+            break;
+        case KEY_PAIR_SAVED:
+            *cache_ptr = (ECC_RPMB_Key_Storage *)&g_DCU_ecc_key_saved_cache;
+            *cache_name = "g_DCU_ecc_key_saved_cache";
+            break;
+        case KEY_PAIR_USED_MTR:
+            *cache_ptr = (ECC_RPMB_Key_Storage *)&g_MTR_ecc_key_used_cache;
+            *cache_name = "g_MTR_ecc_key_used_cache";
+            break;
+        case KEY_PAIR_SAVED_MTR:
+            *cache_ptr = (ECC_RPMB_Key_Storage *)&g_MTR_ecc_key_saved_cache;
+            *cache_name = "g_MTR_ecc_key_saved_cache";
+            break;
+        default:
+            return -1;
+    }
+    return TEE_SUCCESS;
+}
