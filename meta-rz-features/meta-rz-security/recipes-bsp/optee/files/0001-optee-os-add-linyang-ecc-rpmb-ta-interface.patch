+/* For AES operation. */
+#define HW_SCE_AES128_KEY_INDEX_WORD_SIZE                         (12U)
+#define HW_SCE_AES256_KEY_INDEX_WORD_SIZE                         (16U)
+#define HW_SCE_AES128_KEY_WORD_SIZE                               (4U)
