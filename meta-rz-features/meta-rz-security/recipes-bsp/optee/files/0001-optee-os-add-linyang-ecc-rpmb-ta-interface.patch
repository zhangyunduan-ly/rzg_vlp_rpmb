+static int rpmb_cache_alloc_or_find_idx(uint32_t target_key_id)
+{
+    // Õģłµ¤źµēŠÕĘ▓ÕŁśÕ£©ńÜäkey_idń╝ōÕŁś
+    for (int i = 0; i < RPMB_KEY_CACHE_MAX_CNT; i++) {
+        if (g_rpmb_key_cache[i].is_valid == 1 && 
+            g_rpmb_key_cache[i].rpmb_key_id == target_key_id) {
+            return i;
+        }
+    }
+    // µ£¬µēŠÕł░ÕłÖÕłåķģŹń®║ķŚ▓õĖŗµĀć
+    for (int i = 0; i < RPMB_KEY_CACHE_MAX_CNT; i++) {
+        if (g_rpmb_key_cache[i].is_valid == 0) {
+            return i;
+        }
+    }
+    return -1; // ń╝ōÕŁśµ▒ĀÕĘ▓µ╗Ī
+}
