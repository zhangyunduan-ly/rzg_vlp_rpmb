+Esc_ERROR
+EscEcc_CalculateRandomK(
+    const EscEcc_CurveT* curve,
+    EscEcc_FieldElementT* k)
+{
+    Esc_ERROR returnCode = Esc_NO_ERROR;
+    Esc_UINT8 rand[EscEcc_MAX_WORDS * 4U]={1,2,3,4,5,2,3,4,5,2,3,4,5,2,3,4,5};
+    EscEcc_FieldElementT n_minus_one;
+    Esc_UINT32 zeroBitMask, temp, randomErrorCount;
+    Esc_SINT8 compResult;
+
+    /* Initialize n_minus_one to avoid compiler warning */
+    n_minus_one.word[0] = 0U;
+    EscEccFe_Assign(&n_minus_one, &curve->base_point_order_n.prime_p, curve->base_point_order_n.pLen);
+    Esc_ASSERT( (n_minus_one.word[0] & 0x01U) == 1U );
+    n_minus_one.word[0] = n_minus_one.word[0] - 1U;
+
+    /* Calculate mask for msb of n-1 */
+    zeroBitMask = EscEcc_32BIT_WORD_ALL_SET;
+    temp = EscEcc_32BIT_WORD_MSB_SET;
+    Esc_ASSERT( n_minus_one.word[curve->base_point_order_n.pLen - 1U] != 0U );
+    
+    while ( (n_minus_one.word[curve->base_point_order_n.pLen - 1U] & temp) == 0U)
+    {
+        zeroBitMask >>= 1U;
+        temp >>= 1U;
+    }
+
+    /* Clear unused words in k */
+    for (temp = curve->base_point_order_n.pLen; temp < EscEcc_MAX_WORDS; temp++)
+    {
+        k->word[temp] = 0U;
+    }
+
+    /* Generate random k (0 < k < n) */
+    randomErrorCount = 0U;
+    do
+    {
+        /* Get REE time and generate rand array */
+        TEE_Time tee_time;
+        TEE_GetREETime(&tee_time);
+
+        // ========== 1. Print tee_time  ==========
+        DMSG("EscEcc_CalculateRandomK: TEE_Time values:");
+        DMSG("  - seconds: %lu (0x%08lX)", tee_time.seconds, tee_time.seconds);  // ÕŹüĶ┐øÕłČ+ÕŹüÕģŁĶ┐øÕłČ
+        DMSG("  - microseconds: %lu (0x%08lX)", tee_time.millis, tee_time.millis);
+
+        /* Generate rand array with time */
+        SERVp_hash_sha256((unsigned char*)&tee_time, sizeof(TEE_Time), rand, NULL);
+        memcpy(rand + 32, &tee_time.seconds, 4);
+
+        // ========== 2. Print rand array (ķ¬īĶ»üķÜÅµ£║ÕĆ╝) ==========
+        const uint32_t print_len = (4U * curve->base_point_order_n.pLen) > 64 ? 64 : (4U * curve->base_point_order_n.pLen);
+        DMSG("EscEcc_CalculateRandomK: rand array (first %u bytes):", print_len);
+        // for (temp = 0U; temp < print_len; temp++)
+        // {
+        //     if (temp % 16 == 0) DMSG("  ");          // µ»ÅĶĪīÕ╝ĆÕż┤ń╝®Ķ┐ø
+        //     DMSG("%02X ", rand[temp]);               // ÕŹüÕģŁĶ┐øÕłČµēōÕŹ░ÕŁŚĶŖé
+        //     if (temp % 16 == 15) DMSG("");           // µ»Å16ÕŁŚĶŖéµŹóĶĪī
+        // }
+        // DMSG(""); // ń╗ōµØ¤µŹóĶĪī
+
+        /* Convert rand to field element k */
+        for (temp = 0U; temp < curve->base_point_order_n.pLen; temp++)
+        {
+            k->word[temp] = EscEccWd_FromOctets( rand, temp * 4U );
+        }
+
+        /* Mask msb bits */
+        k->word[curve->base_point_order_n.pLen - 1U] &= zeroBitMask;
+
+        /* Compare k with n-1 */
+        compResult = EscEccFe_AbsoluteCompare( k, &n_minus_one, curve->base_point_order_n.pLen );
+        randomErrorCount++;
+
+    } while ( (randomErrorCount < EscEcc_MAX_RANDOM_CALLS) &&
+              ((compResult >= 0) || (EscEccFe_IsZero(k, curve->maxWords) == TRUE)) );
+    
+    if (randomErrorCount > EscEcc_MAX_RANDOM_CALLS)
+    {
+        returnCode = Esc_INTERNAL_FUNCTION_ERROR;
+        DMSG("EscEcc_CalculateRandomK: Failed, exceed max random calls (%u)", randomErrorCount);
+    }
+    else
+    {
+        DMSG("EscEcc_CalculateRandomK: Success, random calls: %u", randomErrorCount);
+    }
+
+    return returnCode;
+}
