+
+#define ECC256_PRIKEY_LEN 32
+#define ECC384_PRIKEY_LEN 48
+
+/*****************************************************************************
+ ÕćĮ µĢ░ ÕÉŹ  : Servp_ECDSA_DigitSign
+ ÕŖ¤ĶāĮµÅÅĶ┐░  : µĢ░ÕŁŚńŁŠÕÉŹ Õ»╣µĢ░µŹ«ÕģłÕüÜSHAÕåŹÕüÜńŁŠÕÉŹ
+ ĶŠōÕģźÕÅéµĢ░  : INT8U *pPriveKey  ńŁŠÕÉŹń¦üķÆź  
+ 		   : INT8U nPriveKeyLen ńŁŠÕÉŹń¦üķÆźńÜäķĢ┐Õ║” 32 or 48 byte
+ 		     INT8U* pBuf  ńŁēÕŠģńŁŠÕÉŹńÜäµĢ░µŹ« 
+  		   : B_FUN_V ECCquitCondition  Õø×Ķ░āÕćĮµĢ░µīćķÆł’╝īńö©õ║Äµ¤źń£ŗµś»ÕÉ”ķ£ĆĶ”üń┤¦µĆźµāģÕåĄõĖŗÕÅŖµŚČķĆĆÕć║’╝īķ£ĆĶ”üĶ░āńö©ĶĆģµĀ╣µŹ«Õ«×ķÖģµāģÕåĄń╝¢ÕåÖÕćĮµĢ░ŃĆé
+ 		     int inLen ńŁēÕŠģńŁŠÕÉŹńÜäµĢ░µŹ«ķĢ┐Õ║”
+ ĶŠōÕć║ÕÅéµĢ░  : INT8U *pSigOut  ńŁŠÕÉŹ
+ Ķ┐ö Õø× ÕĆ╝  : BOOL TRUE µłÉÕŖ¤
+*****************************************************************************/
+//BOOL Servp_ECDSA_DigitSign(INT8U *pPriveKey, INT8U nPriveKeyLen, INT8U *pBuf, int inLen, INT8U *pSigOut, B_FUN_V ECCquitCondition)
+BOOL Servp_ECDSA_DigitSign(INT8U *pPriveKey, INT8U nPriveKeyLen, INT8U *pBuf, int inLen, INT8U *pSigOut)
+{
+  INT8U ShaValue[48];
+  EscEcc_CurveId curveId = EscEcc_CURVE_SECP_256;
+
+  //Õ»╣ĶŠōÕģźµĢ░µŹ«ÕüÜsha
+  if (ECC256_PRIKEY_LEN == nPriveKeyLen) {
+    curveId = EscEcc_CURVE_SECP_256;
+#ifdef CFGSHA256_hardWareEnable
+    return FALSE; //µÜéõĖŹµö»µīüńĪ¼õ╗ČSHA256’╝īÕÉÄń╗ŁµĘ╗ÕŖĀ
+#else
+    SERVp_hash_sha256(pBuf, inLen, ShaValue, NULL); //hashÕĆ╝õĖ┤µŚČµöŠÕ£©ĶŠōÕć║õĖŁ
+#endif //CFGSHA256_hardWareEnable
+  } else {
+    curveId = EscEcc_CURVE_SECP_384;
+#ifdef CFGSHA384_hardWareEnable
+    return FALSE; //µÜéõĖŹµö»µīüńĪ¼õ╗ČSHA384’╝īÕÉÄń╗ŁµĘ╗ÕŖĀ
+#else
+    SERVp_hash_sha512(pBuf, inLen, ShaValue, 1, NULL); //1:is384
+
+#endif //CFGSHA384_hardWareEnable
+  }
+
+#ifdef CFGECC_hardWareEnable
+  return FALSE; //µÜéõĖŹµö»µīüńĪ¼õ╗ČECC’╝īÕÉÄń╗ŁµĘ╗ÕŖĀ
+#else
+  EscEcc_SignatureT nEscEccSignature;
+  DMSG("%s %d \r\n", __func__, __LINE__);
+
+  DMSG("\r\nSign HASH value is: ");
+    // for(int i=0;i<nPriveKeyLen;i++)
+    // {
+    //     DMSG("%x",ShaValue[i]);
+    // }
+  if (Esc_NO_ERROR == EscEcc_SignatureGeneration(&nEscEccSignature, ShaValue, nPriveKeyLen, pPriveKey, nPriveKeyLen, curveId)) {
+    memcpy(pSigOut, nEscEccSignature.r_bytes, nPriveKeyLen);
+    memcpy(pSigOut + nPriveKeyLen, nEscEccSignature.s_bytes, nPriveKeyLen);
+    DMSG("\r\nNew pSigOut value is: ");
+    // for(int i=0;i<2*nPriveKeyLen;i++)
+    // {
+    //     DMSG("%x",pSigOut[i]);
+    // }
+    return TRUE;
+  } else {
+    return FALSE;
+  }
+#endif //CFGECC_hardWareEnable
+}
+
+/*****************************************************************************
+ ÕćĮ µĢ░ ÕÉŹ  : Servp_ECDSA_Verification
+ ÕŖ¤ĶāĮµÅÅĶ┐░  : µĢ░ÕŁŚńŁŠÕÉŹķ¬īĶ»ü Õ»╣µĢ░µŹ«ÕģłÕüÜSHAÕåŹÕüÜńŁŠÕÉŹķ¬īĶ»ü
+ ĶŠōÕģźÕÅéµĢ░  : INT8U *pQDig  ńŁŠÕÉŹķ¬īĶ»üńÜäÕģ¼ķÆź 
+ 		   : INT8U nPriveKeyLen ńŁŠÕÉŹń¦üķÆźńÜäķĢ┐Õ║” 32 or 48 byte
+ 		     INT8U* pBuf  ńŁēÕŠģńŁŠÕÉŹķ¬īĶ»üńÜäµĢ░µŹ«   
+ 		     int inLen ńŁēÕŠģńŁŠÕÉŹķ¬īĶ»üńÜäµĢ░µŹ«ķĢ┐Õ║”
+ 		     INT8U *pSig  ńŁēÕŠģķ¬īĶ»üńÜäńŁŠÕÉŹ
+  		   : B_FUN_V ECCquitCondition  Õø×Ķ░āÕćĮµĢ░µīćķÆł’╝īńö©õ║Äµ¤źń£ŗµś»ÕÉ”ķ£ĆĶ”üń┤¦µĆźµāģÕåĄõĖŗÕÅŖµŚČķĆĆÕć║’╝īķ£ĆĶ”üĶ░āńö©ĶĆģµĀ╣µŹ«Õ«×ķÖģµāģÕåĄń╝¢ÕåÖÕćĮµĢ░ŃĆé
+ ĶŠōÕć║ÕÅéµĢ░  : 
+ Ķ┐ö Õø× ÕĆ╝  : BOOL TRUE ńŁŠÕÉŹķ¬īĶ»üµłÉÕŖ¤
+*****************************************************************************/
+//BOOL Servp_ECDSA_Verification(INT8U *pQDig, INT8U nPriveKeyLen, INT8U *pBuf, int inLen, INT8U *pSig, B_FUN_V ECCquitCondition)
+BOOL Servp_ECDSA_Verification(INT8U *pQDig, INT8U nPriveKeyLen, INT8U *pBuf, int inLen, INT8U *pSig)
+{
+  INT8U ShaValue[64];
+  EscEcc_CurveId curveId = EscEcc_CURVE_SECP_256;
+  DMSG("%s %d \r\n",__func__, __LINE__);
+  //Õ»╣ĶŠōÕģźµĢ░µŹ«ÕüÜsha
+  if (ECC256_PRIKEY_LEN == nPriveKeyLen) {
+    DMSG("%s %d \r\n",__func__, __LINE__);
+    curveId = EscEcc_CURVE_SECP_256;
+#ifdef CFGSHA256_hardWareEnable
+    return FALSE; //µÜéõĖŹµö»µīüńĪ¼õ╗ČSHA256’╝īÕÉÄń╗ŁµĘ╗ÕŖĀ
+#else
+    SERVp_hash_sha256(pBuf, inLen, ShaValue, NULL); //hashÕĆ╝õĖ┤µŚČµöŠÕ£©ĶŠōÕć║õĖŁ
+#endif //CFGSHA256_hardWareEnable
+  } else {
+    DMSG("%s %d \r\n",__func__, __LINE__);
+    curveId = EscEcc_CURVE_SECP_384;
+#ifdef CFGSHA384_hardWareEnable
+    return FALSE; //µÜéõĖŹµö»µīüńĪ¼õ╗ČSHA384’╝īÕÉÄń╗ŁµĘ╗ÕŖĀ
+#else
+    SERVp_hash_sha512(pBuf, inLen, ShaValue, 1, NULL); //1:is384
+#endif //CFGSHA384_hardWareEnable
+  }
+
+#ifdef CFGECC_hardWareEnable
+  return FALSE; //µÜéõĖŹµö»µīüńĪ¼õ╗ČECC’╝īÕÉÄń╗ŁµĘ╗ÕŖĀ
+#else
+  EscEcc_SignatureT nEscEccSignature;
+  EscEcc_PublicKeyT nEscEccQ;
+  DMSG("%s %d \r\n",__func__, __LINE__);
+  memcpy(nEscEccSignature.r_bytes, pSig, nPriveKeyLen);
+  memcpy(nEscEccSignature.s_bytes, pSig + nPriveKeyLen, nPriveKeyLen);
+  memcpy(nEscEccQ.x, pQDig, nPriveKeyLen);
+  memcpy(nEscEccQ.y, pQDig + nPriveKeyLen, nPriveKeyLen);
+  DMSG("%s %d  %d\r\n", __func__, __LINE__, curveId);
+  DMSG("\r\nVerify HASH value is: ");
+    for(int i=0;i<nPriveKeyLen;i++)
+    {
+        DMSG("%x",ShaValue[i]);
+    }
+  if (Esc_NO_ERROR == EscEcc_SignatureVerification(ShaValue, nPriveKeyLen, &nEscEccSignature, &nEscEccQ, curveId)) {
+    DMSG("%s %d \r\n",__func__, __LINE__);
+    return TRUE;
+  } else {
+    DMSG("%s %d \r\n",__func__, __LINE__);
+    return FALSE;
+  }
+#endif //CFGECC_hardWareEnable
+}
+
+/*****************************************************************************
+ ÕćĮ µĢ░ ÕÉŹ  : Servp_ECDSA_SHA256_Verification
+ ÕŖ¤ĶāĮµÅÅĶ┐░  : µĢ░ÕŁŚńŁŠÕÉŹķ¬īĶ»ü ĶŠōÕģźõĖ║ÕŠģńŁŠÕÉŹńÜäSHA256ÕĆ╝
+ ĶŠōÕģźÕÅéµĢ░  : INT8U *pQDig ķ¬īĶ»üńŁŠÕÉŹńÜäÕģ¼ķÆź 64ÕŁŚĶŖé
+ 		     INT8U* pSHA256Buf  ńŁēÕŠģķ¬īĶ»üńŁŠÕÉŹńÜäsha256µĢ░µŹ« 32byte
+  		   : B_FUN_V ECCquitCondition  Õø×Ķ░āÕćĮµĢ░µīćķÆł’╝īńö©õ║Äµ¤źń£ŗµś»ÕÉ”ķ£ĆĶ”üń┤¦µĆźµāģÕåĄõĖŗÕÅŖµŚČķĆĆÕć║’╝īķ£ĆĶ”üĶ░āńö©ĶĆģµĀ╣µŹ«Õ«×ķÖģµāģÕåĄń╝¢ÕåÖÕćĮµĢ░ŃĆé
+ ĶŠōÕć║ÕÅéµĢ░  : INT8U *pSigOut  ÕŠģķ¬īĶ»üńÜäńŁŠÕÉŹ
+ Ķ┐ö Õø× ÕĆ╝  : BOOL TRUE ķ¬īĶ»üµłÉÕŖ¤
+*****************************************************************************/
+//BOOL Servp_ECDSA_SHA256_Verification(INT8U *pQDig, INT8U *pSHA256Buf, INT8U *pSig, B_FUN_V ECCquitCondition)
+BOOL Servp_ECDSA_SHA256_Verification(INT8U *pQDig, INT8U *pSHA256Buf, INT8U *pSig)
+{
+#ifdef CFGECC_hardWareEnable
+  return FALSE; //µÜéõĖŹµö»µīüńĪ¼õ╗ČECC’╝īÕÉÄń╗ŁµĘ╗ÕŖĀ
+#else
+  EscEcc_SignatureT nEscEccSignature;
+  EscEcc_PublicKeyT nEscEccQ;
+  memcpy(nEscEccSignature.r_bytes, pSig, ECC256_PRIKEY_LEN);
+  memcpy(nEscEccSignature.s_bytes, pSig + ECC256_PRIKEY_LEN, ECC256_PRIKEY_LEN);
+  memcpy(nEscEccQ.x, pQDig, ECC256_PRIKEY_LEN);
+  memcpy(nEscEccQ.y, pQDig + ECC256_PRIKEY_LEN, ECC256_PRIKEY_LEN);
+
+  if (Esc_NO_ERROR == EscEcc_SignatureVerification(pSHA256Buf, ECC256_PRIKEY_LEN, &nEscEccSignature, &nEscEccQ, EscEcc_CURVE_SECP_256)) {
+    return TRUE;
+  } else {
+    return FALSE;
+  }
+
+  return FALSE;
+#endif //CFGECC_hardWareEnable
+}
+
+/*****************************************************************************
+ ÕćĮ µĢ░ ÕÉŹ  : Servp_ECC_GenKeyPair
+ ÕŖ¤ĶāĮµÅÅĶ┐░  : ECCÕ»åķÆźÕ»╣ńö¤µłÉ
+ ĶŠōÕģźÕÅéµĢ░  : INT8U nPriveKeyLen ńŁēÕŠģńö¤µłÉńÜäń¦üķÆźńÜäķĢ┐Õ║”
+  		   : B_FUN_V ECCquitCondition  Õø×Ķ░āÕćĮµĢ░µīćķÆł’╝īńö©õ║Äµ¤źń£ŗµś»ÕÉ”ķ£ĆĶ”üń┤¦µĆźµāģÕåĄõĖŗÕÅŖµŚČķĆĆÕć║’╝īķ£ĆĶ”üĶ░āńö©ĶĆģµĀ╣µŹ«Õ«×ķÖģµāģÕåĄń╝¢ÕåÖÕćĮµĢ░ŃĆé
