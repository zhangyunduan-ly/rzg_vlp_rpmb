+++ b/ta/ly_ecc/include/_ecc.h
@@ -0,0 +1,688 @@
+/***************************************************************************
+ * This file is part of the cryptographic library CycurLIB                 *
+ *                                                                         *
+ * Copyright (C) 2016 ESCRYPT GmbH - All Rights Reserved                   *
+ *                                                                         *
+ *     ESCRYPT GmbH - Embedded Security                                    *
+ *     Zentrum fuer IT-Sicherheit                                          *
+ *     Lise-Meitner-Allee 4                                                *
+ *     44801 Bochum                                                        *
+ *     Germany                                                             *
+ *                                                                         *
+ *     www.escrypt.com                                                     *
+ *                                                                         *
+ ***************************************************************************/
+
+/***************************************************************************/
+/*!
+   \file
+
+   \brief       Common types and basic functions for ECC.
+
+   Byteorder of the long numbers is Little endian
+
+   $Rev: 2750 $
+ */
+/***************************************************************************/
+
+#ifndef ESC__ECC_H_
+#define ESC__ECC_H_
+
+/***************************************************************************
+ * 1. INCLUDES                                                             *
+ ***************************************************************************/
+
+#include "ecc_cfg.h" 
+#include "SERVp_cycurlib_config.h"
+
+/***************************************************************************
+ * 2. DEFINES REQUIRED BY CONFIGURATION                                    *
+ ***************************************************************************/
+
+/***************************************************************************
+ * 3. CONFIGURATION                                                        *
+ ***************************************************************************/
+
+/***************************************************************************
+ * 4. DEFINES                                                              *
+ ***************************************************************************/
+/** Number of bits in one word */
+#define EscEcc_WORD_BITS 32U
+
+#if Esc_HAS_INT64 == 1
+/** low 32 bit word from 64 bit */
+#    define EscEcc_LO64( a ) ( (Esc_UINT32)( (a) & 0xFFFFFFFFU ) )
+/** high 32 bit word from 64 bit */
+#    define EscEcc_HI64( a ) ( (Esc_UINT32)( ( (a) >> 32 ) & 0xFFFFFFFFU ) )
+/** return min(x,y) */
+#    define EscEcc_MIN( x, y ) ( ( (x) < (y) ) ? (x) : (y) )
+#else
+/** low 16 bit word from 32 bit */
+#    define EscEcc_LO32( a ) ( (Esc_UINT16)( (a) & 0xFFFFU ) )
+/** high 16 bit word from 32 bit */
+#    define EscEcc_HI32( a ) ( (Esc_UINT16)( ( (a) >> 16 ) & 0xFFFFU ) )
+#endif
+
+/** Bit mask in which the highest bit of a 32 bit word is set */
+#define EscEcc_32BIT_WORD_MSB_SET 0x80000000U
+/** Bit mask in which all bits of a 32 bit word are set */
+#define EscEcc_32BIT_WORD_ALL_SET 0xFFFFFFFFU
+
+/** As the internal generation of random nonces for signing and key generation depend on random values,
+    this is the maximum number of calls to the provided random function until a
+    Esc_INTERNAL_FUNCTION_ERROR is thrown to prevent infinite loops */
+#define EscEcc_MAX_RANDOM_CALLS 15U
+
+/** As Signature- and KeyGeneration depend on random nonces with a specific structure, this is the maximum
+    number of calls to the random nonce generation function until a Esc_INTERNAL_FUNCTION_ERROR is thrown
+    to prevent infinite loops */
+#define EscEcc_MAX_GENERATE_NONCE_CALLS 4U
+
+/** ID for curve secp160r1 */
+#define EscEcc_CURVE_SECP_160         0U
+/** ID for curve secp192r1 (also known as NIST P-192) */
+#define EscEcc_CURVE_SECP_192         1U
+/** ID for curve secp224r1 (also known as NIST P-224) */
+#define EscEcc_CURVE_SECP_224         2U
+/** ID for curve secp256r1 (also known as NIST P-256) */
+#define EscEcc_CURVE_SECP_256         3U
+/** ID for curve secp384r1 (also known as NIST P-384) */
+#define EscEcc_CURVE_SECP_384         4U
+/** ID for curve secp521r1 (also known as NIST P-521) */
+#define EscEcc_CURVE_SECP_521         5U
+
+/** ID for curve brainpoolP160r1 */
+#define EscEcc_CURVE_BRAINPOOL_P160   6U
+/** ID for curve brainpoolP192r1 */
+#define EscEcc_CURVE_BRAINPOOL_P192   7U
+/** ID for curve brainpoolP224r1 */
+#define EscEcc_CURVE_BRAINPOOL_P224   8U
+/** ID for curve brainpoolP256r1 */
+#define EscEcc_CURVE_BRAINPOOL_P256   9U
+/** ID for curve brainpoolP320r1 */
+#define EscEcc_CURVE_BRAINPOOL_P320   10U
+/** ID for curve brainpoolP384r1 */
+#define EscEcc_CURVE_BRAINPOOL_P384   11U
+/** ID for curve brainpoolP512r1 */
+#define EscEcc_CURVE_BRAINPOOL_P512   12U
+
+/** The curve ID with the highest value. This must be kept in sync with the ID values. */
+#define EscEcc_MAX_CURVE_ID     (EscEcc_CURVE_BRAINPOOL_P512)
+
+#if (EscEcc_SECP_521_ENABLED == 1)
+/** Maximum Key Length in Bytes */
+#   define EscEcc_KEY_BYTES_MAX  66U
+/** Maximum Key Length in Words */
+#   define EscEcc_MAX_WORDS  18U
+#elif (EscEcc_BRAINPOOL_P512_ENABLED == 1)
+/** Maximum Key Length in Bytes */
+#   define EscEcc_KEY_BYTES_MAX  64U
+/** Maximum Key Length in Words */
+#   define EscEcc_MAX_WORDS  17U
+#elif ((EscEcc_SECP_384_ENABLED == 1) || (EscEcc_BRAINPOOL_P384_ENABLED == 1))
+/** Maximum Key Length in Bytes */
+#   define EscEcc_KEY_BYTES_MAX  48U
+/** Maximum Key Length in Words */
+#   define EscEcc_MAX_WORDS  13U
+#elif (EscEcc_BRAINPOOL_P320_ENABLED == 1)
+/** Maximum Key Length in Bytes */
+#   define EscEcc_KEY_BYTES_MAX  40U
+/** Maximum Key Length in Words */
+#   define EscEcc_MAX_WORDS  11U
+#elif ((EscEcc_SECP_256_ENABLED == 1) || (EscEcc_BRAINPOOL_P256_ENABLED == 1))
+/** Maximum Key Length in Bytes */
+#   define EscEcc_KEY_BYTES_MAX  32U
+/** Maximum Key Length in Words */
+#   define EscEcc_MAX_WORDS  9U
+#elif ((EscEcc_SECP_224_ENABLED == 1) || (EscEcc_BRAINPOOL_P224_ENABLED == 1))
+/** Maximum Key Length in Bytes */
+#   define EscEcc_KEY_BYTES_MAX  28U
+/** Maximum Key Length in Words */
+#   define EscEcc_MAX_WORDS  8U
+#elif ((EscEcc_SECP_192_ENABLED == 1) || (EscEcc_BRAINPOOL_P192_ENABLED == 1))
+/** Maximum Key Length in Bytes */
+#   define EscEcc_KEY_BYTES_MAX  24U
+/** Maximum Key Length in Words */
+#   define EscEcc_MAX_WORDS  7U
+#elif (EscEcc_SECP_160_ENABLED == 1)
+/** Maximum Key Length in Bytes */
+#   define EscEcc_KEY_BYTES_MAX  20U
+/** Maximum Key Length in Words */
+#   define EscEcc_MAX_WORDS  7U
+#elif (EscEcc_BRAINPOOL_P160_ENABLED == 1)
+/** Maximum Key Length in Bytes */
+#   define EscEcc_KEY_BYTES_MAX  20U
+/** Maximum Key Length in Words */
+#   define EscEcc_MAX_WORDS  6U
+#endif
+
+/** The number of activated curves */
+#define EscEcc_NUMBER_CURVES \
+    (EscEcc_SECP_160_ENABLED + \
+     EscEcc_SECP_192_ENABLED + \
+     EscEcc_SECP_224_ENABLED + \
+     EscEcc_SECP_256_ENABLED + \
+     EscEcc_SECP_384_ENABLED + \
+     EscEcc_SECP_521_ENABLED + \
+     EscEcc_BRAINPOOL_P160_ENABLED + \
+     EscEcc_BRAINPOOL_P192_ENABLED + \
+     EscEcc_BRAINPOOL_P224_ENABLED + \
+     EscEcc_BRAINPOOL_P256_ENABLED + \
+     EscEcc_BRAINPOOL_P320_ENABLED + \
+     EscEcc_BRAINPOOL_P384_ENABLED + \
+     EscEcc_BRAINPOOL_P512_ENABLED)
+
+/** Test configuration */
+#if (EscEcc_NUMBER_CURVES == 0)
+#   error "At least one elliptic curve must be enabled"
+#endif
+
+/** Affine coordinates EscEcc_PointT type */
+#define C_PT_AFFINE     0U
+/** Jacobian coordinates EscEcc_PointT type */
+#define C_PT_JACOBIAN   2U
+
+/** Maximum multiplication precision a * b = c. len(c) = len(a) + len(b) */
+#define EscEcc_MAX_LONG_WORDS (2U * EscEcc_MAX_WORDS)
+
+#if ( (EscEcc_ECDSA_ENABLED == 1) && (EscEcc_USE_SHAMIRS_TRICK == 1) )
+/** Enable the definition of the functions containing Shamir's Trick
+ * depending on the configuration */
+#   define EscEcc_ENABLE_SHAMIRS_TRICK 1
+#else
+/** Disable the definition of the functions containing Shamir's Trick
+ * depending on the configuration */
+#   define EscEcc_ENABLE_SHAMIRS_TRICK 0
+#endif
+
+#if EscEcc_USE_SLIDING_WINDOW == 1
+/** Number of precomputed elements for the sliding window algorithm */
+#   define EscEcc_NUM_WINDOW_ELEMENTS  ( (Esc_SINT16)( 1U << (EscEcc_WINDOW_SIZE - 1U) ) )
+#endif
+
+/***************************************************************************
+ * 5. TYPE DEFINITIONS                                                     *
+ ***************************************************************************/
+
+/** Select used curve. See curve identifiers above for valid values. */
+typedef Esc_UINT8 EscEcc_CurveId;
+
+/** A field element with long number arithmetic */
+typedef struct
+{
+    /** the words of the long number */
+    Esc_UINT32 word[EscEcc_MAX_WORDS];
+} EscEcc_FieldElementT;
+
+
+/** A long field element with long number arithmetic,
+which is the result of a multiplication. */
+typedef struct
+{
+    /** the words of the long number */
+    Esc_UINT32 word[EscEcc_MAX_LONG_WORDS];
+} EscEcc_FieldElementLongT;
+
+/** Field parameters */
+typedef struct
+{
+    /** Precalculated P, used in barrett reduction */
+    EscEcc_FieldElementT precalc_my_p;
+    /** Prime */
+    EscEcc_FieldElementT prime_p;
+    /** Length of p in words */
+    Esc_UINT8 pLen;
+} EscEcc_FieldT;
+
+/** Elliptic curve point */
+typedef struct
+{
+    /** Type of the curve */
+    Esc_UINT8 type;
+    /** X-Coordinate */
+    EscEcc_FieldElementT x;
+    /** Y-Coordinate */
+    EscEcc_FieldElementT y;
+    /** Z-Coordinate */
+    EscEcc_FieldElementT z;
+} EscEcc_PointT;
+
+/** Elliptic curve */
+typedef struct
+{
+    /** Coefficient a */
+    EscEcc_FieldElementT coefficient_a;
+    /** Coefficient b */
+    EscEcc_FieldElementT coefficient_b;
+    /** Base point G */
+    EscEcc_PointT base_point_G;
+    /** Curve order n */
+    EscEcc_FieldT base_point_order_n;
+    /** Field parameters */
+    EscEcc_FieldT ecc_field_params;
+    /** Curve's key size in bits */
+    Esc_UINT16 keySizeBits;
+    /** Curve's key size in bytes */
+    Esc_UINT8 keySizeBytes;
+    /** Curve's key size in words */
+    Esc_UINT8 keySizeWords;
+    /** Maximum number of words of a EscEcc_FieldElementT */
+    Esc_UINT8 maxWords;
+    /** Maximum number of double words of a EscEcc_FieldElementT */
+    Esc_UINT8 maxWordsLong;
+    /** Curve ID **/
+    EscEcc_CurveId curveID;
+} EscEcc_CurveT;
+
+/** Public key for ECC */
+typedef struct
+{
+    /** Pointer to x */
+    Esc_UINT8 x[EscEcc_KEY_BYTES_MAX];
+    /** Pointer to y */
+    Esc_UINT8 y[EscEcc_KEY_BYTES_MAX];
+} EscEcc_PublicKeyT;
+
+/** ECDSA signature */
+typedef struct
+{
+    /** Bytes of r */
+    Esc_UINT8 r_bytes[EscEcc_KEY_BYTES_MAX];
+    /** Bytes of s */
+    Esc_UINT8 s_bytes[EscEcc_KEY_BYTES_MAX];
+} EscEcc_SignatureT;
+
+/***************************************************************************
+ * 6. FUNCTION PROTOTYPES                                                  *
+ ***************************************************************************/
+/**
+ * Adds two arrays of with a length of len with carry.
+ *
+ * \param[out] carry_out The carry.
+ * \param[out] c The result of the addition.
+ * \param[in] a Summand a.
+ * \param[in] b Summand b.
+ * \param[in] len Length of both summands.
+ */
+void
+EscEccWd_AddCLoop(
+    Esc_UINT32* carry_out,
+    Esc_UINT32 c[],
+    const Esc_UINT32 a[],
+    const Esc_UINT32 b[],
+    const Esc_UINT8 len );
+
+/**
+ * Subtracts two arrays of with a length of len with carry.
+ *
+ * \param[out] c The result of the subtraction.
+ * \param[out] borrow_out The borrow.
+ * \param[in] a Minuend a.
+ * \param[in] b subtrahend b.
+ * \param[in] len Length of both input values.
+ */
+void
+EscEccWd_SubBLoop(
+    Esc_UINT32 c[],
+    Esc_UINT32* borrow_out,
+    const Esc_UINT32 a[],
+    const Esc_UINT32 b[],
+    const Esc_UINT8 len );
+
+/* Field arithmetic */
+/**
+ * Converts a field element to a byte array (big endian)
+ *
+ * \param[in] input Field element to convert.
+ * \param[out] output Converted FE in byte array. Must have curve->keySizeBytes.
+ * \param[in] curve Underlying curve.
+ */
+void
+EscEccFe_ToUint8(
+    const EscEcc_FieldElementT* input,
+    Esc_UINT8 output[],
+    const EscEcc_CurveT* curve );
+
+/**
+ * Converts big endian byte array to a field element
+ *
+ * \param[in] input Big endian byte array.
+ * \param[in] inputLen Length of byte array.
+ * \param[out] output Resulting FE.
+ * \param[in] curve Underlying curve.
+ */
+void
+EscEccFe_FromUint8(
+    const Esc_UINT8 input[],
+    Esc_UINT32 inputLen,
+    EscEcc_FieldElementT* output,
+    const EscEcc_CurveT* curve );
+
+#if EscEcc_ECDSA_ENABLED == 1
+/**
+ * Converts a field element a long field element.
+ * a = b, unused most significant words are set to zero.
+ *
+ * \param[out] a resulting long field element.
+ * \param[in] b Input field element.
+ * \param[in] lenWords Length of input field element.
+ */
+void
+EscEccFe_ToLongElement(
+    EscEcc_FieldElementLongT* a,
+    const EscEcc_FieldElementT* b,
+    const Esc_UINT8 lenWords );
+#endif
+
+/**
+ * Set field element to zero.
+ *
+ * \param[out] a Resulting field element = 0.
+ */
+void
+EscEccFe_SetZero(
+    EscEcc_FieldElementT* a );
+
+/**
+ * Set field element to one.
+ *
+ * \param[out] a Resulting field element = 1.
+ */
+void
+EscEccFe_SetOne(
+    EscEcc_FieldElementT* a );
+
+/**
+ * Checks a field element for zero.
+ *
+ * \param[in] a Field element to check.
+ * \param[in] lenWords Length of input field element.
+ *
+ * \retval TRUE if the field element equals zero
+ * \retval FALSE if the field element is not zero.
+ */
+Esc_BOOL
+EscEccFe_IsZero(
+    const EscEcc_FieldElementT* a,
+    const Esc_UINT8 lenWords );
+
+/**
+ * Checks a field element for one.
+ *
+ * \param[in] a Field element to check.
+ * \param[in] lenWords Length of input field element.
+ *
+ * \retval TRUE if the field element equals one
+ * \retval FALSE if the field element is not one.
+ */
+Esc_BOOL
+EscEccFe_IsOne(
+    const EscEcc_FieldElementT* a,
+    const Esc_UINT8 lenWords );
+
+/**
+ * Compares two field elements.
+ *
+ * \param[in] a Field element a.
+ * \param[in] b Field element b.
+ * \param[in] lenWords Length of both input field elements.
+ *
+ * \retval +1 if field element a is greater than b (a > b).
+ * \retval -1 if field element a is smaller than b (a < b).
+ * \retval 0 if field elements have the same value (a == b).
+ */
+Esc_SINT8
+EscEccFe_AbsoluteCompare(
+    const EscEcc_FieldElementT* a,
+    const EscEcc_FieldElementT* b,
+    const Esc_UINT8 lenWords );
+
+/**
+ * Copy a field element to another one.
+ *
+ * Field Elements c and a can point to the same location (aliased).
+ *
+ * \param[out] c Copy of the input field element a.
+ * \param[in] a Field element to copy.
+ * \param[in] lenWords Length of both field elements.
+ */
+void
+EscEccFe_Assign(
+    EscEcc_FieldElementT* c,
+    const EscEcc_FieldElementT* a,
+    const Esc_UINT8 lenWords );
+
+/**
+ * Shifts a field element to the right by one bit.
+ *
+ * \param[in,out] a Field element to shift.
+ * \param[in] lenWords Length of both field elements.
+ */
+void
+EscEccFe_ShiftRight(
+    EscEcc_FieldElementT* a,
+    const Esc_UINT8 lenWords );
+
+/**
+ * Multiplies two field elements c = a * b.
+ *
+ * \param[out] c Resulting long field element.
+ * \param[in] a Field element a.
+ * \param[in] b Field element b.
+ * \param[in] curve Underlying curve.
+ */
+void
+EscEccFe_Multiply(
+    EscEcc_FieldElementLongT* c,
+    const EscEcc_FieldElementT* a,
+    const EscEcc_FieldElementT* b,
+    const EscEcc_CurveT* curve );
+
+/**
+ * Adds two field elements under modulus, c = a + b mod p.
+ *
+ * \param[out] c Resulting field element.
+ * \param[in] a Summand a.
+ * \param[in] b Summand b.
+ * \param[in] fGP Underlying field (includes modulus p).
+ * \param[in] lenWords Length of both field elements.
+ */
+void
+EscEccFe_ModularAdd(
+    EscEcc_FieldElementT* c,
+    const EscEcc_FieldElementT* a,
+    const EscEcc_FieldElementT* b,
+    const EscEcc_FieldT* fGP,
+    const Esc_UINT8 lenWords );
+
+/**
+ * Subtracts two field elements under modulus c = a - b mod p.
+ *
+ * \param[out] c Resulting field element.
+ * \param[in] a Minuend a.
+ * \param[in] b subtrahend b.
+ * \param[in] fGP Underlying field (includes modulus p).
+ * \param[in] lenWords Length of both field elements.
+ */
+void
+EscEccFe_ModularSub(
+    EscEcc_FieldElementT* c,
+    const EscEcc_FieldElementT* a,
+    const EscEcc_FieldElementT* b,
+    const EscEcc_FieldT* fGP,
+    const Esc_UINT8 lenWords );
+
+/**
+ * Reduce a field element z with modulus p using Barrett Reduction, r = z mod p
+ *
+ * \param[out] r Resulting field element.
+ * \param[in] z Long field element to reduce
+ * \param[in] fGP Underlying field (includes modulus p).
+ * \param[in] curve Underlying curve.
+ */
+void
+EscEccFe_ReduceBarrett(
+    EscEcc_FieldElementT* r,
+    const EscEcc_FieldElementLongT* z,
+    const EscEcc_FieldT* fGP,
+    const EscEcc_CurveT* curve );
+
+/**
+ * Multiplies two field elements under modulus p (prime of the ECC domain parameters), c = a * b mod p.
+ *
+ * Field Element c and one of the two operands (a or b) can point to the same location (aliased).
+ *
+ * \param[out] c Resulting field element.
+ * \param[in] a Field element a.
+ * \param[in] b Field element b.
+ * \param[in] curve Underlying curve.
+ */
+void
+EscEccFe_MultiplyModP(
+    EscEcc_FieldElementT* c,
+    const EscEcc_FieldElementT* a,
+    const EscEcc_FieldElementT* b,
+    const EscEcc_CurveT* curve );
+
+#if EscEcc_ECDSA_ENABLED == 1
+/**
+ * Multiplies two field elements under modulus n (base point order of the ECC domain parameters), c = a * b mod p.
+ *
+ * Field Element c and one of the two operands (a or b) can point to the same location (aliased).
+ *
+ * \param[out] c Resulting field element.
+ * \param[in] a Field element a.
+ * \param[in] b Field element b.
+ * \param[in] curve Underlying curve.
+ */
+void
+EscEccFe_MultiplyModN(
+    EscEcc_FieldElementT* c,
+    const EscEcc_FieldElementT* a,
+    const EscEcc_FieldElementT* b,
+    const EscEcc_CurveT* curve );
+#endif
+
+
+#if (EscEcc_USE_SLIDING_WINDOW == 1) || (EscEcc_ENABLE_SHAMIRS_TRICK == 1)
+/**
+ * Checks the given bit in a field element for zero.
+ *
+ * \param[in] c Field element.
+ * \param[in] index Bit to check.
+ *
+ * \retval TRUE if the bit index of the field element c is set.
+ * \retval FALSE if the bit index of the field element c is not set.
+ */
+Esc_BOOL
+EscEccFe_isBitSet(
+    const EscEcc_FieldElementT* c,
+    Esc_SINT16 index );
+#endif
+
+/* Point arithmetic */
+/**
+ * Sets the given point to the point of infinity.
+ *
+ * \param[out] pX Point which is set to infinity.
+ */
+void
+EscEccPt_SetInfinity(
+    EscEcc_PointT* pX );
+
+/**
+ * Checks if the given point is zero.
+ *
+ * \param[out] pX Point which is checked for zero.
+ * \param[in] curve Underlying curve.
+ *
+ * \retval TRUE if the point pX is zero.
+ * \retval FALSE if the point pX is not zero.
+ */
+Esc_BOOL
+EscEccPt_IsZero(
+    const EscEcc_PointT* pX,
+    const EscEcc_CurveT* curve );
+
+/**
+ * Checks if the given point is the point of infinity.
+ *
+ * \param[in] pX Point which is checked.
+ * \param[in] curve Underlying curve.
+ *
+ * \retval TRUE if the point pX is the point of infinity.
+ * \retval FALSE if the point pX is not the point of infinity.
+ */
+Esc_BOOL
+EscEccPt_IsInfinity(
+    const EscEcc_PointT* pX,
+    const EscEcc_CurveT* curve );
+
+/**
+ * Copy a point to another one.
+ *
+ * Points pY and pX can point to the same location (aliased).
+ *
+ * \param[out] pY Copy of the input point pX.
+ * \param[in] pX Point to copy.
+ * \param[in] curve Underlying curve.
+ */
+void
+EscEccPt_Assign(
+    EscEcc_PointT* pY,
+    const EscEcc_PointT* pX,
+    const EscEcc_CurveT* curve );
+
+/**
+ * Doubles a Jacobian point, pJ = 2 * pJ0.
+ *
+ * Points pJ and pJ0 can point to the same location (aliased).
+ *
+ * \param[out] pJ Jacobian point for the result.
+ * \param[in] pJ0 Point to double.
+ * \param[in] curve Underlying curve.
+ */
+void
+EscEccPt_JacobianDouble(
+    EscEcc_PointT* pJ,
+    const EscEcc_PointT* pJ0,
+    const EscEcc_CurveT* curve );
+
+/**
+ * Adds two Jacobian points, pJ = pJ0 + pJ1.
+ *
+ * Points pJ and one of the two operands (pJ0 or pJ1) can point to the same location (aliased).
+ *
+ * \param[out] pJ Jacobian point for the result.
+ * \param[in] pJ0 Summand pJ0.
+ * \param[in] pJ1 Summand pJ1.
+ * \param[in] curve Underlying curve.
+ */
+void
+EscEccPt_JacobianAdd(
+    EscEcc_PointT* pJ,
+    const EscEcc_PointT* pJ0,
+    const EscEcc_PointT* pJ1,
+    const EscEcc_CurveT* curve );
+
+/**
+ * Calculate random k according to Algo B.5.2 from FIPS 186-4 (page 64)
+ *
+ * \param[in] randomState Random state which may be required by your random implementation.
+ * \param[in] getRandomFunc Random function as specified in random.h
+ * \param[in] curve The selected elliptic curve.
+ * \param[out] k The generated random value k
+ *
+ * \return Esc_NO_ERROR if everything works fine.
+ */
+Esc_ERROR
+EscEcc_CalculateRandomK(
+    const EscEcc_CurveT* curve,
+    EscEcc_FieldElementT* k);
+
+
+/***************************************************************************
+ * 7. END                                                                  *
+ ***************************************************************************/
+
+#endif /* ESC__ECC_H_ */
