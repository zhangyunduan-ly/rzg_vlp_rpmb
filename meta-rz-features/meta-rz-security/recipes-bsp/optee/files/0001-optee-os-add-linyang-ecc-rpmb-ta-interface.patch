+uint32_t calculate_crc32(const uint8_t *data, uint32_t length)
+{
+    uint32_t crc = 0xFFFFFFFF; // CRC32 ÕłØÕ¦ŗÕĆ╝’╝łµĀćÕćåń║”Õ«Ü’╝ē
+    uint32_t i;
+
+    if (data == NULL || length == 0) {
+        return 0; // ķØ×µ│ĢĶŠōÕģź’╝īĶ┐öÕø×µŚĀµĢł CRC
+    }
+
+    for (i = 0; i < length; i++) {
+        // µ¤źĶĪ©µ│ĢĶ«Īń«Ś’╝īµĢłńÄćķ½śõ║ÄķĆÉõĮŹĶ«Īń«Ś
+        crc = (crc >> 8) ^ crc32_table[(crc & 0xFF) ^ data[i]];
+    }
+
+    return crc ^ 0xFFFFFFFF; // CRC32 µ£Ćń╗łÕ╝éµł¢ÕĆ╝
+}
