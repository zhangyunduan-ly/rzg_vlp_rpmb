+static TEE_Result ecdsa_sec_check_pubkey(uint32_t types, TEE_Param params[TEE_NUM_PARAMS])
+{
+    // ÕÅéµĢ░ÕłåķģŹ’╝ł4ÕÅéµĢ░ķÖÉÕłČ’╝ē’╝Ü
+    // params[0]’╝ÜĶŠōÕģź’╝īÕģ¼ķÆź’╝łpPubkey’╝īx+yÕłåķćÅ’╝īķĢ┐Õ║”õĖ║2*ń¦üķÆźķĢ┐Õ║”’╝ē
+    // params[1]’╝ÜĶŠōÕć║’╝īķ¬īĶ»üń╗ōµ×£’╝ł1=µłÉÕŖ¤’╝ī0=Õż▒Ķ┤ź’╝ī1ÕŁŚĶŖé’╝ē
+    // params[2]’╝Üµ£¬õĮ┐ńö©
+    // params[3]’╝Üµ£¬õĮ┐ńö©
+
+    // µÅÉÕÅ¢ĶŠōÕģźÕÅéµĢ░
+    uint8_t *pPubkey = (uint8_t *)params[0].memref.buffer;     // Õģ¼ķÆź
+    uint32_t pubkey_len = params[0].memref.size;               // Õģ¼ķÆźķĢ┐Õ║”
+    uint8_t *verify_result = (uint8_t *)params[1].memref.buffer; // ķ¬īĶ»üń╗ōµ×£ĶŠōÕć║
+    uint32_t result_buf_size = params[1].memref.size;          // ń╗ōµ×£ń╝ōÕå▓Õī║Õż¦Õ░Å
+    BOOL verify_success = FALSE;
+    uint8_t t_key_len;  // ń¦üķÆźķĢ┐Õ║”
+
+    // 1. µĀĪķ¬īÕÅéµĢ░ń▒╗Õ×ŗ
+    if (types != TEE_PARAM_TYPES(TEE_PARAM_TYPE_MEMREF_INPUT,    // Õģ¼ķÆź
+                                TEE_PARAM_TYPE_MEMREF_OUTPUT,   // ķ¬īĶ»üń╗ōµ×£
+                                TEE_PARAM_TYPE_NONE,            // µ£¬õĮ┐ńö©
+                                TEE_PARAM_TYPE_NONE)) {         // µ£¬õĮ┐ńö©
+        DMSG("Invalid parameter types (expected 1 input + 1 output + 2 unused)");
+        return TEE_ERROR_BAD_PARAMETERS;
+    }
+
+    // 2. ÕÅéµĢ░µ£ēµĢłµĆ¦µĀĪķ¬ī
+    if (!pPubkey || !verify_result) {
+        DMSG("NULL pointer in public key verification parameters");
+        return TEE_ERROR_BAD_PARAMETERS;
+    }
+
+    // 3. µĀĪķ¬īń╝ōÕå▓Õī║Õż¦Õ░Å
+    if (result_buf_size < 1) {
+        DMSG("Result buffer too small (need 1 byte, got %u)", result_buf_size);
+        return TEE_ERROR_SHORT_BUFFER;
+    }
+
+    // 4. µĀĪķ¬īÕģ¼ķÆźķĢ┐Õ║”ÕÉłµ│ĢµĆ¦
+    t_key_len = pubkey_len / 2;  // ń¦üķÆźķĢ┐Õ║” = Õģ¼ķÆźķĢ┐Õ║”/2
+    if (t_key_len != ECC256_PRIKEY_LEN && t_key_len != ECC384_PRIKEY_LEN) {
+        DMSG("Invalid key length: %u", t_key_len);
+        *verify_result = 0;
+        return TEE_ERROR_BAD_PARAMETERS;
+    }
+    if (pubkey_len != 2 * t_key_len) {
+        DMSG("Public key length invalid (expected %u, got %u)", 2*t_key_len, pubkey_len);
+        *verify_result = 0;
+        return TEE_ERROR_BAD_PARAMETERS;
+    }
+
+    // 5. Ķ░āńö©µĀĖÕ┐āÕģ¼ķÆźķ¬īĶ»üÕćĮµĢ░
+    DMSG("Starting ECC public key verification");
+    verify_success = Servp_ECC_PubKey_verification(pPubkey, t_key_len);
+    
+    // 6. Ķ«ŠńĮ«ĶŠōÕć║ń╗ōµ×£’╝ł1=µłÉÕŖ¤’╝ī0=Õż▒Ķ┤ź’╝ē
+    *verify_result = verify_success ? 1 : 0;
+    params[1].memref.size = 1;
+
+    if (!verify_success) {
+        DMSG("ECC public key verification failed");
+        return TEE_ERROR_BAD_STATE;  // Ķ┐öÕø×ķĆéÕĮōńÜäķöÖĶ»»ń▒╗Õ×ŗ
+    }
+
+    DMSG("ECC public key verification succeeded");
+    return TEE_SUCCESS;
+}
+
+static TEE_Result ecdh_sec_ecdh(uint32_t types, TEE_Param params[TEE_NUM_PARAMS])
+{
+    // 4ÕÅéµĢ░ÕłåķģŹ’╝Ü
+    // params[0]’╝ÜĶŠōÕģź’╝īÕŖĀÕ»åń¦üķÆź
+    // params[1]’╝ÜĶŠōÕģź’╝īAESĶ¦ŻÕ»åÕÅéµĢ░’╝łwrapped_key + IV’╝īµēōÕīģń╗ōµ×äõĮō’╝ē
+    // params[2]’╝ÜĶŠōÕģź’╝īÕ»╣µ¢╣ńÜäÕģ¼ķÆź
+    // params[3]’╝ÜĶŠōÕć║’╝īĶ«Īń«ŚÕŠŚÕł░ńÜäÕģ▒õ║½Õ»åķÆź
+
+    // ĶŠōÕģźÕÅéµĢ░µÅÉÕÅ¢
+    uint8_t *encrypted_priv_key = (uint8_t *)params[0].memref.buffer;
+    uint32_t encrypted_priv_len = params[0].memref.size;
+    aes_decrypt_params_t *aes_params = (aes_decrypt_params_t *)params[1].memref.buffer;
+    uint8_t *peer_pub_key = (uint8_t *)params[2].memref.buffer;
+    uint32_t pub_key_len = params[2].memref.size;
+    uint8_t *shared_secret = (uint8_t *)params[3].memref.buffer;
+    uint32_t secret_size = params[3].memref.size;
+
+    // Ķ¦ŻÕ»åńøĖÕģ│ÕÅśķćÅ
+    sce_aes_handle_t aes_handle = {0};
+    uint8_t plain_priv_key[ECC384_PRIKEY_LEN] = {0};
+    BOOL ecdhResult = FALSE;
+    TEE_Result tee_res = TEE_SUCCESS;
+    bool is_aes128 = false;
+    int i = 0;
+
+    // TA õ╝ÜĶ»ØńøĖÕģ│ÕÅśķćÅ
+    TEE_TASessionHandle aes_sess = TEE_HANDLE_NULL;
+    uint32_t ta_ret_orig = 0;
+    static const TEE_UUID aes_uuid = PTA_SCE_AES_UUID;
+
+    // 1. µĀĪķ¬īÕÅéµĢ░ń▒╗Õ×ŗ
+    if (types != TEE_PARAM_TYPES(TEE_PARAM_TYPE_MEMREF_INPUT,   // ÕŖĀÕ»åń¦üķÆź
+                                TEE_PARAM_TYPE_MEMREF_INPUT,   // AESĶ¦ŻÕ»åÕÅéµĢ░
+                                TEE_PARAM_TYPE_MEMREF_INPUT,   // Õ»╣µ¢╣Õģ¼ķÆź
+                                TEE_PARAM_TYPE_MEMREF_OUTPUT)) { // Õģ▒õ║½Õ»åķÆźĶŠōÕć║
+        DMSG("Invalid parameter types for ECDH");
+        return TEE_ERROR_BAD_PARAMETERS;
+    }
+
+    // 2. ÕÅéµĢ░µ£ēµĢłµĆ¦µĀĪķ¬ī
+    if (!encrypted_priv_key || !aes_params || !peer_pub_key || !shared_secret) {
+        DMSG("NULL pointer in ECDH parameters");
+        return TEE_ERROR_BAD_PARAMETERS;
+    }
+
+    // µĀĪķ¬īAESĶ¦ŻÕ»åÕÅéµĢ░ń╗ōµ×äõĮōÕż¦Õ░Å
+    if (params[1].memref.size != sizeof(aes_decrypt_params_t)) {
+        DMSG("Invalid AES params size (need %zu, got %u)",
+                     sizeof(aes_decrypt_params_t), params[1].memref.size);
+        return TEE_ERROR_BAD_PARAMETERS;
+    }
+
+    // µĀĪķ¬īń¦üķÆźķĢ┐Õ║”’╝ł256/384õĮŹ’╝ē
+    if (encrypted_priv_len != ECC256_PRIKEY_LEN && encrypted_priv_len != ECC384_PRIKEY_LEN) {
+        DMSG("Invalid encrypted private key length: %u", encrypted_priv_len);
+        return TEE_ERROR_BAD_PARAMETERS;
+    }
+
+    // µĀĪķ¬īÕģ¼ķÆźķĢ┐Õ║”’╝ē
+    if (pub_key_len != 2 * encrypted_priv_len) {
+        DMSG("Invalid public key length (need %u, got %u)",
+             2 * encrypted_priv_len, pub_key_len);
+        return TEE_ERROR_BAD_PARAMETERS;
+    }
+
+    // µĀĪķ¬īÕģ▒õ║½Õ»åķÆźĶŠōÕć║ń╝ōÕå▓Õī║Õż¦Õ░Å
+    if (secret_size < encrypted_priv_len) {
+        DMSG("Shared secret buffer too small (need %u, got %u)",
+                     encrypted_priv_len, secret_size);
+        return TEE_ERROR_SHORT_BUFFER;
+    }
+
+    // 3. ńĪ«Õ«ÜAESń▒╗Õ×ŗ’╝ł256õĮŹń¦üķÆźŌåÆAES-128’╝ī384õĮŹŌåÆAES-256’╝ē
+    if (encrypted_priv_len == ECC256_PRIKEY_LEN) {
+        is_aes128 = true;
+    }
+
+    // -------------------------- µēōÕ╝ĆAES TAõ╝ÜĶ»Ø --------------------------
+    tee_res = TEE_OpenTASession(&aes_uuid, TEE_TIMEOUT_INFINITE, 0, NULL, &aes_sess, &ta_ret_orig);
+    if (tee_res != TEE_SUCCESS) {
+        DMSG("Can't open session to AES PTA (0x%x)", tee_res);
+        return tee_res;
+    }
+
+    // -------------------------- ń¼¼õĖĆµŁź’╝ÜÕłØÕ¦ŗÕī¢AESĶ¦ŻÕ»åõĖŖõĖŗµ¢ć --------------------------
+    TEE_Param init_params[TEE_NUM_PARAMS] = {0};
+    uint32_t init_types = TEE_PARAM_TYPES(TEE_PARAM_TYPE_MEMREF_INOUT,
+                                         TEE_PARAM_TYPE_MEMREF_INPUT,
+                                         TEE_PARAM_TYPE_NONE,
+                                         TEE_PARAM_TYPE_NONE);
+    init_params[0].memref.buffer = &aes_handle;
+    init_params[0].memref.size = sizeof(sce_aes_handle_t);
+    init_params[1].memref.buffer = &aes_params->wrapped_key;  // õ╗Äń╗ōµ×äõĮōÕÅ¢wrapped_key
+    init_params[1].memref.size = sizeof(aes_params->wrapped_key);
+    // init_params[2].memref.buffer = aes_params->initial_vector; // õ╗Äń╗ōµ×äõĮōÕÅ¢IV
+    // init_params[2].memref.size = HW_SCE_AES_CBC_IV_BYTE_SIZE;
+
+    // µēōÕŹ░AESÕÅéµĢ░
+    DMSG("\r\nECDH - AES wrapped_key (size: %zu bytes): ", sizeof(aes_params->wrapped_key));
+    for (size_t i = 0; i < sizeof(aes_params->wrapped_key); i++) {
+        DMSG("%02x ", (unsigned int)((uint8_t *)&aes_params->wrapped_key)[i]);
+    }
+    // DMSG("\r\nECDH - AES initial_vector (size: %d bytes): ", HW_SCE_AES_CBC_IV_BYTE_SIZE);
+    // for (size_t i = 0; i < HW_SCE_AES_CBC_IV_BYTE_SIZE; i++) {
+    //     DMSG("%02x ", (unsigned int)aes_params->initial_vector[i]);
+    // }
+
+    // Ķ░āńö©TAńÜäĶ¦ŻÕ»åÕłØÕ¦ŗÕī¢ÕæĮõ╗ż
+    if (is_aes128) {
+        tee_res = TEE_InvokeTACommand(aes_sess, TEE_TIMEOUT_INFINITE,
+                                     PTA_CMD_AES128ECB_DecryptInit,
+                                     init_types, init_params, &ta_ret_orig);
+    } else {
+        tee_res = TEE_InvokeTACommand(aes_sess, TEE_TIMEOUT_INFINITE,
+                                     PTA_CMD_AES256ECB_DecryptInit,
+                                     init_types, init_params, &ta_ret_orig);
+    }
+    if (tee_res != TEE_SUCCESS) {
+        DMSG("ECDH - AES decrypt init failed (0x%x, TA ret: 0x%x)", tee_res, ta_ret_orig);
+        TEE_CloseTASession(aes_sess);
+        return tee_res;
+    }
+
+    // -------------------------- ń¼¼õ║īµŁź’╝Üµē¦ĶĪīń¦üķÆźĶ¦ŻÕ»å --------------------------
+    TEE_Param update_params[TEE_NUM_PARAMS] = {0};
+    uint32_t update_types = TEE_PARAM_TYPES(TEE_PARAM_TYPE_MEMREF_INOUT,
+                                          TEE_PARAM_TYPE_MEMREF_INPUT,
+                                          TEE_PARAM_TYPE_MEMREF_INOUT,
+                                          TEE_PARAM_TYPE_NONE);
+    update_params[0].memref.buffer = &aes_handle;
+    update_params[0].memref.size = sizeof(sce_aes_handle_t);
+    update_params[1].memref.buffer = encrypted_priv_key;
+    update_params[1].memref.size = encrypted_priv_len;
+    update_params[2].memref.buffer = plain_priv_key;
+    update_params[2].memref.size = encrypted_priv_len;
+
+    // Ķ░āńö©TAńÜäĶ¦ŻÕ»åµø┤µ¢░ÕæĮõ╗ż
+    if (is_aes128) {
+        tee_res = TEE_InvokeTACommand(aes_sess, TEE_TIMEOUT_INFINITE,
+                                     PTA_CMD_AES128ECB_DecryptUpdate,
+                                     update_types, update_params, &ta_ret_orig);
+    } else {
+        tee_res = TEE_InvokeTACommand(aes_sess, TEE_TIMEOUT_INFINITE,
+                                     PTA_CMD_AES256ECB_DecryptUpdate,
+                                     update_types, update_params, &ta_ret_orig);
+    }
+    if (tee_res != TEE_SUCCESS) {
+        DMSG("ECDH - Private key decryption failed (0x%x, TA ret: 0x%x)", tee_res, ta_ret_orig);
+        TEE_CloseTASession(aes_sess);
+        return tee_res;
+    }
+
+    // -------------------------- ń¼¼õĖēµŁź’╝ÜÕ«īµłÉĶ¦ŻÕ»åµōŹõĮ£ --------------------------
+    TEE_Param final_params[TEE_NUM_PARAMS] = {0};
+    uint32_t final_types = TEE_PARAM_TYPES(TEE_PARAM_TYPE_MEMREF_INOUT,
+                                          TEE_PARAM_TYPE_NONE,
+                                          TEE_PARAM_TYPE_NONE,
+                                          TEE_PARAM_TYPE_NONE);
+    final_params[0].memref.buffer = &aes_handle;
+    final_params[0].memref.size = sizeof(sce_aes_handle_t);
+
+    // Ķ░āńö©TAńÜäĶ¦ŻÕ»åµ£Ćń╗łÕæĮõ╗ż
+    if (is_aes128) {
+        tee_res = TEE_InvokeTACommand(aes_sess, TEE_TIMEOUT_INFINITE,
+                                     PTA_CMD_AES128ECB_DecryptFinal,
+                                     final_types, final_params, &ta_ret_orig);
+    } else {
+        tee_res = TEE_InvokeTACommand(aes_sess, TEE_TIMEOUT_INFINITE,
+                                     PTA_CMD_AES256ECB_DecryptFinal,
+                                     final_types, final_params, &ta_ret_orig);
+    }
+    if (tee_res != TEE_SUCCESS) {
+        DMSG("ECDH - Decryption finalization failed (0x%x, TA ret: 0x%x)", tee_res, ta_ret_orig);
+        TEE_CloseTASession(aes_sess);
+        return tee_res;
+    }
+
+    // -------------------------- Õģ│ķŚŁTAõ╝ÜĶ»Ø --------------------------
+    TEE_CloseTASession(aes_sess);
+
+    // -------------------------- µēōÕŹ░Ķ¦ŻÕ»åÕÉÄńÜäń¦üķÆź --------------------------
+    DMSG("\r\nECDH - Decrypted private key: ");
+    for (i = 0; i < encrypted_priv_len; i++) {
+        DMSG("%02x ", plain_priv_key[i]);
+    }
+    DMSG("\r\nECDH - Peer public key: ");
+    for (i = 0; i < pub_key_len; i++) {
+        DMSG("%02x ", peer_pub_key[i]);
+    }
+
+    // -------------------------- µē¦ĶĪīECDHÕ»åķÆźõ║żµŹó --------------------------
+    DMSG("Performing ECDH key exchange");
+    ecdhResult = Servp_ECDH(plain_priv_key, peer_pub_key, shared_secret, encrypted_priv_len);
+    if (!ecdhResult) {
+        DMSG("ECDH key exchange failed");
+        return TEE_ERROR_GENERIC;
+    }
+
+    // -------------------------- µēōÕŹ░Õģ▒õ║½Õ»åķÆź --------------------------
+    DMSG("\r\nECDH - Generated shared secret: ");
+    for (i = 0; i < encrypted_priv_len; i++) {
+        DMSG("%02x ", shared_secret[i]);
+    }
+
+    // -------------------------- Ķ«ŠńĮ«ĶŠōÕć║ķĢ┐Õ║” --------------------------
+    params[3].memref.size = encrypted_priv_len;
+
+    DMSG("ECDH key exchange completed successfully");
+    return TEE_SUCCESS;
+}
+
+TEE_Result TA_InvokeCommandEntryPoint(void __unused *session,
+				      uint32_t command,
+				      uint32_t param_types,
+				      TEE_Param params[4])
+{
+	switch (command) {
+        
+    case PTA_CMD_ECC_secp256r1_GenerateKeyPair:
+	case PTA_CMD_ECC_secp384r1_GenerateKeyPair:
+         DMSG("\r\nReady to generate key pair in TEE-OS");
+			return ecdsa_sec_keypair_generate(param_types, params);
+
+    case PTA_CMD_ECC_secp256r1_Sin:
+    case PTA_CMD_ECC_secp384r1_Sin:
+        DMSG("\r\nReady to Sin in TEE-OS!!!!!");
+        return ecdsa_sec_sign(param_types, params);
+
+    case PTA_CMD_ECC_secp256r1_SinVerify:
+    case PTA_CMD_ECC_secp384r1_SinVerify:
+        DMSG("\r\nReady to SinVerify in TEE-OS");
+        return ecdsa_sec_verify(param_types, params);
+
+    case PTA_CMD_ECC_secp256r1_CheckPubKey:
+    case PTA_CMD_ECC_secp384r1_CheckPubKey:
+        DMSG("\r\nReady to Check public key in TEE-OS");
+        return ecdsa_sec_check_pubkey(param_types, params);
+
+    case PTA_CMD_ECC_secp256r1_ECDH:
+    case PTA_CMD_ECC_secp384r1_ECDH:
+        DMSG("\r\nReady to do ECDH in TEE-OS");
+        return ecdh_sec_ecdh(param_types, params);
+
+	default:
+		EMSG("Command ID 0x%x is not supported", command);
+		return TEE_ERROR_NOT_SUPPORTED;
+	}
+}
