+               , (x[i&0x0f] = rol(tm,1)) )   
+               
+    Rl( a, b, c, d, e, F1, K1, x[ 0] );  
+    Rl( e, a, b, c, d, F1, K1, x[ 1] );  
+    Rl( d, e, a, b, c, F1, K1, x[ 2] );  
+    Rl( c, d, e, a, b, F1, K1, x[ 3] );  
+    Rl( b, c, d, e, a, F1, K1, x[ 4] );  
+    Rl( a, b, c, d, e, F1, K1, x[ 5] );  
+    Rl( e, a, b, c, d, F1, K1, x[ 6] );  
+    Rl( d, e, a, b, c, F1, K1, x[ 7] );  
+    Rl( c, d, e, a, b, F1, K1, x[ 8] );  
+    Rl( b, c, d, e, a, F1, K1, x[ 9] );  
+    Rl( a, b, c, d, e, F1, K1, x[10] );  
+    Rl( e, a, b, c, d, F1, K1, x[11] );  
+    Rl( d, e, a, b, c, F1, K1, x[12] );  
+    Rl( c, d, e, a, b, F1, K1, x[13] );  
+    Rl( b, c, d, e, a, F1, K1, x[14] );  
+    Rl( a, b, c, d, e, F1, K1, x[15] );  
+    Rl( e, a, b, c, d, F1, K1, M(16) );  
+    Rl( d, e, a, b, c, F1, K1, M(17) );  
+    Rl( c, d, e, a, b, F1, K1, M(18) );  
+    Rl( b, c, d, e, a, F1, K1, M(19) );  
+    Rl( a, b, c, d, e, F2, K2, M(20) );  
+    Rl( e, a, b, c, d, F2, K2, M(21) );  
+    Rl( d, e, a, b, c, F2, K2, M(22) );  
+    Rl( c, d, e, a, b, F2, K2, M(23) );  
+    Rl( b, c, d, e, a, F2, K2, M(24) );  
+    Rl( a, b, c, d, e, F2, K2, M(25) );  
+    Rl( e, a, b, c, d, F2, K2, M(26) );  
+    Rl( d, e, a, b, c, F2, K2, M(27) );  
+    Rl( c, d, e, a, b, F2, K2, M(28) );  
+    Rl( b, c, d, e, a, F2, K2, M(29) );  
+    Rl( a, b, c, d, e, F2, K2, M(30) );  
+    Rl( e, a, b, c, d, F2, K2, M(31) );  
+    Rl( d, e, a, b, c, F2, K2, M(32) );  
+    Rl( c, d, e, a, b, F2, K2, M(33) );  
+    Rl( b, c, d, e, a, F2, K2, M(34) );  
