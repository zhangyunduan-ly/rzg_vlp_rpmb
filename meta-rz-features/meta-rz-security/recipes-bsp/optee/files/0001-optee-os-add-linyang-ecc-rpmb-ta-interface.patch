+
+#if Esc_HAS_INT64 == 0
+static void
+EscEccWd_Multiply(
+    Esc_UINT32* c_high,
+    Esc_UINT32* c_low,
+    Esc_UINT32 a,
+    Esc_UINT32 b );
+#endif
+
+static Esc_UINT32
+EscEccWd_FromOctets(
